<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Usuarios - NeuPsi-Pro</title>
    <link rel="stylesheet" href="/css/output.css">
</head>
<body class="bg-[#002B7A] flex h-screen lg:flex-row transition-transform duration-300">

    <div id="overlay" class="fixed inset-0 bg-black/40 hidden md:hidden"></div>

    <%- include('../partials/sidebar') %>

    <div class="flex-1 flex flex-col min-w-0">

        <%- include('../partials/header') %>

        <main class="flex-1 px-4 md:px-6 pt-6 pb-0 overflow-hidden">
            <div class="w-full h-full bg-gray-100 rounded-tl-3xl rounded-tr-3xl px-6 pt-6 pb-0 flex flex-col gap-4">

                <!--Title, search, signUser-->
                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
                    <h1 class="text-2xl font-bold text-[#1E1E1E]">Usuarios</h1>

                    <div class="flex items-center gap-3">
                        <button
                            onclick="signUpUser()"
                            class="btn-mini w-full sm:w-[260px] md:w-[306px] bg-[#C89B3C]">
                            <svg xmlns="http://www.w3.org/2000/svg" class="white-icon-mini" fill="none"
                                viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
                            </svg>
                            <span>Registrar Usuario</span>
                        </button>

                        <div class="search-input">
                            <input
                                id="search-input"
                                type="text"
                                class="search-input_field"
                                placeholder="Buscar"/>
                            <svg xmlns="http://www.w3.org/2000/svg" class="search-icon" fill="none"
                                viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M21 21l-4.35-4.35M17 11A6 6 0 105 11a6 6 0 0012 0z"/>
                            </svg>
                        </div>
                    </div>
                </div>

                <!-- Table -->
                <div class="flex-1 overflow-auto bg-white rounded-xl shadow-sm border-t-4 border-[#002B7A] px-3 md:px-6">
                <table class="w-full border-collapse text-sm md:text-base">
                    <thead>
                        <tr class="border-b-2 border-gray-200">
                            <th class="py-2.5 px-10 text-left font-semibold text-gray-700 w-40">Folio</th>
                            <th class="py-2.5 px-10 text-left font-semibold text-gray-700">Nombre</th>
                            <th class="py-2.5 px-10 text-center font-semibold text-gray-700 w-60">Consultar Información</th>
                        </tr>
                    </thead>
                    <tbody id="users-tbody">
                        <tr>
                            <td colspan="3" class="py-10 text-center text-gray-400">Cargando...</td>
                        </tr>
                    </tbody>
                </table>
            </div>

                <div id="pagination" class="flex items-center justify-center gap-3 py-3"></div>

            </div>
        </main>
    </div>

    <script src="/js/sidebar.js"></script>
    <%- include('./_scriptUserList') %>
</body>
</html>