<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Usuario - Golondrina</title>
    <link rel="stylesheet" href="/css/output.css">
</head>

<body class="bg-[#0A2472] flex h-screen lg:flex-row transition-transform duration-300">

    <div id="overlay" class="fixed inset-0 bg-black/40 hidden md:hidden"></div>

    <!-- Sidebar -->
     <%- include('../partials/sidebar.ejs') %>

    <div class="flex-1 flex flex-col overflow-hidden">

        <!-- Header -->
        <%- include('../partials/header.ejs') %>

        <!-- Main -->
        <main class="flex-1 p-3 sm:p-4 md:p-6 pb-0 md:pl-0 overflow-hidden flex flex-col">

            <div class="flex-1 min-h-0 w-full bg-white rounded-tl-2xl rounded-tr-2xl md:rounded-tl-3xl md:rounded-tr-3xl overflow-y-auto px-3 sm:px-4 md:px-6 py-3 sm:py-4 md:py-6">
                <div class="flex items-center gap-4 mb-5">
                    <a href="/users/<%= id_user %>">
                        <button class="cursor-pointer pb">
                            <svg class="black-icon shrink-0 size-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 9-3 3m0 0 3 3m-3-3h7.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                            </svg>
                        </button>
                    </a>
                    <h1 class="text-2xl font-bold text-[#1E1E1E]">
                        Entrevista inicial
                    </h1>
                </div>
                <hr class="border-3 rounded-2xl border-[#002B7A] mb-4">
                <div id="sections-stepper">
                    <%- include('../partials/sections.ejs') %>
                </div>

                <!-- Contenido -->
                <div class="w-full pt-0 p-3">

                    <div class="grid grid-cols-1 sm:grid-cols-2 pb-3">
                        <!--Step title-->
                        <div>
                            <h1 id="step-title" class="font-bold section_title"></h1>
                        </div>

                        <!--Navegation buttons-->
                        <%- include('../partials/navButtons.ejs') %>
                    </div>

                    <!-- Content -->
                    <div class="flex flex-col lg:grid lg:grid-cols-5 gap-6">

                        <!-- Sidebar -->
                        <div id="sidebar-timeline" class="z-10">
                            <%- include('../partials/sectionsSidebar.ejs') %>
                        </div>

                        <div id="dynamic-content" class="md:col-span-4 min-w-0">
                            <!-- Substep Title -->
                            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
                                <h2 id="subStep-title" class="section_title"></h2>
                            </div>

                            <!-- IDENTIFICATION 1.1 -->
                            <div id="identification-section-1" class="identification-content hidden">
                                <%- include('./identification/subStep1/subStep1.ejs') %>
                            </div>

                            <!-- FINANCIAL 2.1 -->
                            <div id="financial-section-1" class="financial-content hidden">
                                <div class="grid md:grid-cols-2 gap-4">

                                    <div>
                                        <%- include('./financial/subStep1/incomes.ejs') %>
                                    </div>

                                    <div>
                                        <%- include('./financial/subStep1/expenses.ejs') %>
                                    </div>

                                </div>
                            </div>

                            <!-- FINANCIAL 2.2 -->
                            <div id="financial-section-2"
                                class="financial-content hidden">

                                <div>
                                    <%- include('./financial/subStep2/esc.ejs') %>
                                </div>

                            </div>

                            <!-- FINANCIAL 2.3 -->
                            <div id="financial-section-3"
                                class="financial-content hidden">

                                <div>
                                    <%- include('./financial/subStep3/amai.ejs') %>
                                </div>
                            </div>

                            <!-- FINANCIAL 2.4 -->
                            <div id="financial-section-4"
                                class="financial-content hidden">

                                <div>
                                    <%- include('./financial/subStep4/results.ejs') %>
                                </div>
                            </div>

                        </div>

                    </div>

                    <!--Navegation buttons-->
                    <%- include('../partials/navButtons.ejs') %>
                </div>
            </div>
        </main>

    </div>

    <!-- Script -->
    <script src="/js/initialInterview/identification/imcCalculator.js"></script>
    <script src="/js/initialInterview/identificationMapper.js"></script>
    <script src="/js/initialInterview/identificationBuilder.js"></script>
    <script src="/js/initialInterview/financial/financialMapper.js"></script>
    <script src="/js/sidebar.js"></script>
    <script src="/js/initialInterview/sectionsStepper.js"></script>
    <script src="/js/initialInterview/sidebarTimeline.js"></script>
    <script src="/js/initialInterview/financial/financialBuilder.js"></script>

    <!------------------------ Load Content Functions ------------------------>
    <script>
        // Total subSteps per phase (current_step), used to know the navigation boundaries
        const PHASE_SUBSTEPS = { 1: 1, 2: 4 };

        // Update nav buttons: hidden only at the very first/last subStep of the whole interview
        function updateNavigationButtons(phase, currentSection) {

            const isFirst = phase === 1 && currentSection === 1;
            const isLast = phase === 2 && currentSection === PHASE_SUBSTEPS[2];

            document.querySelectorAll('.prevBtn').forEach(button => {

                if (isFirst) {
                    button.classList.add('opacity-0', 'pointer-events-none');
                } else {
                    button.classList.remove('opacity-0', 'pointer-events-none');
                }
            });

            document.querySelectorAll('.nextBtn').forEach(button => {

                if (isLast) {
                    button.classList.add('opacity-0', 'pointer-events-none');
                } else {
                    button.classList.remove('opacity-0', 'pointer-events-none');
                }
            });
        }

        // ----- Functions that set titles ------------------------------------

        // Set by step
        function setStepTitle(data) {
            const steptitle = document.getElementById('step-title');

            if (data.current_step === 1) {

                steptitle.textContent =
                    '1. Ficha de Identificación';

            } else if (data.current_step === 2) {

                steptitle.textContent =
                    '2. Nivel Socioeconómico';

            } else if (data.current_step === 3) {

                steptitle.textContent =
                    '3. Historia Clínica';

            } else {

                steptitle.textContent =
                    'Sección no encontrada';
            }
        }

        // Set by Substep
        function setSubStepTitle(data) {
            const subStepTitle = document.getElementById('subStep-title');

            if (data.current_step === 1) {

                if (data.current_section === 1) {
                    subStepTitle.textContent = '1.1 Datos Personales';
                }

            } else if (data.current_step === 2) {

                if (data.current_section === 1) {
                    subStepTitle.textContent = '2.1 Ingresos y Egresos';

                } else if (data.current_section === 2) {
                    subStepTitle.textContent = '2.2 ESC Gubernamental';

                } else if (data.current_section === 3) {
                    subStepTitle.textContent = '2.3 Cuestionario AMAI';

                } else if (data.current_section === 4) {
                    subStepTitle.textContent = '2.4 Resumen de Resultados';
                }
            }
        }

        // Get content by substep ---------------------------------------------
        async function loadSection(section) {

            try {
                const res = await fetch(
                    `/users/${id_user}/initial-interview/api/${id_user}/financial/${section}`
                );

                const data = await res.json();
                console.log('DATA: ', data);

                if (!res.ok) {
                    console.error(data.error);
                    return;
                }

                window.financialData = data;

                // update sections state
                window.sectionsState = {
                    currentStep: data.current_step,
                    completedSteps: data.data.completedSteps,
                    subStep: data.current_section
                };

                // update sidebar state
                window.sidebarState = {
                    currentStep: data.current_section,
                    completedSteps: data.data.completedSubSteps,
                };

                setSubStepTitle(data);
                setFinancialContent(data);
                updateNavigationButtons(data.current_step, data.current_section);

                window.sidebarState.phase = data.current_step;
                window.sidebarState.currentStep = section;

                if (window.renderSidebar) {
                    window.renderSidebar();
                }

                if (window.renderSections) {
                    window.renderSections();
                }

                setTimeout(() => {
                    window.renderFinancialData?.();
                }, 0);

            } catch (err) {
                console.error(err);
            }
        }

        // ----- Functions that set content -----------------------------------

        // Financial step Content
        function setFinancialContent(data) {

            // Hidde all
            document.querySelectorAll('.financial-content')
                .forEach(section => {
                    section.classList.add('hidden');
                });

            // Chance the correct substep
            const activeSection =
                document.getElementById(
                    `financial-section-${data.current_section}`
                );

            if (activeSection) {
                activeSection.classList.remove('hidden');
            }
        }
        
        // Identification step Content
        function setIdentificationContent(data) {

            // Hidde all
            document.querySelectorAll('.identification-content')
                .forEach(section => {
                    section.classList.add('hidden');
                });

            // Chance the correct substep
            const activeSection =
                document.getElementById(
                    `identification-section-${data.current_section}`
                );

            if (activeSection) {
                activeSection.classList.remove('hidden');
            }
        }

        // Set Content
        function setContent(data) {
            if (data.current_step === 1) {
                setIdentificationContent(data);
            } else if (data.current_step === 2) {
                setFinancialContent(data);
            }
        }

        // Get content by identification subStep ------------------------------
        async function loadIdentificationSection(section) {

            try {
                const res = await fetch(
                    `/users/${id_user}/initial-interview/api/${id_user}/identification/${section}`
                );

                const data = await res.json();
                console.log('DATA: ', data);

                if (!res.ok) {
                    console.error(data.error);
                    return;
                }

                window.identificationData = data;

                // update sections state
                window.sectionsState = {
                    currentStep: data.current_step,
                    completedSteps: data.data.completedSteps,
                    subStep: data.current_section
                };

                // update sidebar state (identification has no per-subStep completion list)
                window.sidebarState = {
                    phase: data.current_step,
                    currentStep: data.current_section,
                    completedSteps: [],
                };

                setSubStepTitle(data);
                setIdentificationContent(data);
                updateNavigationButtons(data.current_step, data.current_section);

                if (window.renderSidebar) {
                    window.renderSidebar();
                }

                if (window.renderSections) {
                    window.renderSections();
                }

                setTimeout(() => {
                    window.mapSubStep1?.(window.identificationData.data);
                }, 0);

            } catch (err) {
                console.error(err);
            }
        }

        // Load identification step content
        async function loadIdentification() {
            try {

                await loadIdentificationSection(1);

                const data = window.identificationData;

                // Set titles
                setStepTitle(data);

                window.sectionsState = {
                    currentStep: data.current_step,
                    completedSteps: data.data.completedSteps,
                    subStep: data.current_section
                };

                if (window.renderSections) {
                    window.renderSections();
                }

            } catch (err) {
                console.error(err);
            }
        }

        // Load financial step content
        async function loadFinancial() {
            try {

                await loadSection(1);

                const data = window.financialData;

                // Set titles
                setStepTitle(data);

                const refEl = document.getElementById("refNumber");
                if (refEl) refEl.textContent = data.refNumber || "";

                window.sectionsState = {
                    currentStep: data.current_step,
                    completedSteps: data.data.completedSteps,
                    subStep: data.current_section
                };

                if (window.renderSections) {
                    window.renderSections();
                }

            } catch (err) {
                console.error(err);
            }
        }

        // ----- Cross-phase navigation orchestration --------------------------
        // 1 = Ficha de Identificación, 2 = Nivel Socioeconómico (financiero)

        // Get the loaded GET payload of the active phase
        function getActivePhaseData() {
            return window.currentPhase === 1
                ? window.identificationData
                : window.financialData;
        }

        // Save the active subStep of the active phase
        async function saveActiveSection(section) {
            return window.currentPhase === 1
                ? saveIdentificationSection(section)
                : saveSection(section);
        }

        // Load and render a given phase/subStep, switching phases when needed
        async function goToSection(phase, section) {

            window.currentPhase = phase;

            if (phase === 1) {
                await loadIdentificationSection(section);
            } else {
                await loadSection(section);
            }

            const data = getActivePhaseData();

            setStepTitle(data);
            setSubStepTitle(data);
            setContent(data);
            updateNavigationButtons(phase, section);

            window.sidebarState.phase = phase;
            window.sidebarState.currentStep = section;

            if (window.renderSidebar) {
                window.renderSidebar();
            }
        }

        const id_user = "<%= id_user %>";
        window.currentPhase = 1;

        // Entry point: start at Identification, jumping to Financial only if it's already completed
        async function loadInitialInterview() {

            await loadIdentification();

            const completedSteps = window.identificationData?.data?.completedSteps || [];

            if (completedSteps.includes(1)) {
                await goToSection(2, 1);
            }
        }

        loadInitialInterview();

        // ---------------------------- LISTENERS ----------------------------

        // Listener for change substep (delegated: the sidebar subSteps are rebuilt per phase)
        document.addEventListener('click', async (e) => {

            const stepEl = e.target.closest('#sidebar-timeline .timeline-step');
            if (!stepEl) return;

            const phase = window.currentPhase;
            const current = getActivePhaseData().current_section;
            const section = Number(stepEl.dataset.step);

            if (section === current) return;

            // Save current section before changing
            await saveActiveSection(current);

            await goToSection(phase, section);
        });

        // NEXT buttons
        document.querySelectorAll('.nextBtn').forEach(button => {

            button.addEventListener('click', async () => {

                const phase = window.currentPhase;
                const current = getActivePhaseData().current_section;
                const total = PHASE_SUBSTEPS[phase];

                await saveActiveSection(current);

                if (current < total) {
                    await goToSection(phase, current + 1);
                } else if (phase < 2) {
                    await goToSection(phase + 1, 1);
                }
            });
        });

        // PREVIOUS buttons
        document.querySelectorAll('.prevBtn').forEach(button => {

            button.addEventListener('click', async () => {

                const phase = window.currentPhase;
                const current = getActivePhaseData().current_section;

                // Save current section before changing
                await saveActiveSection(current);

                if (current > 1) {
                    await goToSection(phase, current - 1);
                } else if (phase > 1) {
                    await goToSection(phase - 1, PHASE_SUBSTEPS[phase - 1]);
                }
            });
        });

        // No negative values
        document.querySelectorAll('input[type="number"]').forEach(input => {

            input.addEventListener('keydown', (e) => {

                if (e.key === '-' || e.key === '+' || e.key === 'e') {
                    e.preventDefault();
                }
            });
        });
    </script>

    <!------------------------ Save Content Functions ------------------------>
    <script>

        // PATCH Section Content
        async function saveSection (section) {
            try {
                
                const body = buildSection(section);
                console.log('body: ', body);
                const res = await fetch(
                `/users/${id_user}/initial-interview/api/${id_user}/financial/${section}`,
                {
                    method: 'PATCH',
                    headers: {
                    'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(body),
                }
                );

                const data = await res.json();

                if (!res.ok) {
                    console.error(data.error);
                    return false;
                }

                return true;

            } catch (err) {

                console.error(err);
                return false;
            }
        }

        // PATCH Identification Section Content
        async function saveIdentificationSection (section) {
            try {

                const body = buildIdentificationSection(section);
                console.log('body: ', body);
                const res = await fetch(
                `/users/${id_user}/initial-interview/api/${id_user}/identification/${section}`,
                {
                    method: 'PATCH',
                    headers: {
                    'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(body),
                }
                );

                const data = await res.json();

                if (!res.ok) {
                    console.error(data.error);
                    return false;
                }

                return true;

            } catch (err) {

                console.error(err);
                return false;
            }
        }
    </script>

</body>
</html>