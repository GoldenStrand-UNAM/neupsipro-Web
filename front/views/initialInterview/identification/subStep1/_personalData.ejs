<div>
    <h2 class="section_title">Datos Generales de la Entrevista</h2>

    <div class="mt-4 space-y-4">
        <!--Interview date-->
        <div>
            <label class="input_label">Fecha de la entrevista</label>
            <input type="date" id="interviewDate" class="input">
        </div>

        <!--Interviewer name-->
        <div>
            <label class="input_label">Nombre del entrevistador</label>
            <input type="text" id="interviewerName" maxlength="80" class="input" placeholder="Nombre completo">
            <p class="text-xs text-gray-400 mt-1">Máximo 80 caracteres</p>
        </div>

        <!--Support student name-->
        <div>
            <label class="input_label">Nombre del estudiante de apoyo</label>
            <input type="text" id="supportStudentName" maxlength="80" class="input" placeholder="Nombre completo">
        </div>

        <!--Companions name-->
        <div>
            <label class="input_label">Nombre de los acompañantes</label>
            <input type="text" id="companionsName" maxlength="80" class="input" placeholder="Nombre completo">
        </div>

        <!--Companion relation-->
        <div>
            <label class="input_label">Parentesco con el acompañante</label>
            <input type="text" id="companionRelation" maxlength="30" class="input" placeholder="Ej. Madre, padre, tutor">
        </div>

        <!--Address-->
        <div>
            <label class="input_label">Domicilio</label>
            <input type="text" id="address" maxlength="120" class="input" placeholder="Calle, número, colonia, municipio">
        </div>

        <!--Proof of address-->
        <div>
            <label class="input_label">Comprobante de domicilio</label>
            <input type="text" id="proofAddress" maxlength="60" class="input" placeholder="Tipo de comprobante presentado">
        </div>

        <!--Healthcare system-->
        <div>
            <label class="input_label">Sistema de salud</label>
            <input type="text" id="healthcareSystem" maxlength="60" class="input" placeholder="Ej. IMSS, ISSSTE, particular">
        </div>

        <!--Religion-->
        <div>
            <label class="input_label">Religión</label>
            <input type="text" id="religion" maxlength="40" class="input" placeholder="Religión que profesa">
        </div>

        <!--Residence-->
        <div>
            <label class="input_label">Lugar de residencia</label>
            <input type="text" id="residence" maxlength="60" class="input" placeholder="Ciudad, estado">
        </div>

        <!--Ocupation-->
        <div>
            <label class="input_label">Ocupación</label>
            <input type="text" id="ocupation" maxlength="60" class="input" placeholder="Ocupación actual">
        </div>

        <!--Schooling-->
        <div>
            <label class="input_label">Escolaridad</label>

            <select id="schooling" class="select input text-gray-400">
                <option disabled selected value="">Selecciona una opción</option>

                <option value="Sin escolaridad">Sin escolaridad</option>
                <option value="Primaria">Primaria</option>
                <option value="Secundaria">Secundaria</option>
                <option value="Bachillerato">Bachillerato</option>
                <option value="Licenciatura">Licenciatura</option>
                <option value="Posgrado">Posgrado</option>
            </select>
        </div>

        <!--Father's schooling-->
        <div>
            <label class="input_label">Escolaridad del padre</label>

            <select id="fathersSchooling" class="select input text-gray-400">
                <option disabled selected value="">Selecciona una opción</option>

                <option value="Sin escolaridad">Sin escolaridad</option>
                <option value="Primaria">Primaria</option>
                <option value="Secundaria">Secundaria</option>
                <option value="Bachillerato">Bachillerato</option>
                <option value="Licenciatura">Licenciatura</option>
                <option value="Posgrado">Posgrado</option>
            </select>
        </div>

        <!--Mother's schooling-->
        <div>
            <label class="input_label">Escolaridad de la madre</label>

            <select id="mothersSchooling" class="select input text-gray-400">
                <option disabled selected value="">Selecciona una opción</option>

                <option value="Sin escolaridad">Sin escolaridad</option>
                <option value="Primaria">Primaria</option>
                <option value="Secundaria">Secundaria</option>
                <option value="Bachillerato">Bachillerato</option>
                <option value="Licenciatura">Licenciatura</option>
                <option value="Posgrado">Posgrado</option>
            </select>
        </div>
    </div>
</div>
