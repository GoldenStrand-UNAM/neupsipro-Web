<div>
    <h2 class="section_title">Integrantes del Hogar</h2>

    <div class="mt-4 space-y-4">
        <!--Number of family members-->
        <div>
            <label class="input_label">Número de integrantes de la familia</label>
            <input type="number" min="0" step="1" id="numberFamilyMembers" class="input" placeholder="Cantidad de integrantes">
        </div>

        <!--Roomie info-->
        <div>
            <label class="input_label">¿Con quién vive?</label>
            <input type="text" id="roomieInfo" maxlength="150" class="input" placeholder="Ej. Vive con sus padres y hermanos">
            <p class="text-xs text-gray-400 mt-1">Máximo 150 caracteres</p>
        </div>

        <!--Additional info-->
        <div>
            <label class="input_label">Información adicional sobre problemas de salud familiares</label>
            <input type="text" id="aditionalInfo" maxlength="400" class="input" placeholder="Describe información relevante sobre la familia">
            <p class="text-xs text-gray-400 mt-1">Máximo 400 caracteres</p>
        </div>
    </div>
</div>