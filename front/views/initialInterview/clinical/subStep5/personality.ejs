<div>
    <%
        const fields = [
            { id: 'depression',          label: 'Depresión' },
            { id: 'anxiety',             label: 'Ansiedad' },
            { id: 'stress',              label: 'Estrés' },
            { id: 'sleepingProblems',    label: 'Sueño' },
            { id: 'easilyAngry',         label: 'Me enojo fácilmente' },
            { id: 'veryEmotional',       label: 'Muy emocional (p. ej., lloro con facilidad)' },
            { id: 'frustratedEasily',    label: 'Me frustro fácilmente' },
            { id: 'changesComments',     label: '¿Alguien le ha comentado sobre cambios en su pensamiento, conducta, estado de ánimo o personalidad?' },
            { id: 'familyProblem',       label: 'En este momento, ¿tiene algún problema marital / familiar?' },
            { id: 'legalProblem',        label: 'En este momento, ¿tiene algún problema legal?' },
            { id: 'legalProblemDesc',    label: 'Si tiene problema legal, describa' },
            { id: 'financeProblem',      label: 'En este momento, ¿tiene algún problema manejo de casa o del dinero?' },
            { id: 'drivingProblem',      label: 'En este momento, ¿tiene algún problema para conducir?' },
            { id: 'controlProblems',     label: 'Observación clínica: Nivel general de introspección del entrevistado' },
        ];
    %>

    <div class="space-y-4 max-w-xl mt-3">
        <% fields.forEach(function (f) { %>
            <div>
                <label class="input_label"><%= f.label %></label>
                <input type="text" id="<%= f.id %>" maxlength="100" class="input" placeholder="Notas" oninput="this.value = this.value.replace(/[^\w\s.,;:?!()áéíóúÁÉÍÓÚñÑüÜ-]/g, '')">
                <span class="char-counter text-xs text-gray-400 mt-1" data-target="<%= f.id %>" data-max="100">0/100</span>
            </div>
        <% }); %>
    </div>
</div>
