<div>
    <%
        const fields = [
            { id: 'sensationLoss',        label: 'Pérdida de la sensación (indique en qué parte/s del cuerpo)' },
            { id: 'visionDif',            label: 'Dificultad para ver' },
            { id: 'wearsGlasses',         label: 'Usa lentes' },
            { id: 'blurryVision',         label: 'Vista borrosa' },
            { id: 'hearingLoss',          label: 'Dificultad para escuchar' },
            { id: 'ringingEars',          label: 'Zumbido en los oídos' },
            { id: 'pain',                 label: 'Dolor' },
            { id: 'phantomLimb',          label: 'Presencia de miembro fantasma' },
            { id: 'phantomLimbDesc',      label: 'Describa (tipo y frecuencia)' },
            { id: 'phantomLimbPain',      label: 'Presencia de miembro fantasma doloroso' },
            { id: 'phantomLimbPainDesc',  label: 'Describa (tipo y frecuencia)' },
        ];
    %>

    <div class="space-y-4 max-w-xl mt-3">
        <% fields.forEach(function (f) { %>
            <div>
                <label class="input_label"><%= f.label %></label>
                <input type="text" id="<%= f.id %>" maxlength="100" class="input" placeholder="Notas" oninput="this.value = this.value.replace(/[^\w\s.,;:?!()áéíóúÁÉÍÓÚñÑüÜ-]/g, '')">
                <span class="char-counter text-xs text-gray-400 mt-1" data-target="<%= f.id %>" data-max="100">0/100</span>
            </div>
        <% }); %>
    </div>
</div>
