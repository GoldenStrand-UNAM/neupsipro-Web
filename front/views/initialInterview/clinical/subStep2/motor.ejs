<div>
    <%
        const fields = [
            { id: 'weakness',        label: 'Debilidad (indique la parte del cuerpo)' },
            { id: 'movementProblem', label: 'Problema con movimientos motores finos' },
            { id: 'tremor',          label: 'Temblor' },
            { id: 'tics',            label: 'Tics' },
            { id: 'balanceProblems', label: 'Problema de equilibrio' },
            { id: 'falls',           label: 'Caídas / Frecuencia de caídas' },
        ];
    %>

    <div class="space-y-4 max-w-xl mt-3">
        <% fields.forEach(function (f) { %>
            <div>
                <label class="input_label"><%= f.label %></label>
                <div class="flex flex-wrap items-center gap-2">
                    <select id="<%= f.id %>_presence" class="input w-40 sm:w-48 flex-shrink-0">
                        <option value="">Selecciona una opción</option>
                        <option value="Positivo">Positivo</option>
                        <option value="Negativo">Negativo</option>
                    </select>
                    <input type="text" id="<%= f.id %>" maxlength="90" class="input flex-1 min-w-[140px]" placeholder="Notas">
                </div>
                <span class="char-counter text-xs text-gray-400 mt-1" data-target="<%= f.id %>" data-max="90">0/90</span>
            </div>
        <% }); %>
    </div>
</div>
