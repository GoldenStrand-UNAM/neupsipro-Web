<div class="space-y-6">
  <h2 class="section_title">3.2 Motor</h2>
  <div class="mt-4 space-y-4">

    <!-- weakness -->
    <div>
      <label class="input_label">Debilidad (indicar parte del cuerpo)</label>
      <div class="flex gap-2 mt-1">
        <select id="weakness" class="input w-40 flex-shrink-0 bg-white border border-gray-300 rounded-md text-sm text-gray-500" disabled>
          <option value="" disabled selected>Selecciona una opción</option>
          <option value="si">Sí</option>
          <option value="no">No</option>
        </select>
        <input type="text" id="weaknessNotes" placeholder="Notas"
          class="input flex-1 bg-white border border-gray-300 rounded-md text-sm text-gray-500 placeholder-gray-400" disabled/>
      </div>
    </div>

    <!-- fine motor -->
    <div>
      <label class="input_label">Problema con movimientos motores finos</label>
      <div class="flex gap-2 mt-1">
        <select id="fineMotor" class="input w-40 flex-shrink-0 bg-white border border-gray-300 rounded-md text-sm text-gray-500" disabled>
          <option value="" disabled selected>Selecciona una opción</option>
          <option value="si">Sí</option>
          <option value="no">No</option>
        </select>
        <input type="text" id="fineMotorNotes" placeholder="Notas"
          class="input flex-1 bg-white border border-gray-300 rounded-md text-sm text-gray-500 placeholder-gray-400" disabled />
      </div>
    </div>

    <!-- tremor -->
    <div>
      <label class="input_label">Temblor</label>
      <div class="flex gap-2 mt-1">
        <select id="tremor" class="input w-40 flex-shrink-0 bg-white border border-gray-300 rounded-md text-sm text-gray-500" disabled>
          <option value="" disabled selected>Selecciona una opción</option>
          <option value="si">Sí</option>
          <option value="no">No</option>
        </select>
        <input type="text" id="tremorNotes" placeholder="Notas"
          class="input flex-1 bg-white border border-gray-300 rounded-md text-sm text-gray-500 placeholder-gray-400" disabled/>
      </div>
    </div>

    <!-- falls -->
    <div>
      <label class="input_label">Caídas</label>
      <div class="flex gap-2 mt-1">
        <select id="falls" class="input w-40 flex-shrink-0 bg-white border border-gray-300 rounded-md text-sm text-gray-500" disabled>
          <option value="" disabled selected>Selecciona una opción</option>
          <option value="si">Sí</option>
          <option value="no">No</option>
        </select>
        <input type="text" id="fallsNotes" placeholder="Notas"
          class="input flex-1 bg-white border border-gray-300 rounded-md text-sm text-gray-500 placeholder-gray-400" disabled/>
      </div>
    </div>

    <!-- frequency -->
    <div>
      <div class="flex items-center gap-2 mt-1">
        <label class="input_label w-40 flex-shrink-0 mb-0">Frecuencia</label>
        <input type="text" id="fallsFrequency" placeholder="Notas"
          class="input flex-1 bg-white border border-gray-300 rounded-md text-sm text-gray-500 placeholder-gray-400" disabled/>
      </div>
    </div>

  </div>
</div>