<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mi Panel - Golondrina</title>
    <link rel="stylesheet" href="/css/output.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.css"/>
</head>
<body data-module="<%= tutorialModule %>"  class="bg-[#0A2472] flex h-screen lg:flex-row transition-transform duration-300">

  <div id="overlay" class="fixed inset-0 bg-black/40 hidden md:hidden"></div>

  <%- include('../partials/sidebar') %>

  <div class="flex-1 flex flex-col overflow-hidden">

    <%- include('../partials/header') %>
    <main class="flex-1 px-3 sm:px-6 pt-4 sm:pt-6 pb-0 md:pl-0 overflow-auto">
      <div class="w-full bg-white rounded-3xl px-6 pt-6 pb-0 flex flex-col">
        <div class = "overflow-auto" id="dashboard">
<div class="flex flex-col gap-4 mb-4 flex-shrink-0">
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 min-h-[34px] md:min-h-[40px]">
            <h1 class="font-['Roboto'] text-2xl text-black font-bold">Mi Panel</h1>
          </div>

          <div>
            <img src="/assets/Linear-determinate progress indicator.svg"
              alt="Progress indicator" class="w-full">
          </div>
        </div>
        <div class="flex flex-row" id="selectClinical"></div>

        <div class="flex-1 overflow-auto pb-6 flex flex-col gap-5">
          <div id="introText">
            <div class="col-span-full text-gray-400 py-4">Cargando...</div>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3" id="topCubes">
            <div class="col-span-full text-center text-gray-400 py-4">Cargando...</div>
          </div>

          <!-- ROW: polar chart + standby users -->
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            <div class="bg-[#F8F8FB] rounded-xl p-4 shadow-sm">
              <h2 class="text-sm font-semibold text-gray-700 mb-2">Así luce tu flujo de usuarios:</h2>
                <div class="relative h-[280px]">
                  <canvas id="flowChart"></canvas>
                </div>
              </div>
              <div class="bg-[#E5E8FA] rounded-xl p-5 shadow-sm">
                <h2 class="text-sm font-semibold text-gray-700 mb-3">Estos son tus usuarios:</h2>
                  <div id="userInfoPanel" class="text-sm text-gray-700">
                    <p class="text-gray-400">Cargando...</p>
                  </div>
              </div>
          </div>
          <h2 class="text-lg font-bold text-gray-700 mb-2">Así lucen tus próximas citas:</h2>
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
            <div id="todayAppointments" class="bg-[#F8F8FB] rounded-xl p-4 shadow-sm text-center">
              <h2 class="text-sm font-semibold text-gray-700 mb-3">Hoy:</h2>
              <div class="col-span-full text-center text-gray-400 py-4">Cargando...</div>
            </div>
            <div id="tomorrowAppointments" class="bg-[#F8F8FB] rounded-xl p-4 shadow-sm text-center">
              <div class="col-span-full text-center text-gray-400 py-4">Cargando...</div>
            </div>
            <div id="otherAppointments"class="bg-[#F8F8FB] rounded-xl p-4 shadow-sm text-center">
              <div class="col-span-full text-center text-gray-400 py-4">Cargando...</div>
            </div>
          </div>
          <h2 class="text-lg font-bold text-gray-700 mb-2">Asi lucen los usuarios con los que has trabajado a lo largo del tiempo:</h2>
          <div id="historicalText">
            <div class="col-span-full text-gray-400 py-4">Cargando...</div>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3" id="bottomCubes">
            <div class="col-span-full text-center text-gray-400 py-4">Cargando...</div>
          </div>
        </div>
        </div>
        
      </div>
      <div class="mt-auto pt-4">
        <%- include('../partials/footer') %>
      </div>
    </main>
  </div>
  <script src="/js/sidebar.js"></script>
  <script src="/js/main.js"></script> 
  <script src="https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.js.iife.js"></script>

  <script>
    const tutorialElements = {
      1: null,                  
      2: '#selectClinical',    
      3: '#topCubes',            
      4: '#flowChart',          
      5: '#userInfoPanel',      
      6: '#todayAppointments',   
      7: '#bottomCubes',        
    };
  </script>
  <script src="/js/tutorial.js"></script>
  <script src="/js/dashboardClinical.js"></script>
</body>