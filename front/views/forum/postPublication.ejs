<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Golondrina - Nueva Publicación</title>
  <link rel="stylesheet" href="/css/output.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.css"/>
</head>
<body data-module="<%= tutorialModule %>" class="bg-[#0A2472] flex h-screen lg:flex-row transition-transform duration-300">

    <div id="overlay" class="fixed inset-0 bg-black/40 hidden md:hidden"></div>

    <%- include('../partials/sidebar') %>

    <div class="flex-1 flex flex-col overflow-hidden">

        <%- include('../partials/header') %>

        <main class="flex-1 px-3 sm:px-6 pt-4 sm:pt-6 pb-0 md:pl-0 overflow-hidden">
            <div class="w-full h-full bg-white rounded-3xl p-6 overflow-y-auto">
  
        <div class="flex items-center gap-4 mb-5">

                          <a href="/forum">
                            <button class="cursor-pointer pb">
                                <svg class="black-icon shrink-0 size-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 9-3 3m0 0 3 3m-3-3h7.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                                </svg>
                            </button>
                         </a>
          <!-- ============ Title of the view ====================== -->
          <h2 class="text-2xl font-bold text-gray-800 tracking-tight">Registrar Publicación</h2>  
          
          <!-- ============ Clear Button ======================  -->           
          <button id="clearBtn" class="btn-clear">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
          <span>Limpiar</span>
          </button>
        </div>
        <div class="w-full h-[4px] bg-[#002B7A] my-4"></div>                        

        <form id="formPublicacion" class="space-y-6 mt-6" enctype="multipart/form-data">
          <!-- ============ Title Upload ====================== -->
          <div class="space-y-1">
            <label class="text-sm font-medium text-gray-700">Título * </label>

            <div class="search-input w-full relative">
              <input type="text" name="titulo" required maxlength="50" class="search-input_field" placeholder="Titulo..." id="titleInput">
                <span id="titleCount" class="absolute bottom-0 right-2 text-xs text-gray-500"> 0/50 </span>
            </div>
          </div>
          
          <!-- ============ Content Upload ====================== -->
          <div class="editor relative">

            <label class="editor-label">Contenido *</label>

            <div class="editor-toolbar"> </div>

            <div class="editor-body" contenteditable="true" oninput="limitContent(this)" data-placeholder="Escribe aquí el contenido..."></div>
              <span id="charCount" class="absolute bottom-2 right-2 text-xs text-gray-500"> 0/500 </span>
          </div>
          
          <!-- ============ File Upload ====================== -->
          <div class="file-upload">
            <label class="file-upload-label">Multimedia (Opcional)</label>

            <div class="file-upload-dropzone" id="dropzone">

              <div id="filePreview" class="hidden flex flex-col items-center gap-2">
                <img id="previewImg" src="" class="w-16 h-16 object-cover rounded-md border">
                <span id="previewName" class="text-[10px] text-gray-600 text-center break-all"></span>
              </div>

              <div id="emptyState" class="flex flex-col items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="file-upload-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                    d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <span class="file-upload-text">Haz clic o arrastra una imagen aquí</span>
              </div>

              <input type="file" name="imagen" accept="image/jpeg,image/png,image/webp" class="file-upload-input" id="fileInput">
            </div>
          </div>


          <input type="hidden" name="contenido" id="contentHidden">

          <!-- ============ Upload Button======================-->
          <div class="flex justify-center md:justify-end pt-2">
            <button id="btnPublish" class="btn-mini bg-[#BA8700] w-full md:w-[220px]">
      
              <svg xmlns="http://www.w3.org/2000/svg"fill="none"viewBox="0 0 24 24"stroke-width="1.5"stroke="currentColor" class="white-icon">
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
              </svg>

              <span>Publicar</span>

            </button>
          </div>
        </form>
      </div>

      </main>
  </div>
</body>
<script src="https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.js.iife.js"></script>
<script src="/js/main.js"></script>
<script src="/js/tutorial.js"></script>
<script>
  const tutorialElements = {
    1: null,           // intro
    2: '#titleInput', // input title
    3: '.editor-body', // content
    4: '#dropzone',    // img
    5: '#btnPublish',  // publish button
  };
</script>
<script>
  const form = document.getElementById('formPublicacion');
  const editor = document.querySelector('.editor-body');
  const hiddenInput = document.getElementById('contentHidden');
  const clearBtn = document.getElementById('clearBtn');
  const dropzone = document.querySelector('.file-upload-dropzone');
  const fileInput = document.querySelector('.file-upload-input');
  const filePreview = document.getElementById('filePreview');
  const emptyState  = document.getElementById('emptyState');
  const previewImg  = document.getElementById('previewImg');
  const previewName = document.getElementById('previewName');
  const titleInput = document.getElementById('titleInput');
  const titleCount = document.getElementById('titleCount');

  // Xss Injection Prevention
  function escapeHTML(text) {
    return text
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");
  }

  function resetForm() {
    form.reset();
    editor.innerHTML = '';
    hiddenInput.value = '';
    filePreview.classList.add('hidden');
    emptyState.classList.remove('hidden');
    previewImg.src = '';

    titleCount.innerText = '0/50';
    document.getElementById('charCount').innerText = '0/500';
  }  

  titleInput.addEventListener('input', () => {
    const max = 50;
    const length = titleInput.value.length;
    titleCount.innerText = `${length}/${max}`;
  });

  function limitContent(content) {
    const limit = 500;
    const text = content.innerText;
    
    const length = text.endsWith('\n') ? text.length - 1 : text.length;

    if (length > limit) {
      content.innerText = text.substring(0, limit);
      const range = document.createRange();
      const sel = window.getSelection();
      range.selectNodeContents(content);
      range.collapse(false);
      sel.removeAllRanges();
      sel.addRange(range);
    }

    const counter = document.getElementById('charCount');
    const displayed = Math.min(length, limit);
    if (counter) counter.innerText = `${displayed}/${limit}`;
  }

  // Clean forms
  clearBtn.addEventListener('click', () => {
    resetForm();
    showToast('Formulario limpiado');
  });

  dropzone.addEventListener('click', () => {
    fileInput.click();
  });

  fileInput.addEventListener('change', () => {
    const file = fileInput.files[0];
    if (!file) return;
    if (file.size > 5 * 1024 * 1024) { // 5mb
      showToast('Imagen demasiado pesada', 'error');
      fileInput.value = '';
      return;
    }
    previewImg.src = URL.createObjectURL(file);
    previewName.textContent = escapeHTML(file.name);
    filePreview.classList.remove('hidden'); 
    emptyState.classList.add('hidden');
  });

 form.addEventListener('submit', async (e) => {
  e.preventDefault();

  const rawText = editor.innerText;
  const contentLength = rawText.endsWith('\n') ? rawText.length - 1 : rawText.length;
  const content = rawText.trim();

  if (!content) {
    showToast('El contenido es obligatorio', 'error');
    return;
  }

  if (contentLength > 500) {
    showToast('El contenido no puede superar los 500 caracteres', 'error');
    return;
  }

  hiddenInput.value = content;

  const formData = new FormData(form);

  try {
    const res = await fetch('/forum/post', {
      method: 'POST',
      headers: { 'x-csrf-token': _csrfToken },
      body: formData,
    });

    const data = await res.json();

    if (res.ok) {
      sessionStorage.setItem('pendingToast', JSON.stringify({ 
        message: 'Publicación creada correctamente', 
        type: 'success' 
      }));
      window.location.href = '/forum';
    } else {
      const fallback =
        res.status === 413 ? 'La imagen es demasiado grande (max 5mb)' :
        res.status === 422 ? 'Datos inválidos' :
        res.status === 429 ? 'Haz alcanzado el límite de publicaciónes. Intenta de nuevo más tarde' : 
        'Error al publicar';
      showToast(data.error || fallback, 'error');
    }
  } catch (error) {
    showToast('Error de red. Intenta de nuevo más tarde', 'error');
  }
});
  
</script>
</html>