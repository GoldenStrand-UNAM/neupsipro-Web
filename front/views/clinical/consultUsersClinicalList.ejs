<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Colaboradores - Golondrina</title>
    <link rel="stylesheet" href="/css/output.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.css"/>
</head>
<body data-module="<%= tutorialModule %>" class="bg-[#0A2472] flex h-screen lg:flex-row transition-transform duration-300">
    <script src="/js/main.js"></script>

    <div id="overlay" class="fixed inset-0 bg-black/40 hidden md:hidden"></div>

    <%- include('../partials/sidebar') %>

    <div class="flex-1 flex flex-col min-w-0">

        <%- include('../partials/header') %>

        <main class="flex-1 px-3 sm:px-6 pt-4 sm:pt-6 pb-0 md:pl-0 overflow-auto">
            <div class="w-full h-full bg-white rounded-3xl px-6 pt-6 pb-0 flex flex-col gap-4">

                <!--Title, search, signUser-->
                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
                    <h1 class="text-2xl font-bold text-[#1E1E1E]">Equipo de Colaboradores</h1>

                    <div class="flex items-center gap-3">
                        <a href="/clinical/postUser">
                        <button
                            class="btn-mini w-full sm:w-[260px] md:w-[306px] bg-[#C89B3C]">
                            <svg xmlns="http://www.w3.org/2000/svg" class="white-icon-mini" fill="none"
                                viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
                            </svg>
                            <span>Nuevo Colaborador</span>
                        </button>
                        </a>

                        <div  id="searchBox" class="search-input">
                            <input id="search-input"type="text" class="search-input_field" placeholder="Buscar por nombre"/>
                            <svg xmlns="http://www.w3.org/2000/svg" class="search-icon" fill="none"
                                viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M21 21l-4.35-4.35M17 11A6 6 0 105 11a6 6 0 0012 0z"/>
                            </svg>
                        </div>
                    </div>
                </div>
                <div> 
                    <img src="/assets/Linear-determinate progress indicator.svg"  alt="Progress indicator" class="w-full">         
                </div>

                <!-- Table -->
                <div id="clinicalTable"  class="flex-1 overflow-x-auto overflow-y-auto bg-[#FAFAFA] rounded-xl shadow-sm px-3 md:px-6">
                    <table class="w-full min-w-[700px] border-collapse text-sm md:text-base">
                        <thead>
                            <tr class="border-b-2 border-gray-200">
                                <th class="w-[30%] py-2.5 px-6 text-left font-semibold text-gray-700">Nombre</th>
                                <th class="w-[18%] py-2.5 px-6 text-center font-semibold text-gray-700">Afiliación</th>
                                <th class="w-[18%] py-2.5 px-6 text-center font-semibold text-gray-700">Actividad</th>
                                <th class="w-[18%] py-2.5 px-6 text-center font-semibold text-gray-700">Usuarios asignados</th>
                                <th class="w-[18%] py-2.5 px-6 text-center font-semibold text-gray-700">Consultar información</th>
                            </tr>
                        </thead>
                        <tbody id="users-tbody">
                            <tr>
                                <td colspan="5" class="py-10 text-center text-gray-400">Cargando...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div id="pagination" class="flex items-center justify-center gap-3 py-3"></div>

            </div>
            <div class="mt-auto pt-4">
                <%- include('../partials/footer') %>
            </div>
        </main>
    </div>

    <script src="/js/sidebar.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.js.iife.js"></script>
    <script>
        const tutorialElements = {
        1: null,               
        2: '#btnNewClinical', 
        3: '#searchBox',       
        4: '#clinicalTable',   
        5: '#pagination',     
        };
    </script>
  <script src="/js/tutorial.js"></script>
    <script>
        const MAX_SEARCH_LENGTH = 50;

        // Function to prevent XSS inyections
        function escapeHtml(str) {
            return String(str)
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        let currentPage   = 1;
        const LIMIT       = 6;
        let searchQuery   = "";
        let debounceTimer;

        if (sessionStorage.getItem('savedUser') === 'true') {
            showToast('Usuario guardado correctamente');
            sessionStorage.removeItem('savedUser');
        }

        // = ====  Fetch===========
        async function fetchUsers() {
            const params = new URLSearchParams({ search: searchQuery, page: currentPage, limit: LIMIT });
            try {
                const res  = await fetch(`/api/usuarios-clinicos?${params}`);
                const data = await res.json();

                if (res.status === 429) {
                    showMsg('Demasiadas solicitudes. Intenta de nuevo en unos minutos.', 'text-red-400');
                    return;
                }

                if (!res.ok) {
                    console.error("Server error:", data.error);
                    showMsg("Ocurrió un error en el sistema. Intenta de nuevo más tarde.", "text-red-400");
                    return;
                }

                renderTable(data.users);
                renderPagination(data.totalPages, data.page);

            } catch (err) {
                console.error("Network error:", err);
                showMsg("No se pudo conectar al servidor. Verifica tu conexión.", "text-red-400");
            }
        }

        // = ====  Render===========
        function renderTable(users) {
            const tbody = document.getElementById("users-tbody");
            if (!users.length) { showMsg("Sin resultados", "text-gray-400"); return; }

            tbody.innerHTML = users.map(u => `
                <tr class="border-b border-gray-100 hover:bg-blue-50 transition-colors duration-150">
                    <td class="py-3 px-6 text-gray-800">${escapeHtml(u.fullName)}</td>
                    <td class="py-3 px-6 text-center  text-gray-700">${escapeHtml(u.affiliation || '—')}</td>
                    <td class="py-3 px-6 text-center  text-gray-700">${escapeHtml(u.activity || '—')}</td>
                    <td class="py-3 px-6 text-center text-gray-800 font-medium">${u.assignedCount ?? 0}</td>
                    <td class="py-3 px-6 flex justify-center">
                        <button
                            onclick="consultar('${escapeHtml(u.id)}')"
                            class="btn-mini bg-[#3350A9]">
                            <svg xmlns="http://www.w3.org/2000/svg" class="white-icon-mini" fill="none"
                                viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943
                                    9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                            </svg>
                            <span>Consultar</span>
                        </button>
                    </td>
                </tr>
            `).join("");
        }

        function renderPagination(totalPages, page) {
            const c = document.getElementById("pagination");
            c.innerHTML = "";
            if (totalPages <= 1) return;

            const btn = (label, disabled, onClick) => {
                const b = document.createElement("button");
                b.textContent = label;
                b.disabled = disabled;
                b.onclick = onClick;
                b.className = "btn-mini bg-[#002B7A] disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:scale-100 disabled:hover:shadow-none";
                return b;
            };

            const info = document.createElement("span");
            info.className = "text-sm text-gray-500";
            info.textContent = `Página ${page} de ${totalPages}`;

            c.append(
                btn("Anterior", page <= 1, () => { currentPage--; fetchUsers(); }),
                info,
                btn("Siguiente ", page >= totalPages, () => { currentPage++; fetchUsers(); })
            );
        }

        function showMsg(msg, colorClass) {
    document.getElementById("users-tbody").innerHTML =
       `<tr>
            <td colspan="5" class="py-10">
                <div class="flex justify-center items-center text-center ${escapeHtml(colorClass)}">
                    ${escapeHtml(msg)}
                </div>
            </td>
        </tr>`;
    document.getElementById("pagination").innerHTML = "";
}

        // = ==== User Finder===========
        const searchInput     = document.getElementById("search-input");
        searchInput.setAttribute("maxlength", MAX_SEARCH_LENGTH); // limit of characters

        searchInput.addEventListener("input", e => {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(() => {
                searchQuery = e.target.value.trim();
                currentPage = 1;
                fetchUsers();
            }, 400);
        });


        function consultar(id) {
            window.location.href = `/clinical/${id}`
         }

        fetchUsers();
        
    </script>
</body>
</html>