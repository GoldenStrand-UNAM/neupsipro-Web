<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Registrar Usuario Clínico - Golondrina</title>
  <link rel="stylesheet" href="/css/output.css" />
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
</head>
<body class="bg-[#0A2472] flex h-screen lg:flex-row transition-transform duration-300">
  <script src="/js/main.js"></script>

  <div id="overlay" class="fixed inset-0 bg-black/40 hidden md:hidden"></div>

  <%- include('../partials/sidebar') %>

  <div class="flex-1 flex flex-col overflow-hidden">

    <%- include('../partials/header') %>

    <main class="flex-1 px-3 sm:px-6 pt-4 sm:pt-6 pb-0 md:pl-0 overflow-auto">
      <div class="w-full h-full bg-white rounded-tl-3xl rounded-tr-3xl px-6 pt-6 pb-0 flex flex-col gap-4 overflow-auto">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
          <div class="flex items-center gap-3">
            <a href="/clinical">
              <button class="cursor-pointer pb">
                <svg class="black-icon shrink-0 size-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 9-3 3m0 0 3 3m-3-3h7.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                </svg>
              </button>
            </a>
            <h1 class="text-2xl font-bold text-[#1E1E1E]">Registrar Usuario Clínico</h1>
          </div>
          <div class="flex items-center gap-3">
            <button 
              onclick="resetFormBtn()" 
              class="flex items-center gap-2"
              style="color: #FF0404"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
              <span>Limpiar</span>
            </button>
          </div>
        </div>
        <div> 
          <img src="/assets/Linear-determinate progress indicator.svg"  alt="Progress indicator" class="w-full">         
        </div>

        <form id="formUser" class="px-6 pt-6 pb-0 flex flex-col gap-4">
          <div class="flex flex-col sm:flex-row sm:items-center gap-4 w-full">      
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Nombre(s) <span style="color: #FF0404">*</span>
            </label>
            <div class="inputs w-full relative flex items-center">
              <input
                required
                class="input-base w-full sm:flex-1 border p-2 pr-12 rounded"
                type="text"
                name="firstName"
                id="firstName"
                placeholder="Juan Carlos"
                maxlength="30"
              >
              <span id="charactersNames" class="absolute right-3 text-xs text-gray-500 pointer-events-none"> 
                0/30 
              </span>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row sm:items-center gap-4 w-full">      
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Apellido paterno <span style="color: #FF0404">*</span>
            </label>
            <div class="inputs w-full relative flex items-center">
              <input
                required
                class="input-base w-full sm:flex-1 border p-2 pr-12 rounded"
                type="text"
                name="lastnameP"
                id="lastnameP"
                placeholder="Hernández"
                maxlength="30"
              >
              <span id="charactersLastnameP" class="absolute right-3 text-xs text-gray-500 pointer-events-none"> 
                0/30 
              </span>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row sm:items-center gap-4 w-full">       
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Apellido materno
            </label>
            <div class="inputs w-full relative flex items-center">
              <input
                class="input-base w-full sm:flex-1 border p-2 pr-12 rounded"
                type="text"
                name="lastnameM"
                id="lastnameM"
                placeholder="Camacho"
                maxlength="30"
              >
              <span id="charactersLastnameM" class="absolute right-3 text-xs text-gray-500 pointer-events-none"> 
                0/30 
              </span>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row sm:items-center gap-4 w-full">
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Fecha de nacimiento <span style="color: #FF0404">*</span>
            </label>
            <div class="relative w-full sm:flex-1 flex items-center">
              <input 
                required
                type="text" 
                id="birthdate" 
                name="birthdate"
                placeholder="DD/MM/AAAA"
                class="datetime-local input-base w-full border p-2 pr-10 rounded outline-none focus:ring-2 focus:ring-blue-500 bg-white"
              >
              <div class="absolute right-3 pointer-events-none text-gray-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
            </div>
          </div>

          <div class="mb-8 flex flex-col sm:flex-row sm:items-center gap-4 w-full">
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              E-mail
            </label>
            <div class="inputs w-full relative flex items-center">
              <input
                class="input-base w-full sm:flex-1 border p-2 pr-12 rounded"
                type="text"
                name="email"
                id="email"
                placeholder="ejemplo@gmail.com"
                maxlength="50"
              >
              <span id="charactersEmail" class="absolute right-3 text-xs text-gray-500 pointer-events-none"> 
                0/50 
              </span>
            </div>
          </div>

          <div class="mt-8 flex flex-col sm:flex-row sm:items-center gap-4 w-full">
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Afiliación <span style="color: #FF0404">*</span>
            </label>
            <div class="inputs w-full relative flex items-center">
              <input
                required
                class="input-base w-full sm:flex-1 border p-2 pr-12 rounded"
                type="text"
                name="affiliation"
                id="affiliation"
                placeholder="UNAM"
                maxlength="20"
              >
              <span id="charactersAffiliation" class="absolute right-3 text-xs text-gray-500 pointer-events-none"> 
                0/20 
              </span>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row sm:items-center gap-4 w-full">
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Actividad <span style="color: #FF0404">*</span>
            </label>
            <div class="inputs w-full relative flex items-center">
              <input
                required
                class="input-base w-full sm:flex-1 border p-2 pr-12 rounded"
                type="text"
                name="activity"
                id="activity"
                placeholder="Trabajo"
                maxlength="20"
              >
              <span id="charactersActivity" class="absolute right-3 text-xs text-gray-500 pointer-events-none"> 
                0/20 
              </span>
            </div>
          </div>
          <div class="flex flex-col sm:flex-row sm:items-center gap-4 w-full">
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Fecha de inicio <span style="color: #FF0404">*</span>
            </label>
            <div class="relative w-full sm:flex-1 flex items-center">
              <input 
                required
                type="text" 
                id="startDate" 
                name="startDate"
                placeholder="DD/MM/AAAA"
                class="input-base w-full border p-2 pr-10 rounded outline-none focus:ring-2 focus:ring-blue-500 bg-white"
              >
              <div class="absolute right-3 pointer-events-none text-gray-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row sm:items-center gap-4 w-full">
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Fecha de fin <span style="color: #FF0404">*</span>
            </label>
            <div class="relative w-full sm:flex-1 flex items-center">
              <input 
                required
                type="text" 
                id="finishDate" 
                name="finishDate"
                placeholder="DD/MM/AAAA"
                class="input-base w-full border p-2 pr-10 rounded outline-none focus:ring-2 focus:ring-blue-500 bg-white"
              >
              <div class="absolute right-3 pointer-events-none text-gray-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
            </div>
          </div>
          <div class="mb-8 flex flex-col sm:flex-row sm:items-center gap-4 w-full">
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Horas
            </label>
            <div class="inputs w-full relative flex items-center">
              <input
                class="input-base w-full sm:flex-1 border p-2 pr-12 rounded"
                type="text"
                name="hours"
                id="hours"
                placeholder="200"
                maxlength="4"
              >
            </div>
          </div>

          <div class="mt-8 flex flex-col sm:flex-row sm:items-center gap-4 w-full">
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Usuario <span style="color: #FF0404">*</span>
            </label>
            <div class="inputs w-full relative flex items-center">
              <input
                required
                class="input-base w-full sm:flex-1 border p-2 pr-12 rounded"
                type="text"
                name="username"
                id="username"
                placeholder="Nombre de usuario"
                maxlength="30"
              >
              <span id="charactersUserName" class="absolute right-3 text-xs text-gray-500 pointer-events-none"> 
                0/30 
              </span>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row sm:items-center gap-4 w-full">
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Contraseña <span style="color: #FF0404">*</span>
            </label>
            <div class="inputs w-full relative flex items-center">
              <input
                required
                class="input-base w-full sm:flex-1 border p-2 pr-12 rounded"
                type="password"
                name="password"
                id="password"
                placeholder="Contraseña del usuario"
                maxlength="30"
              >
              <span id="charactersPassword" class="absolute right-3 text-xs text-gray-500 pointer-events-none"> 
                0/30 
              </span>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row sm:items-center gap-4 w-full">
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Confirma contraseña <span style="color: #FF0404">*</span>
            </label>
            <div class="inputs w-full relative flex items-center">
              <input
                required
                class="input-base w-full sm:flex-1 border p-2 pr-12 rounded"
                type="password"
                name="confirmPassword"
                id="confirmPassword"
                placeholder="Contraseña del usuario"
                maxlength="30"
              >
              <span id="charactersConfirmPassword" class="absolute right-3 text-xs text-gray-500 pointer-events-none"> 
                0/30 
              </span>
            </div>
          </div>
          <div class="mb-8 flex flex-col sm:flex-row w-full">
            <div class="sm:block sm:w-1/4 shrink-0"></div>
            <div class="flex flex-row w-full justify-between px-4">
              <button type="button" id="showPw" style="color: #0600b7" class="text-sm"><span id="showHide">Mostrar</span> Contraseña</button>
              <div id="validation" style="color: #ff1f0b" class="text-sm"></div>
            </div>
          </div>

          <div class="mt-8 flex flex-col sm:flex-row sm:items-center gap-4 w-full">
            <label class="sm:w-1/4 shrink-0">
            </label>
            <div class="relative w-full sm:flex-1 flex items-center font-semibold text-lg">
              Contacto de emergencia
            </div>
          </div>
          <div class="flex flex-col sm:flex-row sm:items-center gap-4 w-full">
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Nombre completo
            </label>
            <div class="inputs w-full relative flex items-center">
              <input
                class="input-base w-full sm:flex-1 border p-2 pr-12 rounded"
                type="text"
                name="emergencyContactName"
                id="emergencyContactName"
                placeholder="Jimena Camacho Flores"
                maxlength="50"
              >
              <span id="charactersEmergencyContactName" class="absolute right-3 text-xs text-gray-500 pointer-events-none"> 
                0/50 
              </span>
            </div>
          </div>
          <div class="flex flex-col sm:flex-row sm:items-center gap-4 w-full">
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Teléfono
            </label>
            <div class="inputs w-full relative flex items-center">
              <input
                class="input-base w-full sm:flex-1 border p-2 pr-12 rounded"
                type="tel"
                name="emergencyContactPhone"
                id="emergencyContactPhone"
                placeholder="1234567890"
                maxlength="15"
              >
              <span id="charactersEmergencyContactPhone" class="absolute right-3 text-xs text-gray-500 pointer-events-none"> 
                0/15 
              </span>
            </div>
          </div>
          <div class="mb-8 flex flex-col sm:flex-row sm:items-center gap-4 w-full">
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Relación
            </label>
            <div class="inputs w-full relative flex items-center">
              <input
                class="input-base w-full sm:flex-1 border p-2 pr-12 rounded"
                type="text"
                name="emergencyContactRelation"
                id="emergencyContactRelation"
                placeholder="Madre"
                maxlength="25"
              >
              <span id="charactersEmergencyContactRelation" class="absolute right-3 text-xs text-gray-500 pointer-events-none"> 
                0/25 
              </span>
            </div>
          </div>

          <div class="mb-8 flex justify-center md:justify-end pt-2">
            <button class="btn-mini bg-[#3350A9]">
              <svg class="white-icon-mini" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 3.75V16.5L12 14.25 7.5 16.5V3.75m9 0H18A2.25 2.25 0 0 1 20.25 6v12A2.25 2.25 0 0 1 18 20.25H6A2.25 2.25 0 0 1 3.75 18V6A2.25 2.25 0 0 1 6 3.75h1.5m9 0h-9" />
              </svg>
              <span>Guardar</span>
            </button>
          </div>
        </form>
      </div>
    </main>
  </div>

  <script src="/js/sidebar.js"></script>

  <script>
    window.__CSRF_TOKEN__ = "<%= csrfToken %>";
  </script>
  </body>

  <script>
    const form = document.getElementById('formUser');
    const passInput = document.getElementById('password');
    const confirmInput = document.getElementById('confirmPassword');
    const userInput = document.getElementById('username');

    function escapeHTML(text) {
      return text
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");
    }

    function resetFormBtn(){
      if (form) form.reset();
      showToast('Formulario limpiado');
    }

    form.addEventListener('submit', async (e) => {
      event.preventDefault();
      const formData = new FormData(form);

      try {
      const res = await fetch('/clinical/post', {
        method: 'POST',
        headers: { 'x-csrf-token': _csrfToken },
        body: formData,
      });

      const data = await res.json();

      if (res.ok) {
        sessionStorage.setItem('savedUser', 'true');
        window.location.href = '/clinical';
      } else {
        if (res.status === 409 && data.inUse === 'user') {
          userInput.setCustomValidity("El nombre de usuario ya está en uso");
          userInput.style.border = '2px solid red';
          userInput.style.boxShadow = 'inset 0 0 0 100px #fef2f2';
          userInput.reportValidity();
        } else {
          console.log(data.error);
          showToast((data.error || 'Error desconocido'), 'error');
        }
      }
      } catch (error) {
        console.log(`Error de conexión: ${error}`);
        showToast(`Error de conexión: ${error}`, 'error');
      }
    });

    userInput.addEventListener('input', () => {
      userInput.setCustomValidity("");
      userInput.style.border = '';
      userInput.style.boxShadow = '';
    });

    function setupCounter(inputId, counterId) {
      const input = document.getElementById(inputId);
      const counter = document.getElementById(counterId);

      if (!input || !counter) return;

      const max = input.getAttribute('maxlength');

      input.addEventListener('input', () => {
        const longitud = input.value.length;
        counter.textContent = `${longitud}/${max}`;
      });
    }

    function validateDates(id){
      const inputFecha = document.getElementById(id);
      const today = new Date();

      const fp = flatpickr(document.getElementById(id), {
        dateFormat: "d/m/Y",
        allowInput: true,
        maxDate: "today",
        minDate: "01/01/1900",
        disableMobile: true
      });

      inputFecha.addEventListener('input', (e) => {
        let v = e.target.value.replace(/\D/g, '');
        let finalValue = "";
        const actualYear = new Date().getFullYear();

        if (v.length > 0) {
          let day = v.substring(0, 2);
          let month = v.substring(2, 4);
          let year = v.substring(4, 8);

          if (parseInt(day) > 31) day = "31";
          if (parseInt(month) > 12) month = "12";
          if (parseInt(year) > 2026) year = actualYear;
          if (parseInt(year) < 1900 && v.length == 8) year = 1900;

          if (v.length <= 2) finalValue = day;
          else if (v.length <= 4) finalValue = day + "/" + month;
          else finalValue = day + "/" + month + "/" + year;
        }

        e.target.value = finalValue;

      });
    }

    function validateFutureDates(id){
      const inputFecha = document.getElementById(id);
      const today = new Date();

      const fp = flatpickr(document.getElementById(id), {
        dateFormat: "d/m/Y",
        allowInput: true,
        maxDate: "31/12/2100",
        minDate: "today",
        disableMobile: true
      });

      inputFecha.addEventListener('input', (e) => {
        let v = e.target.value.replace(/\D/g, '');
        let finalValue = "";
        const actualYear = new Date().getFullYear();

        if (v.length > 0) {
          let day = v.substring(0, 2);
          let month = v.substring(2, 4);
          let year = v.substring(4, 8);

          if (parseInt(day) > 31) day = "31";
          if (parseInt(month) > 12) month = "12";
          if (parseInt(year) < 2026 && v.length == 8) year = actualYear;
          if (parseInt(year) > 2100) year = 2100;

          if (v.length <= 2) finalValue = day;
          else if (v.length <= 4) finalValue = day + "/" + month;
          else finalValue = day + "/" + month + "/" + year;
        }

        e.target.value = finalValue;

      });
    }

    function validatePhone(id) {
      const inputPhone = document.getElementById(id);

      inputPhone.addEventListener('input', (e) => {
        let v = e.target.value.replace(/[^0-9+]/g, '');

        if (v.includes('+')) {
          const hasPlus = v.startsWith('+');
          v = v.replace(/\+/g, '');
          if (hasPlus) {
            v = '+' + v;
          }
        }

        e.target.value = v;
      });
    }

    function validateNumber(id) {
      const inputNumber = document.getElementById(id);

      inputNumber.addEventListener('input', (e) => {
        let v = e.target.value.replace(/[^0-9]/g, '');

        e.target.value = v;
      });
    }

    function validateMatch() {
      const val = passInput.value;
      const confVal = confirmInput.value;

      if (val === confVal) {
        document.getElementById('validation').textContent = "";
        confirmInput.setCustomValidity("");
      } else {
        document.getElementById('validation').textContent = "Las contraseñas no coinciden";
        confirmInput.setCustomValidity("Las contraseñas no coinciden");
      }
    }
    
    passInput.addEventListener('input', validateMatch);
    confirmInput.addEventListener('input', validateMatch);

    const showBtn = document.getElementById('showPw');
    if (showBtn) {
      showBtn.addEventListener('click', () => {
        const type = passInput.type === 'password' ? 'text' : 'password';
        passInput.type = type;
        confirmInput.type = type;
                
        const label = document.getElementById('showHide');
        if (label) label.textContent = type === 'password' ? 'Mostrar' : 'Ocultar';
      });
    }

    setupCounter('firstName', 'charactersNames');
    setupCounter('lastnameP', 'charactersLastnameP');
    setupCounter('lastnameM', 'charactersLastnameM');
    setupCounter('email', 'charactersEmail');
    setupCounter('affiliation', 'charactersAffiliation');
    setupCounter('activity', 'charactersActivity');
    setupCounter('username', 'charactersUserName');
    setupCounter('password', 'charactersPassword');
    setupCounter('confirmPassword', 'charactersConfirmPassword');
    setupCounter('emergencyContactName', 'charactersEmergencyContactName');
    setupCounter('emergencyContactPhone', 'charactersEmergencyContactPhone');
    setupCounter('emergencyContactRelation', 'charactersEmergencyContactRelation');
    validateDates('birthdate');
    validateDates('startDate');
    validateFutureDates('finishDate');
    validatePhone('emergencyContactPhone');
    validateNumber('hours');
  </script>
</html>