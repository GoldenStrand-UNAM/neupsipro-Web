<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Permisos - Golondrina</title>
    <link rel="stylesheet" href="/css/output.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.css"/>
</head>

<body data-module="<%= tutorialModule %>"  class="bg-[#0A2472] flex h-screen lg:flex-row transition-transform duration-300">

    <div id="overlay" class="fixed inset-0 bg-black/40 hidden md:hidden"></div>

    <!-- Sidebar -->
    <%- include('../partials/sidebar') %>

    <div class="flex-1 flex flex-col overflow-hidden">

        <!-- Header -->
        <%- include('../partials/header') %>

        <!-- Main -->
        <main class="flex-1 p-6 pb-0 md:pl-0 overflow-hidden">
            <div class="w-full h-full bg-white rounded-3xl p-6 overflow-y-auto space-y-6 mt-6">

                <!--Main Header-->
                <div>
                    <div class="flex items-center gap-4 mb-5">
                        <a href="/clinical">
                            <button class="cursor-pointer pb">
                                <svg class="black-icon shrink-0 size-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 9-3 3m0 0 3 3m-3-3h7.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                                </svg>
                            </button>
                        </a>
                        <h1 class="text-2xl font-bold text-[#1E1E1E]">
                            Permisos del colaborador
                        </h1>
                    </div>
                    
                    <hr class="border-3 rounded-2xl border-[#002B7A]">
                </div>
                 <!-- Clinical User Name -->
                <h2 class="text-xl font-semibold text-[#1E1E1E]">
                    <%= user.userName %>
                </h2>

                <!-- Permissions Table -->
                <div class="overflow-x-auto">
                    <table class="w-full text-sm border-collapse">
                        <thead>
                            <tr class="border-b-2 border-gray-200">
                                <th class="text-left py-3 pr-6 font-semibold text-[#1E1E1E] w-1/3">
                                    Módulo del sistema
                                </th>
                                <th class="text-center py-3 px-4 font-semibold text-[#1E1E1E]">Ver</th>
                                <th class="text-center py-3 px-4 font-semibold text-[#1E1E1E]">Crear</th>
                                <th class="text-center py-3 px-4 font-semibold text-[#1E1E1E]">Editar</th>
                                <th class="text-center py-3 px-4 font-semibold text-[#1E1E1E]">Eliminar</th>
                                <th class="text-center py-3 px-4 font-semibold text-[#1E1E1E]">Origen del permiso</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% modules.forEach(module => { %>
                                <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors"
                                    data-module-id="<%= module.idModule %>">

                                    <!-- Module Name -->
                                    <td class="py-3 pr-6 text-[#1E1E1E]">
                                        <%= module.moduleName %>
                                    </td>

                                    <!-- Action Checkboxes (fixed columns: ver, crear, editar, eliminar) -->
                                    <% ['ver', 'crear', 'editar', 'eliminar'].forEach(action => { %>
                                        <td class="text-center py-3 px-4">
                                            <input
                                                type="checkbox"
                                                id="cb-<%= module.idModule %>-<%= action %>"
                                                class="permission-checkbox w-5 h-5 cursor-pointer accent-[#C9A84C]"
                                                data-module-id="<%= module.idModule %>"
                                                data-action="<%= action %>"
                                                <%# Pre-populate checked state from backend value %>
                                                <%= module.actions[action].active ? 'checked' : '' %>
                                            />
                                        </td>
                                    <% }) %>

                                    <!-- Origin Badge -->
                                    <td class="text-center py-3 px-4">
                                        <span
                                            class="origin-badge px-3 py-1 rounded text-xs font-medium
                                                   <%= module.hasCustomException ? 'bg-[#7C6FCD] text-white' : 'bg-[#C9A84C] text-white' %>"
                                            data-module-id="<%= module.idModule %>">
                                            <%= module.hasCustomException ? 'Personalizado' : 'Heredado del Rol' %>
                                        </span>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>

                <!-- Save Button -->
                <div class="flex justify-end pb-4">
                    <button
                        id="btn-save-permissions"
                        class="flex items-center gap-2 bg-[#002B7A] text-white px-5 py-2 rounded-lg font-semibold hover:bg-[#001f5c] transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                        data-user-id="<%= user.idUser %>">
                        <svg class="size-5 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none"
                             viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M9 3.75H6.912a2.25 2.25 0 0 0-2.15 1.588L2.35 13.177a2.25 2.25 0 0 0-.1.661V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18v-4.162c0-.224-.034-.447-.1-.661L19.24 5.338a2.25 2.25 0 0 0-2.15-1.588H15M2.25 13.5h3.86a2.25 2.25 0 0 1 2.012 1.244l.256.512a2.25 2.25 0 0 0 2.013 1.244h3.218a2.25 2.25 0 0 0 2.013-1.244l.256-.512a2.25 2.25 0 0 1 2.013-1.244h3.859M12 3v8.25m0 0-3-3m3 3 3-3" />
                        </svg>
                        Guardar
                    </button>
                </div>

            </div>
                
                
        </main>
    </div>



    <script src="/js/sidebar.js"></script>
    <script src="/js/main.js"></script>