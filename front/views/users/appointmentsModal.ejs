<!-- Flatpickr CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<div id="appointmentModal" class="fixed inset-0 z-50 flex items-center justify-center hidden">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
    <div class="relative bg-white rounded-2xl p-8 max-w-md w-full mx-4 shadow-2xl">
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-semibold text-gray-900">Agendar cita</h2>
            <button id="closeAppointmentModal" class="text-gray-400 hover:text-gray-700 transition-colors cursor-pointer" aria-label="Cerrar">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                </svg>
            </button>
        </div>
        <div class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2" for="appointmentDateTime">Fecha y hora</label>
                <div class="search-input">
                    <input
                        id="appointmentDateTime"
                        type="text"
                        placeholder="Selecciona fecha y hora"
                        class="search-input_field"
                    />
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2" for="appointmentClinic">Clínico asignado</label>
                <div class="search-input">
                    <select id="appointmentClinic" class="search-input_field">
                        <option value="">Cargando clínicos...</option>
                    </select>
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2" for="appointmentIssue">Motivo</label>
                <div class="search-input">
                    <input
                        id="appointmentIssue"
                        type="text"
                        maxlength="50"
                        placeholder="Ej. Evaluación inicial"
                        class="search-input_field"
                    />
                </div>
                <p class="text-xs text-gray-400 mt-1">Máx. 50 caracteres</p>
            </div>
            <p id="appointmentError" class="text-sm text-red-500 hidden"></p>
        </div>

        <div class="flex gap-3 justify-end mt-6">
            <button id="cancelAppointment"
                class="flex items-center gap-2 px-5 py-2 rounded-lg border border-gray-300 text-gray-700 text-sm hover:bg-gray-50 transition-colors cursor-pointer">
                Cancelar
            </button>
            <button id="confirmAppointment" class="btn-mini bg-[#3350A9]">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="white-icon-mini">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5m-9-6h.008v.008H12v-.008ZM12 15h.008v.008H12V15Zm0 2.25h.008v.008H12v-.008ZM9.75 15h.008v.008H9.75V15Zm0 2.25h.008v.008H9.75v-.008ZM7.5 15h.008v.008H7.5V15Zm0 2.25h.008v.008H7.5v-.008Zm6.75-4.5h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V15Zm0 2.25h.008v.008h-.008v-.008Zm2.25-4.5h.008v.008H16.5v-.008Zm0 2.25h.008v.008H16.5V15Z" />
                </svg>
                <span>Agendar</span>
            </button>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<script>
// NOTE: flatpickr was included with AI help especially the initDatePickerfunction, but I try to well document it
(function () {
    const btnOpen = document.getElementById('btnScheduleAppointment');
    const modal = document.getElementById('appointmentModal');
    const btnClose = document.getElementById('closeAppointmentModal');
    const btnCancel = document.getElementById('cancelAppointment');
    const btnConfirm = document.getElementById('confirmAppointment');
    const errorBox = document.getElementById('appointmentError');

    const inputDate = document.getElementById('appointmentDateTime');
    const selectClinic = document.getElementById('appointmentClinic');
    const inputIssue = document.getElementById('appointmentIssue');

    const user   = window.__USER_DATA__ || {};
    const idUser = user.idUser;

    let datePicker = null;
    let clinicsLoaded = false;

    function initDatePicker() {
        if (datePicker) return;
        datePicker = flatpickr(inputDate, {
            enableTime: true,
            // format for backend compatibility
            dateFormat: "Y-m-d H:i",
            // no past dates
            minDate: "today",
            time_24hr: true, 
            minuteIncrement: 30,
        });
    }

    // Call the api to know all clinics id and names to show
    async function loadClinics() {
        if (clinicsLoaded) return;
        try {
            const res = await fetch('/api/clinics/list', { credentials: 'include' });
            if (!res.ok) throw new Error('No se pudieron cargar los clínicos');
            const clinics = await res.json();
            // show all clinics and asks to select one
            selectClinic.innerHTML = '<option value="">Selecciona un clínico</option>' +
                clinics.map(c =>
                    `<option value="${escapeHtml(c.id)}">${escapeHtml(c.full_name)}</option>`
                ).join('');
            clinicsLoaded = true;
        } catch (err) {
            selectClinic.innerHTML = '<option value="">Error al cargar</option>';
            console.error(err);
        }
    }

    function showError(msg) {
        errorBox.textContent = msg;
        errorBox.classList.remove('hidden');
    }
    function hideError() {
        errorBox.classList.add('hidden');
        errorBox.textContent = '';
    }

    function resetForm() {
        if (datePicker) datePicker.clear();
        selectClinic.value = '';
        inputIssue.value = '';
        hideError();
    }

    btnOpen?.addEventListener('click', () => {
        modal.classList.remove('hidden');
        initDatePicker();
        loadClinics();
    });

    const closeModal = () => {
        modal.classList.add('hidden');
        resetForm();
    };
    btnClose?.addEventListener('click', closeModal);
    btnCancel?.addEventListener('click', closeModal);

    btnConfirm?.addEventListener('click', async () => {
        hideError();

        const dateTime = inputDate.value;
        const clinicId = selectClinic.value;
        const issue = inputIssue.value.trim();

        if (!dateTime)  return showError('Selecciona una fecha y hora');
        if (!clinicId)  return showError('Selecciona un clínico');
        if (!issue)     return showError('Ingresa el motivo de la cita');

        const originalHTML = btnConfirm.innerHTML;
        try {
            btnConfirm.disabled = true;
            btnConfirm.innerHTML = '<span>Agendando...</span>';

            const res = await fetch(`/users/${idUser}/appointments`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({
                    id_clinic_user: clinicId,
                    issue,
                    date_time: dateTime,
                }),
            });

            const data = await res.json();
            if (!res.ok) throw new Error(data.error || 'Error al agendar');

            showToast('Cita agendada con éxito', 'success');
            // close modal and refresh 
            setTimeout(() => window.location.reload(), 1200);
        } catch (err) {
            showError(err.message);
            btnConfirm.disabled = false;
            btnConfirm.innerHTML = originalHTML;
        }
    });
})();
</script>