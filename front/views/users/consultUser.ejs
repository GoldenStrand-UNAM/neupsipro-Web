    <script>
        document.getElementById("IIbutton").addEventListener("click", () => {

            window.location.href = `/users/<%= usuario.idUser %>/initial-interview/financial`;
        });

    if (sessionStorage.getItem('modifiedUser') === 'true') {
        showToast('Usuario modificado correctamente');
        sessionStorage.removeItem('modifiedUser');
    }

        function escapeHTML(str) {
            if (str === null || str === undefined) return '';
            return String(str)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        }

        const _statusStyles = {
            warning: {
                tag: "bg-[#BA8700]",
                card: "bg-[#BA8700]/30",
                icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />`
            },
            neutral: {
                tag: "bg-gray-400",
                card: "bg-gray-200/30",
                icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />`
            },
            success: {
                tag: "bg-[#002B79]",
                card: "bg-[#002B79]/30",
                icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />`
            },
            complete: {
                tag: "bg-[#002B79]",
                card: "bg-[#002B79]/30",
                icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />`
            },
            fatal: {
                tag: "bg-[#FF0404]",
                card: "bg-[#FF0404]/30",
                icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 0 0 5.636 5.636m12.728 12.728A9 9 0 0 1 5.636 5.636m12.728 12.728L5.636 5.636" />`
            }
        };

        const nameCount = document.getElementById('nameCount');
        const inputAppName = document.getElementById('inputAppName');

        inputAppName.addEventListener('input', () => {
            const max = 20;
            const length = inputAppName.value.length;
            nameCount.innerText = `${length}/${max}`;
        });

        const _statusMap = {
            "Por comenzar": "neutral",

            "En proceso": "warning",

            "Calificada": "complete",

            "Entregado": "success",
            "Terminada": "success",

            "Caducada": "fatal",
        };

        function getStatusStyle(status) {
            const type = _statusMap[status] || "neutral";
            return _statusStyles[type];
        }


        function createApplicationCard(application, idUser) {
            const colors = getStatusStyle(application.status);
            const dateFormatted = application.createdAt
                ? new Date(application.createdAt).toLocaleDateString('es-MX', { day: '2-digit', month: '2-digit', year: 'numeric' })
                : 'Fecha no disponible';
            //TODO: uncomment redirect when clicking application card
            return `
                <a href="/users/${escapeHTML(idUser)}/applications/${escapeHTML(application.idApplication)}/tests" class="block relative rounded-3xl p-6 w-full md:w-auto ${colors.card} hover:opacity-80 transition-opacity cursor-pointer">
                    
                    <div class="absolute top-3 right-3 text-white text-xs px-3 py-1 rounded-full flex items-center gap-1 ${colors.tag}">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4">
                            ${colors.icon}
                        </svg>
                        <p>${escapeHTML(application.status) || "N/A"}</p>
                    </div>

                    <div class="flex flex-col gap-2 mt-4">
                        <div>
                            <svg class="w-8 h-8 opacity-75" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                            </svg>
                        </div>
                        <h3 class="text-lg font-bold text-gray-900">
                            ${escapeHTML(application.applicationName)}
                        </h3>
                        <p class="text-sm text-gray-700">
                            Creada el: ${dateFormatted}
                        </p>
                    </div>
                </a>
            `;
        }

        function createAddSessionCard() {
            return `
                <button id="btnCreateSession"
                    class="flex flex-col items-center justify-center gap-3 rounded-3xl p-6 w-full border-2 border-dashed border-gray-300 hover:border-[#3350A9] hover:bg-[#3350A9]/5 transition-colors cursor-pointer text-gray-400 hover:text-[#3350A9]">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v6m3-3H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                    </svg>
                    <span class="text-sm font-medium">Nueva aplicación</span>
                </button>
            `;
        }
    </script>


   <script>
