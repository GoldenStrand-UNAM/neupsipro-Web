<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Usuario - Golondrina</title>
    <link rel="stylesheet" href="/css/output.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.css"/>
</head>

<body data-module="<%= tutorialModule %>" class="bg-[#0A2472] flex h-screen lg:flex-row transition-transform duration-300">
    <script src="/js/main.js"></script>

    <div id="overlay" class="fixed inset-0 bg-black/40 hidden md:hidden"></div>

    <!-- Sidebar -->
    <%- include('../partials/sidebar') %>

    <div class="flex-1 flex flex-col overflow-hidden">

        <!-- Header -->
        <%- include('../partials/header') %>

        <!-- Main -->
        <main class="flex-1 p-6 pb-0 md:pl-0 overflow-hidden">
            <div class="w-full h-full bg-white rounded-tl-3xl rounded-tr-3xl p-6 overflow-y-auto space-y-6">
                <!--Main Header-->
                <div>
                    <div class="flex items-center gap-4 mb-5">
                        <a href="/users">
                            <button class="cursor-pointer pb">
                                <svg class="black-icon shrink-0 size-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 9-3 3m0 0 3 3m-3-3h7.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                                </svg>
                            </button>
                        </a>
                        <h1 class="text-2xl font-bold text-[#1E1E1E]">
                            Usuario 
                        </h1>
                    </div>
                    
                    <hr class="border-3 rounded-2xl border-[#002B7A]">
                </div>
                                
                
                <!-- User info -->
                <div id="userInfoCard" class="relative grid grid-cols-1 lg:grid-cols-3 gap-4 md:gap-8 items-center border rounded-2xl border-gray-300 p-6 mt-6">

                    <div class="absolute top-4 right-4">
                        <button id="btnUserOptions" class="p-2 text-gray-500 hover:text-gray-800 hover:bg-gray-100 rounded-full transition-colors cursor-pointer" aria-label="Opciones de usuario">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 12.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 18.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5Z" />
                            </svg>
                        </button>

                        <div id="userOptionsMenu" class="hidden absolute right-0 mt-2 w-40 bg-white border border-gray-200 rounded-xl shadow-lg z-40 overflow-hidden">
                            <button id="btnEditUser" class="w-full flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors cursor-pointer">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L6.832 19.82a4.5 4.5 0 0 1-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 0 1 1.13-1.897L16.863 4.487z" />
                                </svg>
                                Editar
                            </button>
                            <button id="btnDeleteUser" class="w-full flex items-center gap-2 px-4 py-2 text-sm text-red-600 hover:bg-red-50 transition-colors cursor-pointer">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                                </svg>
                                Eliminar
                            </button>
                        </div>
                    </div>
                    <!-- Photo and Name -->
                   <div class="flex flex-col items-center justify-center text-center gap-2">
                        <% if (usuario.photo) { %>
                            <img class="w-24 h-24 rounded-full object-cover " src="<%= usuario.photo %>" alt="Foto de perfil">
                        <% } else { %>
                            <div class="w-24 h-24 rounded-full bg-gray-200 flex items-center justify-center overflow-hidden">
                                <svg class="w-12 h-12 text-gray-500 mt-1" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                                    <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"></path>
                                </svg>
                            </div>
                        <% } %>
                    

                        <p id="userName" class="text-lg font-semibold"></p>
                        <p id="userCode" class="text-sm text-gray-500"></p>
                    </div>

                    <!-- First Column -->
                    <div class="space-y-4">
                        <div class="flex flex-wrap items-start gap-3 w-full">
                            <svg class="w-5 h-5 md:w-6 md:h-6 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" />
                            </svg>
                            <span class="text-gray-600">Edad:</span>
                            <span class="font-medium" id="userAge"></span>
                        </div>
                        <div class="flex flex-wrap items-start gap-3 w-full">
                            <svg class="w-5 h-5 md:w-6 md:h-6 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
                            </svg>
                            <span class="text-gray-600">Ingreso a unidad:</span>
                            <span class="font-medium" id="userDate"></span>
                        </div>
                        <div class="flex flex-wrap items-start gap-3 w-full">
                            <svg class="w-5 h-5 md:w-6 md:h-6 shrink-0" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M14.7368 0H16.2105C19.3373 0 22.336 1.2421 24.5469 3.45306C26.7579 5.66401 28 8.66271 28 11.7895V13.2632H14.7368V0ZM16.2105 11.7895H26.5263C26.5263 9.05356 25.4395 6.42969 23.5049 4.49511C21.5703 2.56052 18.9464 1.47368 16.2105 1.47368V11.7895ZM11.7895 16.2105H23.5789C23.5789 19.3373 22.3368 22.336 20.1259 24.5469C17.9149 26.7579 14.9162 28 11.7895 28C8.66271 28 5.66401 26.7579 3.45306 24.5469C1.2421 22.336 0 19.3373 0 16.2105C0 13.0838 1.2421 10.0851 3.45306 7.87411C5.66401 5.66315 8.66271 4.42105 11.7895 4.42105V16.2105ZM10.3158 17.6842V5.99789C5.32 6.72 1.47368 11.0084 1.47368 16.2105C1.47368 18.9464 2.56052 21.5703 4.49511 23.5049C6.42969 25.4395 9.05356 26.5263 11.7895 26.5263C16.9916 26.5263 21.28 22.68 22.0021 17.6842H10.3158Z" fill="black"/>
                            </svg>
                            <span class="text-gray-600">Fase:</span>
                            <span class="font-medium" id="userPhase"></span>
                        </div>
                        <div class="flex flex-wrap items-start gap-3 w-full">
                            <svg class="w-5 h-5 md:w-6 md:h-6 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
                            </svg>
                            <span class="text-gray-600">Pares:</span>
                            <span class="font-medium" id="groupIntervention"></span>
                        </div>
                        <div class="extra-field hidden md:flex flex-wrap items-start gap-3 w-full min-w-0">
                            <svg class="w-5 h-5 md:w-6 md:h-6 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
                            </svg>
                            <span class="text-gray-600 whitespace-nowrap">Etiología:</span>
                            <span class="font-medium wrap-break-word min-w-0" id="etiology"></span>
                        </div>
                    </div>

                    <!-- Second Column -->
                    <div class="space-y-4">
                        <div class="extra-field hidden md:flex flex-wrap items-start gap-3 w-full min-w-0">
                            <svg class="w-5 h-5 md:w-6 md:h-6 shrink-0" viewBox="0 0 27 31" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M7.038 24.2563H8.538V20.9106H11.538V19.2378H8.538V15.8921H7.038V19.2378H4.038V20.9106H7.038V24.2563ZM15 18.9166H23.25V17.4361H15V18.9166ZM15 22.9047H20.25V21.4259H15V22.9047ZM2.424 30.1113C1.733 30.1113 1.1565 29.8537 0.6945 29.3385C0.2325 28.8232 0.001 28.1803 0 27.4097V11.0659C0 10.2964 0.2315 9.65403 0.6945 9.13879C1.1575 8.62355 1.7335 8.36537 2.4225 8.36426H10.5V1.67285C10.5 1.20334 10.645 0.80743 10.935 0.485127C11.224 0.161709 11.579 0 12 0H15C15.421 0 15.776 0.161709 16.065 0.485127C16.355 0.80743 16.5 1.20334 16.5 1.67285V8.36426H24.5775C25.2675 8.36426 25.8435 8.62243 26.3055 9.13879C26.7675 9.65514 26.999 10.2981 27 11.0676V27.4097C27 28.1792 26.7685 28.8221 26.3055 29.3385C25.8425 29.8548 25.2665 30.1124 24.5775 30.1113H2.424ZM2.424 28.4385H24.5775C24.8465 28.4385 25.0675 28.342 25.2405 28.1491C25.4135 27.9561 25.5 27.7097 25.5 27.4097V11.0659C25.5 10.7659 25.4135 10.5194 25.2405 10.3265C25.0675 10.1336 24.8465 10.0371 24.5775 10.0371H16.5V11.3252C16.5 11.7724 16.3505 12.1627 16.0515 12.4962C15.7525 12.8297 15.402 12.9969 15 12.9981H12C11.598 12.9981 11.2475 12.8308 10.9485 12.4962C10.6495 12.1616 10.5 11.7713 10.5 11.3252V10.0371H2.424C2.154 10.0371 1.9325 10.1336 1.7595 10.3265C1.5865 10.5194 1.5 10.7665 1.5 11.0676V27.4097C1.5 27.7097 1.5865 27.9561 1.7595 28.1491C1.9325 28.342 2.154 28.4385 2.424 28.4385ZM12 11.3252H15V1.67285H12V11.3252Z" fill="black"/>
                            </svg>
                            <span class="text-gray-600">Protesista:</span>
                            <span class="font-medium wrap-break-word min-w-0" id="prosthetist"></span>
                        </div>
                        <div class="extra-field hidden md:flex flex-wrap items-start gap-3 w-full">
                            <svg class="w-5 h-5 md:w-6 md:h-6 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
                            </svg>
                            <span class="text-gray-600">Ingreso a neuropsicología:</span>
                            <span class="font-medium" id="neuroDate"></span>
                        </div>
                        <div class="extra-field hidden md:flex flex-wrap items-start gap-3 w-full">
                            <svg class="w-5 h-5 md:w-6 md:h-6 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5m-9-6h.008v.008H12v-.008ZM12 15h.008v.008H12V15Zm0 2.25h.008v.008H12v-.008ZM9.75 15h.008v.008H9.75V15Zm0 2.25h.008v.008H9.75v-.008ZM7.5 15h.008v.008H7.5V15Zm0 2.25h.008v.008H7.5v-.008Zm6.75-4.5h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V15Zm0 2.25h.008v.008h-.008v-.008Zm2.25-4.5h.008v.008H16.5v-.008Zm0 2.25h.008v.008H16.5V15Z" />
                            </svg>
                            <span class="text-gray-600">Fecha de amputación:</span>
                            <span class="font-medium" id="amputationDate"></span>
                        </div>
                         <div class="extra-field hidden md:flex items-start gap-3 w-full min-w-0">
                            <svg class="w-5 h-5 md:w-6 md:h-6 shrink-0" width="28" height="19" viewBox="0 0 28 19" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M28 0.730769C28 0.924581 27.925 1.11046 27.7915 1.2475C27.658 1.38455 27.4769 1.46154 27.2881 1.46154H21.3559V6.57692C21.3559 6.77074 21.2809 6.95661 21.1474 7.09365C21.0139 7.2307 20.8329 7.30769 20.6441 7.30769H14.7119V12.4231C14.7119 12.6169 14.6369 12.8028 14.5034 12.9398C14.3699 13.0769 14.1888 13.1538 14 13.1538H8.0678V18.2692C8.0678 18.463 7.9928 18.6489 7.8593 18.786C7.7258 18.923 7.54473 19 7.35593 19H0.711864C0.523066 19 0.342001 18.923 0.2085 18.786C0.0749998 18.6489 0 18.463 0 18.2692C0 18.0754 0.0749998 17.8895 0.2085 17.7525C0.342001 17.6155 0.523066 17.5385 0.711864 17.5385H6.64407V12.4231C6.64407 12.2293 6.71907 12.0434 6.85257 11.9063C6.98607 11.7693 7.16713 11.6923 7.35593 11.6923H13.2881V6.57692C13.2881 6.38311 13.3631 6.19724 13.4966 6.06019C13.6301 5.92315 13.8112 5.84615 14 5.84615H19.9322V0.730769C19.9322 0.536957 20.0072 0.351083 20.1407 0.214037C20.2742 0.0769914 20.4553 0 20.6441 0H27.2881C27.4769 0 27.658 0.0769914 27.7915 0.214037C27.925 0.351083 28 0.536957 28 0.730769Z" fill="black"/>
                            </svg>
                            
                            <div class="min-w-0 leading-tight">
                                <span class="text-gray-600">Nivel de amputación:</span>
                                <span class="font-medium wrap-break-word" id="amputationLevel"></span>
                            </div>
                        </div>
                        <div class="extra-field hidden md:flex flex-wrap items-start gap-3 w-full">
                            <svg class="w-5 h-5 md:w-6 md:h-6 shrink-0" width="28" height="28" viewBox="0 0 29 29" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M14.5 28.2721V16.3368M14.5 16.3368C14.5 10.4921 10.5048 5.72205 5.48755 5.45117M14.5 16.3368C14.5 10.4921 18.4953 5.72205 23.5125 5.45117" stroke="black" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M5.48752 9.46485V1.41367C5.48752 0.601541 4.63449 0.194182 4.13564 0.769155L0.79697 4.6139C0.702819 4.72232 0.628135 4.85104 0.57718 4.9927C0.526226 5.13436 0.5 5.28619 0.5 5.43952C0.5 5.59285 0.526226 5.74468 0.57718 5.88634C0.628135 6.028 0.702819 6.15671 0.79697 6.26514L4.1361 10.1099C4.63449 10.6843 5.48752 10.2775 5.48752 9.46485ZM23.5125 9.46485V1.41367C23.5125 0.601541 24.3655 0.194182 24.8644 0.769155L28.203 4.6139C28.2972 4.72232 28.3719 4.85104 28.4228 4.9927C28.4738 5.13436 28.5 5.28619 28.5 5.43952C28.5 5.59285 28.4738 5.74468 28.4228 5.88634C28.3719 6.028 28.2972 6.15671 28.203 6.26514L24.8644 10.1099C24.3655 10.6843 23.5125 10.2775 23.5125 9.46485Z" stroke="black" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>

                            <span class="text-gray-600">Lateralidad:</span>
                            <span class="font-medium" id="laterality"></span>
                        </div>
                        <div class="flex justify-end md:hidden">
                            <button id="btnShowMore" class="flex items-center gap-1 text-sm font-medium text-gray-700 bg-white px-3 py-1">
                                <svg id="iconMore" class="block" width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M7.36842 13.2632H13.2632V7.36842H14.7368V13.2632H20.6316V14.7368H14.7368V20.6316H13.2632V14.7368H7.36842V13.2632ZM14 0C17.713 0 21.274 1.475 23.8995 4.1005C26.525 6.72601 28 10.287 28 14C28 17.713 26.525 21.274 23.8995 23.8995C21.274 26.525 17.713 28 14 28C10.287 28 6.72601 26.525 4.1005 23.8995C1.475 21.274 0 17.713 0 14C0 10.287 1.475 6.72601 4.1005 4.1005C6.72601 1.475 10.287 0 14 0ZM14 1.47368C10.6778 1.47368 7.4917 2.79342 5.14256 5.14256C2.79342 7.4917 1.47368 10.6778 1.47368 14C1.47368 17.3222 2.79342 20.5083 5.14256 22.8574C7.4917 25.2066 10.6778 26.5263 14 26.5263C15.645 26.5263 17.2739 26.2023 18.7936 25.5728C20.3134 24.9433 21.6943 24.0206 22.8574 22.8574C24.0206 21.6943 24.9433 20.3134 25.5728 18.7936C26.2023 17.2739 26.5263 15.645 26.5263 14C26.5263 10.6778 25.2066 7.4917 22.8574 5.14256C20.5083 2.79342 17.3222 1.47368 14 1.47368Z" fill="black"/>
                                </svg>
                                <svg id="iconLess" class="hidden" width="28" height="28" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M6.03452 14.6504H23.2653M28.6499 14.6504C28.6499 18.3634 27.1749 21.9244 24.5494 24.5499C21.9239 27.1754 18.3629 28.6504 14.6499 28.6504C10.9369 28.6504 7.37592 27.1754 4.75041 24.5499C2.1249 21.9244 0.649902 18.3634 0.649902 14.6504C0.649902 10.9374 2.1249 7.37641 4.75041 4.7509C7.37592 2.12539 10.9369 0.650391 14.6499 0.650391C18.3629 0.650391 21.9239 2.12539 24.5494 4.7509C27.1749 7.37641 28.6499 10.9374 28.6499 14.6504Z" stroke="black" stroke-width="1.3"/>
                                </svg>

                                <span id="textShowMore">Ver más</span>
                            </button>
                        </div>
                    </div>

                </div>

                <div  id="statusSection" class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-center p-6 mt-6">
                    <div class="space-y-4 w-fit mx-auto">
                        <button id="btnEditStatus"
                                class="flex items-center justify-start gap-2 hover:bg-gray-100 rounded-lg p-2 cursor-pointer transition-colors group">
                            <span class="text-gray-600 text-base md:text-xl">Estatus: </span>
                            <span id="state"></span>
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
                                class="w-4 h-4 ml-1 text-gray-400 opacity-0 group-hover:opacity-100 transition-opacity">
                                <path stroke-linecap="round" stroke-linejoin="round"
