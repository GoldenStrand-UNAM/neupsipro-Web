<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Intervención - NeuPsi-Pro</title>
    <link rel="stylesheet" href="/css/output.css">
</head>
<body class="bg-[#0A2472] flex min-h-screen flex-col lg:flex-row transition-transform duration-300">

    <div id="overlay" class="fixed inset-0 bg-black/40 hidden md:hidden"></div>

    <%- include('../../partials/sidebar') %>

    <div class="flex-1 flex flex-col overflow-hidden">
        <%- include('../../partials/header') %>

        <main class="flex-1 p-6 pb-0 md:pl-0 overflow-hidden">
            <div class="w-full h-full bg-white rounded-3xl p-6 overflow-y-auto space-y-6 mt-6">

                <div>
                    <div class="flex flex-wrap items-center gap-3 md:gap-4 mb-5">
                        <a href="/users/<%= idUser %>">
                            <button class="cursor-pointer">
                                <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 9-3 3m0 0 3 3m-3-3h7.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                                </svg>
                            </button>
                        </a>
                        <h1 class="text-xl sm:text-2xl font-bold text-[#1E1E1E]">Intervención</h1>
                    </div>
                    <hr class="border-3 rounded-2xl border-[#002B7A]">
                </div>

                <!-- User_info-->
                <div class="border border-gray-200 rounded-2xl p-6 space-y-4">
                    <div class="flex flex-col sm:flex-row items-start gap-4">
                        <% if (intervention.photo) { %>
                            <img 
                                src="<%= intervention.photo %>" 
                                class="w-16 h-16 sm:w-20 sm:h-20 rounded-full object-cover border-2 border-white shadow-sm" 
                                alt="Foto de <%= intervention.userFullName %>"
                            >
                        <% } else { %>
                            <div class="w-16 h-16 sm:w-20 sm:h-20 rounded-full bg-gray-200 border-2 border-white shadow-sm flex items-center justify-center overflow-hidden">
                                <svg 
                                    class="w-10 h-10 text-gray-500" 
                                    fill="currentColor" 
                                    viewBox="0 0 20 20"
                                >
                                    <path 
                                        fill-rule="evenodd" 
                                        d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" 
                                        clip-rule="evenodd"
                                    ></path>
                                </svg>
                            </div>
                        <% } %>

                        <div class="flex-1">
                            <h2 class="text-lg sm:text-xl font-bold break-words text-gray-900">
                                <%= intervention.referenceNumber || 'Sin código' %>
                            </h2>

                            <p class="text-sm break-words text-gray-500">
                                <%= intervention.userFullName %>
                            </p>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-2 mt-3 text-sm">
                                <div class="flex items-center gap-2">
                                    <span class="text-gray-500">Escolaridad:</span>
                                    <span class="font-medium text-gray-700">
                                        <%= intervention.schooling || '—' %>
                                    </span>
                                </div>

                                <div class="flex items-center gap-2">
                                    <span class="text-gray-500">Ocupación:</span>
                                    <span class="font-medium text-gray-700">
                                        <%= intervention.ocupation || '—' %>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Clinic Contract -->
                    <div class="pt-3 border-t border-gray-100">

                        <div class="flex items-start gap-3">

                            <svg class="black-icon-mini shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
                            </svg>
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center justify-between gap-2 mb-1">
                                    <p class="text-gray-600 text-sm">
                                        Contrato clínico:
                                    </p>
                                    <button id="btnEditContract" class="text-gray-400 hover:text-[#3350A9] shrink-0 cursor-pointer" title="Editar datos">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125"/>
                                        </svg>
                                    </button>
                                </div>
                                <% if (intervention.contractLink) { %>
                                    <a href="<%= intervention.contractLink %>" target="_blank" class="text-[#3350A9] text-sm hover:underline break-all">
                                        <%= intervention.contractLink %>
                                    </a>
                                <% } else { %>
                                    <p class="text-gray-400 text-sm italic">
                                        Sin contrato registrado
                                    </p>
                                <% } %>
                            </div>
                        </div>
                    </div>

                    <!-- neuro Profile -->
                    <div class="pt-3 border-t border-gray-100">
                        <div class="flex items-start gap-3">
                            <svg class="black-icon-mini" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" />
                            </svg>

                            <div class="flex-1 min-w-0">
                                <div class="flex items-center justify-between gap-2 mb-1">
                                    <p class="text-gray-600 text-sm">Perfil neuropsicológico:</p>
                                    <button id="btnEditProfile" class="text-gray-400 hover:text-[#3350A9] cursor-pointer shrink-0" title="Editar perfil neuropsicológico">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125" />
                                        </svg>
                                    </button>
                                </div>

                                <% if (intervention.neuroProfile) { %>
                                    <p class="text-gray-700 text-sm whitespace-pre-line break-words"><%= intervention.neuroProfile %></p>
                                <% } else { %>
                                    <p class="text-gray-400 text-sm italic">Sin perfil neuropsicológico registrado</p>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tabla de sesiones -->
                <div class="border border-gray-200 rounded-2xl overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="min-w-[900px] w-full text-sm table-fixed">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="py-3 px-4 text-left text-gray-700 font-medium w-28">Fecha</th>
                                <th class="py-3 px-4 text-left text-gray-700 font-medium w-20">Sesión</th>
                                <th class="py-3 px-4 text-left text-gray-700 font-medium">Desarrollo</th>
                                <th class="py-3 px-4 text-left text-gray-700 font-medium">Objetivos</th>
                                <th class="py-3 px-4 text-left text-gray-700 font-medium">DQP / Tarea</th>
                                <th class="py-3 px-4 w-10"></th>
                            </tr>
                        </thead>
                        <tbody id="sessionsTbody">
                            <% if (!intervention.sessions.length) { %>
                                <tr>
                                    <td colspan="6" class="py-12 text-center text-gray-400">
                                        Sin sesiones registradas todavía
                                    </td>
                                </tr>
                            <% } else { %>
                                <% intervention.sessions.forEach((s, idx) => { %>
                                    <tr class="session-row border-t border-gray-100 hover:bg-gray-50 align-top cursor-pointer"
                                        data-date="<%= new Date(s.sessionDate).toLocaleDateString('es-MX') %>"
                                        data-number="<%= s.sessionNumber || '—' %>"
                                        data-development="<%= s.development || '—' %>"
                                        data-objectives="<%= s.objectives || '—' %>"
                                        data-dqp="<%= s.dqpTask || '—' %>">

                                        <td class="py-3 px-4 text-gray-700 break-words">
                                            <%= new Date(s.sessionDate).toLocaleDateString('es-MX') %>
                                        </td>
                                        <td class="py-3 px-4 text-gray-700 break-words">
                                            <%= s.sessionNumber || '—' %>
                                        </td>
                                        <td class="py-3 px-4 text-gray-500 break-words truncatable">
                                            <%= s.development || '—' %>
                                        </td>
                                        <td class="py-3 px-4 text-gray-500 break-words truncatable">
                                            <%= s.objectives || '—' %>
                                        </td>
                                        <td class="py-3 px-4 text-gray-500 break-words truncatable">
                                            <%= s.dqpTask || '—' %>
                                        </td>

                                        <td class="py-3 px-4 text-center" onclick="event.stopPropagation()">
                                            <% if (idx === intervention.sessions.length - 1) { %>
                                                <button class="btn-delete-session text-red-500 hover:text-red-700 cursor-pointer"
                                                        data-session-id="<%= s.idSession %>"
                                                        title="Eliminar última sesión">
                                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                                        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                                                    </svg>
                                                </button>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                        </table>
                    </div>
                </div>

                <!-- add session -->
                <div class="flex justify-center mt-6 mb-2">
                    <button id="btnAddSession" class="btn-mini bg-[#BA8700] w-full md:w-[220px]">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="white-icon">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                        </svg>
                        <span>Agregar sesión</span>
                    </button>
                </div>

            </div>
        </main>
    </div>


    <script>
        window.__INTERVENTION_DATA__ = {
            idUser: '<%= idUser %>',
            contractLink:  <%- JSON.stringify(intervention.contractLink || '') %>,
            neuro_profile : <%- JSON.stringify(intervention.neuro_profile || '') %>,
            csrfToken: '<%= csrfToken %>',
        };
    </script>

    <script src="/js/main.js"></script>
    <script src="/js/sidebar.js"></script>

    <!-- Modals -->
    <%- include('./editContractModal') %>
    <%- include('./addSessionModal') %>
    <%- include('./deleteSessionModal') %>
    <%- include('./sessionDetailModal') %>
</body>
</html>