<div id="editContractModal" class="fixed inset-0 z-50 flex items-center justify-center hidden">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
    <div class="relative bg-white rounded-2xl p-4 sm:p-6 md:p-8 max-w-xl w-full mx-4 max-h-[90vh] overflow-y-auto shadow-2xl">

        <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-semibold text-gray-900">Datos de la intervención</h2>
            <button id="closeEditContract" class="text-gray-400 hover:text-gray-700 cursor-pointer">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <div class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2" for="editContractLinkInput">
                    Link del contrato clínico
                </label>
                <div class="relative w-full flex items-center">
                    <input id="editContractLinkInput" type="url" placeholder="https://drive.google.com/..." class="search-input_field w-full pr-16" maxlength="250" />
                    <span id="charContractLink" class="absolute right-3 text-xs text-gray-400 pointer-events-none">0/250</span>
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2" for="editNeuropsychInput">
                    Perfil neuropsicológico
                </label>
                <div class="w-full border border-gray-300 rounded-lg focus-within:ring-2 focus-within:ring-[#3350A9] focus-within:border-[#3350A9] bg-white overflow-hidden">
                    <textarea id="editNeuropsychInput" rows="5" maxlength="2000" placeholder="Descripción del perfil neuropsicológico..."
                        class="w-full pl-4 pt-3 pr-4 text-sm bg-transparent border-none outline-none focus:outline-none focus:border-none focus:ring-0 resize-none block"></textarea>
                    <div class="bg-white pb-2 pr-3 pt-1 flex justify-end select-none pointer-events-none">
                        <span id="charNeuroProfile" class="text-xs text-gray-400">0/2000</span>
                    </div>
                </div>
            </div>

            <p class="text-xs text-gray-400">Deja los campos vacíos para borrar su contenido.</p>
            <p id="editContractError" class="text-sm text-red-500 hidden"></p>
        </div>

        <div class="flex flex-col-reverse sm:flex-row gap-3 justify-end mt-6">
            <button class="btn-cancel" id="cancelEditContract">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m9.75 9.75 4.5 4.5m0-4.5-4.5 4.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                </svg>
                <span class="whitespace-nowrap">Cancelar</span>
            </button>
            <button class="btn-save" id="confirmEditContract">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24">
                    <path fill="none" stroke="currentColor" stroke-width="1.5" d="M15.5 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8.5L15.5 3zM15 4v5H6V4m6 14a3 3 0 1 1 0-6a3 3 0 0 1 0 6z"/>
                </svg>
                <span class="whitespace-nowrap">Guardar</span>
            </button>
        </div>
    </div>
</div>

<script>
(function () {
    const btnOpenContract = document.getElementById('btnEditContract');
    const btnOpenProfile = document.getElementById('btnEditProfile');     
    const modal = document.getElementById('editContractModal');
    const btnClose = document.getElementById('closeEditContract');
    const btnCancel = document.getElementById('cancelEditContract');
    const btnConfirm = document.getElementById('confirmEditContract');
    const errorBox = document.getElementById('editContractError');
    const inputLink = document.getElementById('editContractLinkInput');
    const inputProfile = document.getElementById('editNeuropsychInput');

    const data = window.__INTERVENTION_DATA__ || {};
    const idUser = data.idUser;

    function showError(msg) { errorBox.textContent = msg; errorBox.classList.remove('hidden'); }
    function hideError()    { errorBox.classList.add('hidden'); errorBox.textContent = ''; }

    setupCounter('editContractLinkInput', 'charContractLink');
    setupCounter('editNeuropsychInput', 'charNeuroProfile');

    function openModal() {
        hideError();
        inputLink.value = data.contractLink || '';
        inputProfile.value = data.neuroProfile || '';
        inputLink.dispatchEvent(new Event('input'));
        inputProfile.dispatchEvent(new Event('input'));
        modal.classList.remove('hidden');
    }

    function setupCounter(inputId, counterId) {
        const input = document.getElementById(inputId);
        const counter = document.getElementById(counterId);
        if (!input || !counter) return;
        const max = input.getAttribute('maxlength');
        input.addEventListener('input', () => {
            counter.textContent = `${input.value.length}/${max}`;
        });
    }


    btnOpenContract?.addEventListener('click', openModal);
    btnOpenProfile?.addEventListener('click', openModal);

    const close = () => modal.classList.add('hidden');
    btnClose?.addEventListener('click', close);
    btnCancel?.addEventListener('click', close);

    btnConfirm?.addEventListener('click', async () => {
        hideError();
        const link = inputLink.value.trim();
        const profile = inputProfile.value.trim();

        const original = btnConfirm.innerHTML;
        try {
            btnConfirm.disabled = true;
            btnConfirm.innerHTML = '<span>Guardando...</span>';

            const res = await fetch(`/users/${idUser}/intervention`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json','x-csrf-token': _csrfToken,  },
                credentials: 'include',
                body: JSON.stringify({
                    contract_link: link || null,
                    neuro_profile: profile || null,
                }),
            });
            const json = await res.json();
            if (!res.ok) throw new Error(json.error || 'Error al guardar');

            showToast('Datos guardados', 'success');
            setTimeout(() => window.location.reload(), 1200);
        } catch (err) {
            showError(err.message);
            btnConfirm.disabled = false;
            btnConfirm.innerHTML = original;
        }
    });
})();
</script>