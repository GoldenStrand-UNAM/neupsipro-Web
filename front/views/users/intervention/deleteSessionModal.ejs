<div id="deleteSessionModal" class="fixed inset-0 z-50 flex items-center justify-center hidden">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
    <div class="relative bg-white rounded-2xl p-4 sm:p-6 md:p-8 max-w-xl w-full mx-4 max-h-[90vh] overflow-y-auto shadow-2xl">

        <div class="mx-auto flex h-16 w-16 sm:h-20 sm:w-20 flex items-center justify-center rounded-full border-4 border-red-100 mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10 text-red-600">
                <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
            </svg>
        </div>

        <h2 class="text-xl sm:text-2xl font-bold text-gray-900 mb-2">Eliminar sesión</h2>
        <p class="text-gray-600 mb-2 px-4">
            ¿Estás seguro de eliminar la última sesión registrada? Esta acción no se puede deshacer.
        </p>

        <p id="deleteSessionError" class="text-sm text-red-500 mb-4 hidden"></p>

        <div class="flex flex-col-reverse sm:flex-row gap-4 justify-end mt-6">
            <button id="cancelDeleteSession" class="flex-1 flex items-center justify-center gap-3 px-4 py-3 border border-gray-300 rounded-2xl font-semibold text-gray-700 hover:bg-gray-50 cursor-pointer">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="black-icon" >
                    <path stroke-linecap="round" stroke-linejoin="round" d="m9.75 9.75 4.5 4.5m0-4.5-4.5 4.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                </svg>
                <span>Cancelar</span>
            </button>
            <button id="confirmDeleteSession" class="flex-1 flex items-center justify-center gap-3 px-4 py-3 bg-red-600 hover:bg-red-700 rounded-2xl font-semibold text-white cursor-pointer disabled:opacity-60">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="white-icon">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                </svg>
                <span>Eliminar</span>
            </button>
        </div>
    </div>
</div>

<script>
(function () {
    const modal = document.getElementById('deleteSessionModal');
    const btnCancel = document.getElementById('cancelDeleteSession');
    const btnConfirm = document.getElementById('confirmDeleteSession');
    const errorBox = document.getElementById('deleteSessionError');

    const idUser = (window.__INTERVENTION_DATA__ || {}).idUser;
    let pendingSessionId = null;

    function showError(msg) { errorBox.textContent = msg; errorBox.classList.remove('hidden'); }
    function hideError() { errorBox.classList.add('hidden'); errorBox.textContent = ''; }

    document.querySelectorAll('.btn-delete-session').forEach(btn => {
        btn.addEventListener('click', () => {
            pendingSessionId = btn.dataset.sessionId;
            hideError();
            modal.classList.remove('hidden');
        });
    });

    btnCancel?.addEventListener('click', () => {
        modal.classList.add('hidden');
        pendingSessionId = null;
    });

    btnConfirm?.addEventListener('click', async () => {
        if (!pendingSessionId) return;

        const original = btnConfirm.innerHTML;
        try {
            btnConfirm.disabled = true;
            btnConfirm.innerHTML = '<span>Eliminando...</span>';

            const res = await fetch(`/users/${idUser}/intervention/sessions/${pendingSessionId}`, {
                method: 'DELETE',
                credentials: 'include',
                 headers: {'x-csrf-token': _csrfToken,},
            });
            const json = await res.json();
            if (!res.ok) throw new Error(json.error || 'Error al eliminar');

            showToast('Sesión eliminada', 'success');
            setTimeout(() => window.location.reload(), 1200);
        } catch (err) {
            showError(err.message);
            btnConfirm.disabled = false;
            btnConfirm.innerHTML = original;
        }
    });
})();
</script>