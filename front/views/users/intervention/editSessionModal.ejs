<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

<div id="editSessionModal" class="fixed inset-0 z-50 flex items-center justify-center hidden">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
    <div class="relative bg-white rounded-2xl p-4 sm:p-6 md:p-8 max-w-xl w-full mx-4 max-h-[90vh] overflow-y-auto shadow-2xl">

        <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-semibold text-gray-900">Editar sesión</h2>
            <div class="flex items-center gap-3">
                <button type="button" id="resetEditSession" title="Restablecer cambios"
                    class="text-gray-400 hover:text-[#3350A9] transition-colors cursor-pointer">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992V4.356M2.985 19.644v-4.992h4.992m0 0-3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
                    </svg>
                </button>
                <button id="closeEditSession" class="text-gray-400 hover:text-gray-700 cursor-pointer">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
        </div>

        <div class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2" for="editSessionDateInput">Fecha</label>
                    <div class="search-input">
                        <input id="editSessionDateInput" type="text" placeholder="Selecciona fecha" class="search-input_field"/>
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2" for="editSessionNumberInput">
                        Sesión
                    </label>
                    <div class="search-input relative flex items-center">
                        <input id="editSessionNumberInput" type="text" inputmode="numeric" maxlength="20"
                            placeholder="Numero de sesión" class="search-input_field pr-14"/>
                        <span id="charEditSessionNumber" class="absolute right-3 text-xs text-gray-500 pointer-events-none">0/20</span>
                    </div>
                    <span id="editSessionNumberError" class="text-xs text-red-500 hidden mt-1 block"></span>
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2" for="editSessionObjectivesInput">
                    Objetivos
                </label>
                <div class="w-full border border-gray-300 rounded-lg focus-within:ring-2 focus-within:ring-[#3350A9] focus-within:border-[#3350A9] bg-white overflow-hidden">
                    <textarea id="editSessionObjectivesInput" rows="2" maxlength="2000" placeholder="Objetivos de la sesión..."
                        class="w-full pl-4 pt-3 pr-4 text-sm bg-transparent border-none outline-none focus:outline-none focus:border-none focus:ring-0 resize-none block"></textarea>
                    <div class="bg-white pb-2 pr-3 pt-1 flex justify-end select-none pointer-events-none">
                        <span id="charEditSessionObjectives" class="text-xs text-gray-400">0/2000</span>
                    </div>
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2" for="editSessionDevelopmentInput">
                    Desarrollo
                </label>
                <div class="w-full border border-gray-300 rounded-lg focus-within:ring-2 focus-within:ring-[#3350A9] focus-within:border-[#3350A9] bg-white overflow-hidden">
                    <textarea id="editSessionDevelopmentInput" rows="3" maxlength="2000" placeholder="Desarrollo de la sesión..."
                        class="w-full pl-4 pt-3 pr-4 text-sm bg-transparent border-none outline-none focus:outline-none focus:border-none focus:ring-0 resize-none block"></textarea>
                    <div class="bg-white pb-2 pr-3 pt-1 flex justify-end select-none pointer-events-none">
                        <span id="charEditSessionDevelopment" class="text-xs text-gray-400 block text-right mt-1">0/2000</span>
                    </div>
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2" for="editSessionDqpInput">
                    DQP / Tarea terapéutica
                </label>
                <div class="w-full border border-gray-300 rounded-lg focus-within:ring-2 focus-within:ring-[#3350A9] focus-within:border-[#3350A9] bg-white overflow-hidden">
                    <textarea id="editSessionDqpInput" rows="2" maxlength="2000" placeholder="Tarea terapéutica o DQP..."
                       class="w-full pl-4 pt-3 pr-4 text-sm bg-transparent border-none outline-none focus:outline-none focus:border-none focus:ring-0 resize-none block"></textarea>
                    <div class="bg-white pb-2 pr-3 pt-1 flex justify-end select-none pointer-events-none">
                        <span id="charEditSessionDqp" class="text-xs text-gray-400 block text-right mt-1">0/2000</span>
                    </div>
                </div>
            </div>

            <p id="editSessionError" class="text-sm text-red-500 hidden"></p>
        </div>
        <!--Buttons-->
        <div class="flex flex-col-reverse sm:flex-row gap-3 mt-6">
            <button class="btn-cancel flex-1" id="cancelEditSession">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m9.75 9.75 4.5 4.5m0-4.5-4.5 4.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                </svg>
                <span class="whitespace-nowrap">Cancelar</span>
            </button>
            <button id="confirmEditSession" class="btn-add flex-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24">
                    <path fill="none" stroke="currentColor" stroke-width="1.5" d="M15.5 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8.5L15.5 3zM15 4v5H6V4m6 14a3 3 0 1 1 0-6a3 3 0 0 1 0 6z"/>
                </svg>
                <span class="whitespace-nowrap">Guardar</span>
            </button>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/es.js"></script>

<script>
(function () {
    const modal = document.getElementById('editSessionModal');
    const btnClose = document.getElementById('closeEditSession');
    const btnCancel = document.getElementById('cancelEditSession');
    const btnConfirm = document.getElementById('confirmEditSession');
    const btnReset = document.getElementById('resetEditSession');
    const errorBox = document.getElementById('editSessionError');

    const inputDate = document.getElementById('editSessionDateInput');
    const inputNumber = document.getElementById('editSessionNumberInput');
    const inputObj = document.getElementById('editSessionObjectivesInput');
    const inputDev = document.getElementById('editSessionDevelopmentInput');
    const inputDqp = document.getElementById('editSessionDqpInput');
    const numberError = document.getElementById('editSessionNumberError');

    const idUser = (window.__INTERVENTION_DATA__ || {}).idUser;

    let picker = null;
    let currentSessionId = null;
    let originalValues = { date: '', number: '', objectives: '', development: '', dqp: '' };

    inputNumber.addEventListener('input', () => {
        const limpio = inputNumber.value.replace(/\D/g, '');
        if (limpio !== inputNumber.value) {
            numberError.textContent = 'Solo se permiten números';
            numberError.classList.remove('hidden');
            inputNumber.value = limpio;
        } else {
            numberError.classList.add('hidden');
        }
    });

    function showError(msg) { errorBox.textContent = msg; errorBox.classList.remove('hidden'); }
    function hideError()    { errorBox.classList.add('hidden'); errorBox.textContent = ''; }

    function initPicker() {
        if (picker) return;
        picker = flatpickr(inputDate, {
            dateFormat: "Y-m-d",
            maxDate: "2100-12-31",
            locale: "es",
            appendTo: document.querySelector('#editSessionModal .relative'),
            static: true,
            disableMobile: true,
        });
    }

    function setupCounter(inputId, counterId) {
        const input = document.getElementById(inputId);
        const counter = document.getElementById(counterId);
        if (!input || !counter) return;
        const max = input.getAttribute('maxlength');
        input.addEventListener('input', () => {
            counter.textContent = `${input.value.length}/${max}`;
        });
    }

    setupCounter('editSessionNumberInput', 'charEditSessionNumber');
    setupCounter('editSessionObjectivesInput', 'charEditSessionObjectives');
    setupCounter('editSessionDevelopmentInput', 'charEditSessionDevelopment');
    setupCounter('editSessionDqpInput', 'charEditSessionDqp');

    function applyValues(v) {
        inputNumber.value = v.number || '';
        inputObj.value    = v.objectives || '';
        inputDev.value    = v.development || '';
        inputDqp.value    = v.dqp || '';
        if (picker) picker.setDate(v.date || '', true); else inputDate.value = v.date || '';
        [inputNumber, inputObj, inputDev, inputDqp].forEach(el => el.dispatchEvent(new Event('input')));
    }

    const close = () => {
        modal.classList.add('hidden');
        currentSessionId = null;
        hideError();
    };
    btnClose?.addEventListener('click', close);
    btnCancel?.addEventListener('click', close);

    btnReset?.addEventListener('click', () => {
        hideError();
        applyValues(originalValues);
    });


    window.openEditSession = ({ sessionId, date, number, development, objectives, dqp }) => {
        hideError();
        initPicker();
        currentSessionId = sessionId;

        const [dd, mm, yyyy] = (date || '').split('/');
        const isoDate = (dd && mm && yyyy)
            ? `${yyyy}-${mm.padStart(2, '0')}-${dd.padStart(2, '0')}`
            : '';

        originalValues = {
            date: isoDate,
            number: number || '',
            objectives: objectives || '',
            development: development || '',
            dqp: dqp || '',
        };

        applyValues(originalValues);
        modal.classList.remove('hidden');
    };

    btnConfirm?.addEventListener('click', async () => {
        hideError();
        const sessionDate = inputDate.value;
        const sessionNumber = inputNumber.value.trim();
        const objectives = inputObj.value.trim();
        const development = inputDev.value.trim();
        const dqpTask = inputDqp.value.trim();

        if (!sessionDate) return showError('Selecciona la fecha de la sesión');
        if (!currentSessionId) return showError('No se pudo identificar la sesión');

        const original = btnConfirm.innerHTML;
        try {
            btnConfirm.disabled = true;
            btnConfirm.innerHTML = '<span>Guardando...</span>';

            // patch to api json with fetch
            const res = await fetch(`/users/${idUser}/intervention/sessions/${currentSessionId}`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json', 'x-csrf-token': _csrfToken, },
                credentials: 'include',
                body: JSON.stringify({
                    session_number: sessionNumber || null,
                    session_date: sessionDate,
                    objectives: objectives || null,
                    development: development || null,
                    dqp_task: dqpTask || null,
                }),
            });
            const json = await res.json();
            if (!res.ok) throw new Error(json.error || 'Error al actualizar sesión');

            showToast('Sesión actualizada con éxito', 'success');
            setTimeout(() => window.location.reload(), 1200);
        } catch (err) {
            showError(err.message);
            btnConfirm.disabled = false;
            btnConfirm.innerHTML = original;
        }
    });
})();
</script>
