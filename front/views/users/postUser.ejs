<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Registrar Usuario - Golondrina</title>
  <link rel="stylesheet" href="/css/output.css" />
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.css"/>
</head>
<body data-module="<%= tutorialModule %>" class="bg-[#0A2472] flex h-screen lg:flex-row ...">
  <script src="/js/main.js"></script>

  <div id="overlay" class="fixed inset-0 bg-black/40 hidden md:hidden"></div>

  <%- include('../partials/sidebar') %>

  <div class="flex-1 flex flex-col overflow-hidden">

    <%- include('../partials/header') %>

    <main class="flex-1 px-3 sm:px-6 pt-4 sm:pt-6 pb-0 md:pl-0 overflow-auto">
      <div class="w-full h-full bg-white rounded-tl-3xl rounded-tr-3xl px-6 pt-6 pb-0 flex flex-col gap-4 overflow-auto">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
          <div class="flex items-center gap-3">
            <a href="/users">
              <button class="cursor-pointer pb">
                <svg class="black-icon shrink-0 size-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 9-3 3m0 0 3 3m-3-3h7.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                </svg>
              </button>
            </a>
            <h1 class="text-2xl font-bold text-[#1E1E1E]">Registrar Usuario</h1>
          </div>
          <div class="flex items-center gap-3">
            <button onclick="resetFormBtn()" id="btnClear" class="btn-clear">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
              <span>Limpiar</span>
            </button>
          </div>
        </div>
        <div> 
          <img src="/assets/Linear-determinate progress indicator.svg"  alt="Progress indicator" class="w-full">         
        </div>

        <form id="formUser" class="px-6 pt-6 pb-0 flex flex-col gap-4">
          <div class="flex flex-col sm:flex-row sm:items-center gap-4 w-full">      
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Nombre(s) <span style="color: #FF0404">*</span>
            </label>
            <div class="inputs w-full relative flex items-center">
              <input
                required
                class="input-base w-full sm:flex-1 border p-2 pr-12 rounded"
                type="text"
                name="firstName"
                id="firstName"
                placeholder="Juan Carlos"
                maxlength="30"
              >
              <span id="charactersNames" class="absolute right-3 text-xs text-gray-500 pointer-events-none"> 
                0/30 
              </span>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row sm:items-center gap-4 w-full">      
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Apellido paterno <span style="color: #FF0404">*</span>
            </label>
            <div class="inputs w-full relative flex items-center">
              <input
                required
                class="input-base w-full sm:flex-1 border p-2 pr-12 rounded"
                type="text"
                name="lastnameP"
                id="lastnameP"
                placeholder="Hernández"
                maxlength="30"
              >
              <span id="charactersLastnameP" class="absolute right-3 text-xs text-gray-500 pointer-events-none"> 
                0/30 
              </span>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row sm:items-center gap-4 w-full">       
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Apellido materno
            </label>
            <div class="inputs w-full relative flex items-center">
              <input
                class="input-base w-full sm:flex-1 border p-2 pr-12 rounded"
                type="text"
                name="lastnameM"
                id="lastnameM"
                placeholder="Camacho"
                maxlength="30"
              >
              <span id="charactersLastnameM" class="absolute right-3 text-xs text-gray-500 pointer-events-none"> 
                0/30 
              </span>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row sm:items-center gap-4 w-full">
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Fecha de nacimiento <span style="color: #FF0404">*</span>
            </label>
            <div class="relative w-full sm:flex-1 flex items-center">
              <input 
                required
                type="text" 
                id="birthdate" 
                name="birthdate"
                placeholder="DD/MM/AAAA"
                class="datetime-local input-base w-full border p-2 pr-10 rounded outline-none focus:ring-2 focus:ring-blue-500 bg-white"
              >
              <div class="absolute right-3 pointer-events-none text-gray-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
            </div>
          </div>

          <div class="mb-8 flex flex-col sm:flex-row sm:items-center gap-4 w-full">
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Sexo <span style="color: #FF0404">*</span>
            </label>
            <div class="inputs w-full relative flex items-center">
              <select
                required
                class="input-base w-full sm:flex-1 border p-2 pr-12 rounded text-gray-400"
                name="sex"
                id="sex"
              >
                <option disabled selected hidden value="">Elige una opción</option>
                <option value="Masculino" class="text-black">Masculino</option>
                <option value="Femenino" class="text-black">Femenino</option>
                <option value="Sin especificar" class="text-black">Sin especificar</option>
              </select>
            </div>
          </div>
          <div class="flex flex-col sm:flex-row sm:items-center gap-4 w-full">       
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Teléfono
            </label>
            <div class="inputs w-full relative flex items-center">
              <input
                class="input-base w-full sm:flex-1 border p-2 pr-12 rounded"
                type="text"
                name="phone"
                id="phone"
                placeholder="5574048122"
                maxlength="16"
              >
              <span id="charactersPhone" class="absolute right-3 text-xs text-gray-500 pointer-events-none"> 
                0/16 
              </span>
            </div>
          </div>
          <div class="flex flex-col sm:flex-row sm:items-center gap-4 w-full">       
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Correo electrónico
            </label>
            <div class="inputs w-full relative flex items-center">
              <input
                class="input-base w-full sm:flex-1 border p-2 pr-12 rounded"
                type="text"
                name="email"
                id="email"
                placeholder="jorge.v@gmail.com"
                maxlength="50"
              >
              <span id="charactersEmail" class="absolute right-3 text-xs text-gray-500 pointer-events-none"> 
                0/50 
              </span>
            </div>
          </div>

          <div class="mt-8 flex flex-col sm:flex-row sm:items-start gap-4 w-full">
            
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0 mt-2">
              Folio <span style="color: #FF0404">*</span>
            </label>
            
            <div class="flex flex-col w-full">
              
              <div class="inputs w-full relative flex items-center">
                <input
                  required
                  class="input-base w-full sm:flex-1 border p-2 pr-12 rounded"
                  type="text"
                  name="referenceNumber"
                  id="referenceNumber"
                  placeholder="000X - XXX"
                  maxlength="10"                >
                <span id="charactersReferenceNumber" class="absolute right-3 text-xs text-gray-500 pointer-events-none"> 
                  0/10 
                </span>
              </div>
              <small class="text-xs text-gray-500 mt-1 ml-1">
                El folio comienza con 3 números, seguidos de la letra P, un guión y las iniciales del usuario
              </small>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row sm:items-center gap-4 w-full">
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Modalidad <span style="color: #FF0404">*</span>
            </label>
            <div class="inputs w-full relative flex items-center">
              <select
                required
                class="input-base w-full sm:flex-1 border p-2 pr-12 rounded text-gray-400"
                name="modality"
                id="modality"
              >
                <option disabled selected hidden value="">Elige una opción</option>
                <option value="Presencial" class="text-black">Presencial</option>
                <option value="En línea" class="text-black">En línea</option>
              </select>
            </div>
          </div>
          <div class="flex flex-col sm:flex-row sm:items-center gap-4 w-full">
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Ingreso a neuropsicología 
            </label>
            <div class="relative w-full sm:flex-1 flex items-center">
              <input 
                type="text" 
                id="neuroEntryDate" 
                name="neuroEntryDate"
                placeholder="DD/MM/AAAA"
                class="input-base w-full border p-2 pr-10 rounded outline-none focus:ring-2 focus:ring-blue-500 bg-white"
              >
              <div class="absolute right-3 pointer-events-none text-gray-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
            </div>
          </div>

          <div class="mb-8 flex flex-col sm:flex-row sm:items-center gap-4 w-full">
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Pares <span style="color: #FF0404">*</span>
            </label>
            <div class="inputs w-full relative flex items-center">
              <select
                required
                class="input-base w-full sm:flex-1 border p-2 pr-12 rounded text-gray-400"
                name="pairs"
                id="pairs"
              >
                <option disabled selected hidden value="">Elige una opción</option>
                <option value="Sí asiste" class="text-black">Sí</option>
                <option value="No asiste" class="text-black">No</option>
              </select>
            </div>
          </div>

          <div class="mt-8 flex flex-col sm:flex-row sm:items-center gap-4 w-full">
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Fecha de amputación <span style="color: #FF0404">*</span>
            </label>
            <div class="relative w-full sm:flex-1 flex items-center">
              <input 
                required
                type="text" 
                id="amputationDate" 
                name="amputationDate"
                placeholder="DD/MM/AAAA"
                class="input-base w-full border p-2 pr-10 rounded outline-none focus:ring-2 focus:ring-blue-500 bg-white"
              >
              <div class="absolute right-3 pointer-events-none text-gray-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row sm:items-center gap-4 w-full">
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Etiología de amputación <span style="color: #FF0404">*</span>
            </label>
            <div class="inputs w-full relative flex items-center">
              <select
                required
                class="input-base w-full sm:flex-1 border p-2 pr-12 rounded text-gray-400"
                name="basePathology"
                id="basePathology"
              >
                <option disabled selected hidden value="">Elige una opción</option>
                <option value="Diabetes Mellitus 1" class="text-black">Diabetes Mellitus 1</option>
                <option value="Diabetes Mellitus 2" class="text-black">Diabetes Mellitus 2</option>
                <option value="Congénito" class="text-black">Congénito</option>
                <option value="Cáncer" class="text-black">Cáncer</option>
                <option value="Osteomielitis" class="text-black">Osteomielitis</option>
                <option value="Traumática" class="text-black">Traumática</option>
                <option value="other" class="text-black">Otro</option>
              </select>
            </div>
          </div>

          <div id="pathologyDiv" class="flex flex-col sm:flex-row sm:items-center gap-4 w-full hidden">
            <label class="sm:w-1/4 font-small sm:text-right shrink-0" style="color: #FF0404">*</label>
            <div class="inputs w-full relative flex items-center">
              <input type="text" id="otherPathology" name="otherPathology" 
                placeholder="Escribe la etiología"
                maxlength = "50"
                class="input w-full border py-1 px-3 pr-10 mb-2 rounded outline-none focus:ring-2 focus:ring-blue-500 bg-white "/>
                <span id="charactersOtherPathology" class="absolute right-3 text-xs text-gray-500 pointer-events-none"> 
                0/50 
              </span>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row sm:items-center gap-4 w-full">
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Nivel de amputación <span style="color: #FF0404">*</span>
            </label>
            <div class="inputs w-full relative flex items-center">
              <select
                required
                class="input-base w-full sm:flex-1 border p-2 pr-12 rounded text-gray-400"
                name="amputationLevel"
                id="amputationLevel"
              >
                <option disabled selected hidden value="">Elige una opción</option>
                <option value="Sin amputación" class="text-black">Sin amputación</option>
                <option value="Debajo de la rodilla" class="text-black">Debajo de la rodilla</option>
                <option value="Encima de la rodilla" class="text-black">Encima de la rodilla</option>
                <option value="Debajo de la rodilla bilateral" class="text-black">Debajo de la rodilla bilateral</option>
                <option value="Encima de la rodilla bilateral" class="text-black">Encima de la rodilla bilateral</option>
                <option value="Encima + debajo de la rodilla" class="text-black">Encima + debajo de la rodilla</option>
                <option value="Pie" class="text-black">Pie</option>
                <option value="Ambos pies" class="text-black">Ambos pies</option>
                <option value="Mano" class="text-black">Mano</option>
                <option value="Ambas manos" class="text-black">Ambas manos</option>
                <option value="Antebrazo + mano" class="text-black">Antebrazo + mano</option>
                <option value="Ambos antebrazos + manos" class="text-black">Ambos antebrazos + manos</option>
                <option value="Brazo completo" class="text-black">Brazo completo</option>
                <option value="Ambos brazos completos" class="text-black">Ambos brazos completos</option>
                <option value="Pierna completa" class="text-black">Pierna completa</option>
                <option value="Ambas piernas completas" class="text-black">Ambas piernas completas</option>
              </select>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row sm:items-center gap-4 w-full">
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Lateralidad <span style="color: #FF0404">*</span>
            </label>
            <div class="inputs w-full relative flex items-center">
              <select
                required
                class="input-base w-full sm:flex-1 border p-2 pr-12 rounded text-gray-400"
                name="laterality"
                id="laterality"
              >
                <option disabled selected hidden value="">Elige una opción</option>
                <option value="Zurda" class="text-black">Zurda</option>
                <option value="Diestra" class="text-black">Diestra</option>
                <option value="Ambidiestra" class="text-black">Ambidiestra</option>
              </select>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row sm:items-center gap-4 w-full">
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Protesista <span style="color: #FF0404">*</span>
            </label>
            <div class="inputs w-full relative flex items-center">
              <select
                required
                class="input-base w-full sm:flex-1 border p-2 pr-12 rounded text-gray-400"
                name="prosthetist"
                id="prosthetist"
              >
                <option disabled selected hidden value="">Elige una opción</option>
                <option value="CPO Alejandra Santos" class="text-black">CPO Alejandra Santos</option>
                <option value="CPO Juan David Orozco" class="text-black">CPO Juan David Orozco</option>
                <option value="CPO Melvin Arévalo" class="text-black">CPO Melvin Arévalo</option>
              </select>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row sm:items-center gap-4 w-full">
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Fase de rehabilitación <span style="color: #FF0404">*</span>
            </label>
            <div class="inputs w-full relative flex items-center">
              <select
                required
                class="input-base w-full sm:flex-1 border p-2 pr-12 rounded text-gray-400"
                name="phase"
                id="phase"
              >
                <option disabled selected hidden value="">Elige una opción</option>
                <option value="Preprotésico" class="text-black">Preprotésico</option>
                <option value="Protésico" class="text-black">Protésico</option>
                <option value="Postprotésico" class="text-black">Postprotésico</option>
                <option value="Adaptación al ejercicio" class="text-black">Adaptación al ejercicio</option>
                <option value="Alta" class="text-black">Alta</option>
                <option value="Baja de neuropsicología" class="text-black">Baja de neuropsicología</option>
              </select>
            </div>
          </div>

          <div class="mb-8 flex flex-col sm:flex-row sm:items-center gap-4 w-full">
            <label class="sm:w-1/4 font-medium sm:text-right shrink-0">
              Colaborador asignado <span style="color: #FF0404">*</span>
            </label>
            <div class="inputs w-full relative flex items-center">
              <select
                required
                class="input-base w-full sm:flex-1 border p-2 pr-12 rounded text-gray-400"
                name="assigned"
                id="assigned"
              >
                <option disabled selected hidden value="">Elige una opción</option>
              </select>
            </div>
          </div>

          <div class="file-upload mt-2 mb-8 flex flex-col sm:flex-row sm:items-center gap-4 w-full">
            <label class="file-upload-label sm:w-1/4 sm:text-right shrink-0 text-black text-base">
              Foto de perfil
            </label>
            <div class="file-upload-dropzone" id="dropzone">
              <div id="filePreview" class="hidden flex flex-col items-center gap-2">
                <img id="previewImg" src="" class="w-16 h-16 object-cover rounded-md border">
                <span id="previewName" class="text-[10px] text-gray-600 text-center break-all"></span>
              </div>
              <div id="emptyState" class="flex flex-col items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="file-upload-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                    d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <span class="file-upload-text">Haz clic o arrastra una imagen aquí</span>
              </div>
              <input type="file" name="profilePhoto" accept="image/jpeg,image/png,image/webp" class="file-upload-input" id="fileInput">
            </div>
          </div>
          <div class="mb-8 hidden md:flex md:justify-end pt-2 pb-4">
            <button id="btnSave" class="btn-mini bg-[#3350A9]">
              <div id="saveIcon">
                <svg class="white-icon-mini" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 3.75V16.5L12 14.25 7.5 16.5V3.75m9 0H18A2.25 2.25 0 0 1 20.25 6v12A2.25 2.25 0 0 1 18 20.25H6A2.25 2.25 0 0 1 3.75 18V6A2.25 2.25 0 0 1 6 3.75h1.5m9 0h-9" />
              </svg>
              </div>
              <span>Guardar</span>
            </button>
          </div>
        </form>
      </div>
    </main>
  </div>

  <button type="submit" form="formUser" class="md:hidden fixed bottom-6 right-6 z-30 btn-mini bg-[#3350A9] shadow-xl" style="padding: 0.875rem 1.5rem; height: auto; font-size: 1rem;">
    <svg class="w-5 h-5 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 3.75V16.5L12 14.25 7.5 16.5V3.75m9 0H18A2.25 2.25 0 0 1 20.25 6v12A2.25 2.25 0 0 1 18 20.25H6A2.25 2.25 0 0 1 3.75 18V6A2.25 2.25 0 0 1 6 3.75h1.5m9 0h-9" />
    </svg>
    Guardar
  </button>

  <script src="/js/sidebar.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.js.iife.js"></script>
  <script>
    const tutorialElements = {
      1: null,         
      2: '#firstName', 
      3: '#dropzone',  
      4: '#btnClear',  
      5: '#btnSave',  
    };
  </script>
  <script src="/js/tutorial.js"></script>
  <script>
    window.__CSRF_TOKEN__ = "<%= csrfToken %>";
  </script>
  </body>

  <script>
    const form = document.getElementById('formUser');
    const dropzone = document.querySelector('.file-upload-dropzone');
    const fileInput = document.querySelector('.file-upload-input');
    const filePreview = document.getElementById('filePreview');
    const emptyState  = document.getElementById('emptyState');
    const previewImg  = document.getElementById('previewImg');
    const previewName = document.getElementById('previewName');
    const basePathology = document.getElementById('basePathology');
    const btnSave = document.getElementById('btnSave');
    const saveIcon = document.getElementById('saveIcon');
    const referenceNumberInput = document.getElementById('referenceNumber');
    const nameInput = document.getElementById('firstName');
    const lastamePInput = document.getElementById('lastnameP');
    const lastameMInput = document.getElementById('lastnameM');
    const birthdateInput = document.getElementById('birthdate');

    function escapeHTML(text) {
      return text
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");
    }

    function resetFormBtn(){
      if (form) form.reset();

      document.querySelectorAll('input[maxlength]').forEach(input => {
        input.dispatchEvent(new Event('input'));
      });

      const selects = document.querySelectorAll('select');
      selects.forEach(select => {
        select.classList.remove('text-black');
        select.classList.add('text-gray-400');
      });
      filePreview.classList.add('hidden');
      emptyState.classList.remove('hidden');
      previewImg.src = '';
      showToast('Formulario limpiado');
    }

    function checkOther(select, otherSelect, div) {
      const otherInput = document.getElementById(otherSelect);
      const changeDiv = document.getElementById(div);
      if (select.value === 'other') {
          changeDiv.classList.remove('hidden');
          otherInput.required = true;
      } else {
          changeDiv.classList.add('hidden');
          otherInput.required = false;
          otherInput.value = "";
      }
    }

    basePathology.addEventListener('change', () => {
        checkOther(basePathology, 'otherPathology', 'pathologyDiv'); 
    });

    form.addEventListener('submit', async (e) => {
      event.preventDefault();
      const formData = new FormData(form);

      try {
      btnSave.querySelector('span').textContent = 'Cargando...';
      saveIcon.innerHTML = `<svg class="animate-spin h-8 w-8 text-white"
        viewBox="0 0 24 24" fill="none">
        <circle cx="12" cy="12" r="10"
          class="stroke-current opacity-25" stroke-width="3"/>
        <path d="M12 2a10 10 0 0 1 10 10"
          class="stroke-current" stroke-width="3"
          stroke-linecap="round"/>`
      const res = await fetch('/user/post', {
        method: 'POST',
        headers: { 'x-csrf-token': _csrfToken },
        body: formData,
      });

      const data = await res.json();

      if (res.ok) {
        sessionStorage.setItem('userSaved', 'true');
        window.location.href = '/users';
      } else if (res.status === 429) {
          showToast('Has alcanzado el límite de usuarios registrados. Intenta más tarde.', 'error');
          btnSave.querySelector('span').textContent = 'Guardar';
          saveIcon.innerHTML = `<svg class="white-icon-mini" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 3.75V16.5L12 14.25 7.5 16.5V3.75m9 0H18A2.25 2.25 0 0 1 20.25 6v12A2.25 2.25 0 0 1 18 20.25H6A2.25 2.25 0 0 1 3.75 18V6A2.25 2.25 0 0 1 6 3.75h1.5m9 0h-9" />
              </svg>`
      } else {
        showToast((data.error || 'Error desconocido'), 'error');
        if (data.error === 'El usuario ya se encuentra registrado.') {
          lastamePInput.style.border = '2px solid red';
          lastamePInput.style.boxShadow = 'inset 0 0 0 100px #fef2f2';
          lastameMInput.style.border = '2px solid red';
          lastameMInput.style.boxShadow = 'inset 0 0 0 100px #fef2f2';
          birthdateInput.style.border = '2px solid red';
          birthdateInput.style.boxShadow = 'inset 0 0 0 100px #fef2f2';
          nameInput.setCustomValidity("Usuario registrado, cambia un campo");
          nameInput.style.border = '2px solid red';
          nameInput.style.boxShadow = 'inset 0 0 0 100px #fef2f2';
          nameInput.reportValidity();
        } else if (data.error === 'El número de referencia ya pertenece a otro usuario.') {
          referenceNumberInput.setCustomValidity("Usuario registrado, cambia un campo");
          referenceNumberInput.style.border = '2px solid red';
          referenceNumberInput.style.boxShadow = 'inset 0 0 0 100px #fef2f2';
          referenceNumberInput.reportValidity();
        }
        btnSave.querySelector('span').textContent = 'Guardar';
        saveIcon.innerHTML = `<svg class="white-icon-mini" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 3.75V16.5L12 14.25 7.5 16.5V3.75m9 0H18A2.25 2.25 0 0 1 20.25 6v12A2.25 2.25 0 0 1 18 20.25H6A2.25 2.25 0 0 1 3.75 18V6A2.25 2.25 0 0 1 6 3.75h1.5m9 0h-9" />
              </svg>`
      }
      } catch (error) {
      showToast('Error de conexión', 'error');
      btnSave.querySelector('span').textContent = 'Guardar';
      saveIcon.innerHTML = `<svg class="white-icon-mini" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 3.75V16.5L12 14.25 7.5 16.5V3.75m9 0H18A2.25 2.25 0 0 1 20.25 6v12A2.25 2.25 0 0 1 18 20.25H6A2.25 2.25 0 0 1 3.75 18V6A2.25 2.25 0 0 1 6 3.75h1.5m9 0h-9" />
              </svg>`
      }
    });

    const duplicateInputs = [nameInput, lastamePInput, lastameMInput, birthdateInput];

    duplicateInputs.forEach(input => {
      input.addEventListener('input', (e) => {
        nameInput.setCustomValidity("");
        duplicateInputs.forEach(inp => {
          inp.style.border = '';
          inp.style.boxShadow = '';
        });
      });
    });

    referenceNumberInput.addEventListener('input', (e) => {
      referenceNumberInput.setCustomValidity("");
      referenceNumberInput.style.border = '';
      referenceNumberInput.style.boxShadow = '';
    });

    async function fetchUsers() {
      const params = new URLSearchParams({ search: "", page: 1, limit: 100 });
      try {
        const res  = await fetch(`/api/usuarios-clinicos?${params}`);
        const data = await res.json();

        if (!res.ok) {
          console.error("Server error:", data.error);
          showMsg("Ocurrió un error en el sistema. Intenta de nuevo más tarde.", "text-red-400");
          return;
        }

        selectClinicUsers(data.users);
      } catch (err) {
        console.error("Network error:", err);
        showMsg("No se pudo conectar al servidor. Verifica tu conexión.", "text-red-400");
      }
    } 

    function selectClinicUsers(users) {
      const assigned = document.getElementById("assigned");
      if (!users.length) { showMsg("Sin registros", "text-gray-400"); return; }

      const usersHtml = users.map(u => `
          <option value="${escapeHtml(u.id)}" class="text-black">${escapeHtml(u.fullName)}</option>
      `).join("");

      assigned.insertAdjacentHTML('beforeend', usersHtml);
    }

    const phoneInput = document.getElementById('phone');

    const allowedCharRegex = /^[0-9+()-]$/;
    const allowedStringRegex = /^[0-9+()-]+$/;

    phoneInput.addEventListener('keydown', (e) => {
      if (e.key.length !== 1 || e.ctrlKey || e.metaKey || e.altKey) return;

      const isValidKey = allowedCharRegex.test(e.key);

      if (!isValidKey) {
        e.preventDefault();
        showToast('Solo se permiten números, guiones y paréntesis', 'error');
      }
    });

    phoneInput.addEventListener('paste', (e) => {
      const pasteData = (e.originalEvent || e).clipboardData.getData('text/plain');
      
      const isValidPaste = allowedStringRegex.test(pasteData);
      
      if (!isValidPaste) {
        e.preventDefault();
        showToast('El texto pegado contiene caracteres no permitidos', 'error');
      }
    });

    dropzone.addEventListener('click', () => {
      fileInput.click();
    });

    fileInput.addEventListener('change', () => {
      const file = fileInput.files[0];
      if (!file) return;
      if (file.size > 5 * 1024 * 1024) { // 5mb
        showToast('Imagen demasiado pesada', 'error');
        fileInput.value = '';
        return;
      }
      previewImg.src = URL.createObjectURL(file);
      previewName.textContent = escapeHTML(file.name);
      filePreview.classList.remove('hidden'); 
      emptyState.classList.add('hidden');
    });

    function setupCounter(inputId, counterId) {
      const input = document.getElementById(inputId);
      const counter = document.getElementById(counterId);

      if (!input || !counter) return;

      const max = input.getAttribute('maxlength');

      input.addEventListener('input', () => {
        const longitud = input.value.length;
        counter.textContent = `${longitud}/${max}`;
      });
    }

    function formatRefNumber(id) {
      const input = document.getElementById(id);
      input.addEventListener('input', (e) => {
        let cursorP = input.selectionStart;
        const oldLength = input.value.length;
        let val = input.value.toUpperCase().replace(/[^0-9A-Z-]/g, '');
        let numMatch = val.match(/^[0-8]{0,3}/);
        let numPart = numMatch ? numMatch[0] : '';
        let finalValue = numPart;
        
        if (numPart.length === 3) {
          let restPart = val.substring(3);
          if (restPart.length > 0) {
            let prefijo = '';
            if (restPart.startsWith('NP'))
              prefijo = 'NP';
            else if (restPart.startsWith('P'))
              prefijo = 'P';
            if (prefijo === '') {
              if (restPart.startsWith('N')) {
                prefijo = 'N';
                restPart = ''; 
              } else
                restPart = '';
            } else
              restPart = restPart.replace(/^(NP|P)/, '');
            finalValue += prefijo;
            if (prefijo === 'P' || prefijo === 'NP') {
              const tieneGuionManual = restPart.startsWith('-');
              let letterPart = restPart.replace(/^-/, '').replace(/[^A-Z]/g, '').slice(0, 5);
              if (tieneGuionManual || letterPart.length > 0 || restPart.length > 0)
                finalValue += '-' + letterPart;
            }
          }
        }
        
        input.value = finalValue;
        const newLength = finalValue.length;
        cursorP = cursorP + (newLength - oldLength);
        input.setSelectionRange(cursorP, cursorP);
      });
    }

    function validateDates(id){
      const inputFecha = document.getElementById(id);
      const today = new Date();

      const fp = flatpickr(document.getElementById(id), {
        dateFormat: "d/m/Y",
        allowInput: true,
        maxDate: "today",
        minDate: "01/01/1900",
        disableMobile: true
      });

      inputFecha.addEventListener('input', (e) => {
        let v = e.target.value.replace(/\D/g, '');
        let finalValue = "";
        const actualYear = new Date().getFullYear();

        if (v.length > 0) {
          let day = v.substring(0, 2);
          let month = v.substring(2, 4);
          let year = v.substring(4, 8);

          if (parseInt(day) > 31) day = "31";
          if (parseInt(month) > 12) month = "12";
          if (parseInt(year) > 2026) year = actualYear;
          if (parseInt(year) < 1900 && v.length == 8) year = 1900;

          if (v.length <= 2) finalValue = day;
          else if (v.length <= 4) finalValue = day + "/" + month;
          else finalValue = day + "/" + month + "/" + year;
        }

        e.target.value = finalValue;

      });
    }

    function changeDefaultColor(id) {
      const inputSelect = document.getElementById(id);

      inputSelect.addEventListener('change', function() {
        if (this.value !== "") {
          this.classList.remove('text-gray-400');
          this.classList.add('text-black');
        } else {
          this.classList.remove('text-black');
          this.classList.add('text-gray-400');
        }
      });
    }

    fetchUsers();
    setupCounter('firstName', 'charactersNames');
    setupCounter('lastnameP', 'charactersLastnameP');
    setupCounter('lastnameM', 'charactersLastnameM');
    setupCounter('userName', 'charactersUserName');
    setupCounter('otherPathology', 'charactersOtherPathology');
    setupCounter('referenceNumber', 'charactersReferenceNumber');
    setupCounter('prosthetist', 'charactersProsthetist');
    setupCounter('phone', 'charactersPhone');
    setupCounter('email', 'charactersEmail');
    validateDates('birthdate');
    validateDates('amputationDate');
    validateDates('neuroEntryDate');
    changeDefaultColor('sex');
    changeDefaultColor('modality');
    changeDefaultColor('basePathology');
    changeDefaultColor('amputationLevel');
    changeDefaultColor('laterality');
    changeDefaultColor('prosthetist');
    changeDefaultColor('phase');
    changeDefaultColor('assigned');
    changeDefaultColor('pairs');
    formatRefNumber('referenceNumber');
  </script>
</html>
