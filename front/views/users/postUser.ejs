<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registrar Usuario - NeuPsi-Pro</title>
    <link rel="stylesheet" href="/css/output.css">
</head>
<body class="bg-[#0A2472] flex h-screen lg:flex-row transition-transform duration-300">
    <script src="/js/main.js"></script>

    <div id="overlay" class="fixed inset-0 bg-black/40 hidden md:hidden"></div>

    <%- include('../partials/sidebar') %>

    <div class="flex-1 flex flex-col overflow-hidden">

        <%- include('../partials/header') %>

        <main class="flex-1 px-3 sm:px-6 pt-4 sm:pt-6 pb-0 md:pl-0 overflow-hidden">
            <div class="w-full h-full bg-white rounded-tl-3xl rounded-tr-3xl px-6 pt-6 pb-0 flex flex-col gap-4">

                <div>
                    <h1 class="text-2xl font-bold text-[#1E1E1E]">Registrar Usuario</h1>
                </div>
                <div> 
                    <img src="/assets/Linear-determinate progress indicator.svg"  alt="Progress indicator" class="w-full">         
                </div>
                <div class="flex flex-col md:flex-row md:items-center gap-3">

                <label>
                    Nombre(s)
                </label>

                <div class="w-[30%]">
                    <input type="text" placeholder="Juan Carlos" class="input-base">
                </div>

            </div>
            </div>
        </main>
    </div>

    <script src="/js/sidebar.js"></script>
    </body>
</html>