<div id="cancelAppointmentModal" class="fixed inset-0 z-50 flex items-center justify-center hidden">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
    <div class="relative bg-white rounded-2xl p-8 max-w-md w-full mx-4 shadow-2xl text-center">

        <div class="mx-auto flex items-center justify-center h-20 w-20 rounded-full border-4 border-red-100 mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10 text-red-600">
                <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
            </svg>
        </div>

        <h2 class="text-2xl font-bold text-gray-900 mb-2">Cancelar cita</h2>
        <p class="text-gray-600 mb-2 px-4">
            ¿Estás seguro de cancelar esta cita? Podras agendar una nueva cita posteriormente.
        </p>

        <p id="cancelAppointmentError" class="text-sm text-red-500 mb-4 hidden"></p>

        <div class="flex flex-col sm:flex-row gap-4 mt-6">
            <button id="dismissCancelAppointment" class="flex-1 flex items-center justify-center gap-3 px-4 py-3 border border-gray-300 rounded-2xl font-semibold text-gray-700 hover:bg-gray-50 transition-colors cursor-pointer">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m9.75 9.75 4.5 4.5m0-4.5-4.5 4.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                </svg>
                <span class="whitespace-nowrap">Volver</span>
            </button>
            <button id="confirmCancelAppointment" class="flex-1 flex items-center justify-center gap-3 px-4 py-3 bg-red-600 hover:bg-red-700 rounded-2xl font-semibold text-white transition-colors cursor-pointer disabled:opacity-60 disabled:cursor-not-allowed">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                </svg>
                <span class="whitespace-nowrap">Cancelar Cita</span>
            </button>
        </div>
    </div>
</div>

<script>
(function () {
    const btnOpen     = document.getElementById('btnCancelAppointment');
    const modal       = document.getElementById('cancelAppointmentModal');
    const btnDismiss  = document.getElementById('dismissCancelAppointment');
    const btnConfirm  = document.getElementById('confirmCancelAppointment');
    const errorBox    = document.getElementById('cancelAppointmentError');

    const user   = window.__USER_DATA__ || {};
    const idUser = user.idUser;

    btnOpen?.addEventListener('click', () => {
        errorBox.classList.add('hidden');
        errorBox.textContent = '';
        modal.classList.remove('hidden');
    });

    btnDismiss?.addEventListener('click', () => {
        modal.classList.add('hidden');
    });

    btnConfirm?.addEventListener('click', async () => {
        if (!idUser) {
            errorBox.textContent = 'No se pudo identificar al usuario.';
            errorBox.classList.remove('hidden');
            return;
        }

        const originalHTML = btnConfirm.innerHTML;
        try {
            btnConfirm.disabled = true;
            btnConfirm.innerHTML = '<span>Cancelando...</span>';

            const res = await fetch(`/users/${idUser}/appointments`, {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json', 'x-csrf-token': _csrfToken,  },
                credentials: 'include',
            });

            const data = await res.json();
            if (!res.ok) throw new Error(data.error || 'Error al cancelar la cita');

            showToast('Cita cancelada correctamente', 'success');
            setTimeout(() => window.location.reload(), 1200);
        } catch (err) {
            errorBox.textContent = err.message;
            errorBox.classList.remove('hidden');
            btnConfirm.disabled = false;
            btnConfirm.innerHTML = originalHTML;
        }
    });
})();
</script>