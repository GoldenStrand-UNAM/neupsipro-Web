<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Usuarios - Golondrina</title>
    <link rel="stylesheet" href="/css/output.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.css"/>
</head>
<body data-module="<%= tutorialModule %>"  class="bg-[#0A2472] flex h-screen lg:flex-row transition-transform duration-300">
    <script src="/js/main.js"></script>

    <div id="overlay" class="fixed inset-0 bg-black/40 hidden md:hidden"></div>

    <%- include('../partials/sidebar') %>

    <div class="flex-1 flex flex-col overflow-hidden">

        <%- include('../partials/header') %>

        <main class="flex-1 px-3 sm:px-6 pt-4 sm:pt-6 pb-0 md:pl-0 overflow-hidden">
            <div class="w-full h-full bg-white rounded-tl-3xl rounded-tr-3xl px-6 pt-6 pb-0 flex flex-col gap-4">

                <!--Title, search, signUser-->
                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
                    <h1 class="text-2xl font-bold text-[#1E1E1E]">Usuarios</h1>
                    <div class="flex items-center gap-3">
                        <a id="btnNewUser" href="/user/post">
                        <button
                             class= "btn-mini w-full sm:w-[260px] md:w-[306px] bg-[#C89B3C]">
                            <svg xmlns="http://www.w3.org/2000/svg" class="white-icon-mini" fill="none"
                                viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
                            </svg>
                            <span>Nuevo Usuario</span>
                        </button>
                        </a>

                        <div class="search-input">
                            <input id="search-input"type="text" class="search-input_field" placeholder="Buscar por nombre"/>
                            <svg xmlns="http://www.w3.org/2000/svg" class="search-icon" fill="none"
                                viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M21 21l-4.35-4.35M17 11A6 6 0 105 11a6 6 0 0012 0z"/>
                            </svg>
                        </div>
                    </div>
                </div>
                <div> 
                    <img src="/assets/Linear-determinate progress indicator.svg"  alt="Progress indicator" class="w-full">         
                </div>

                <!-- Table -->
                <div class="flex-1 overflow-auto bg-[#FAFAFA] rounded-xl shadow-sm  px-3 md:px-6">
                <table id="usersTable" class="w-full border-collapse text-sm md:text-base ">
                    <thead>
                        <tr class="border-b-2 border-gray-200 table-fixed">
                            <th class="w-[10%] py-2.5 px-4 text-left font-semibold text-gray-700">Folio</th>
                            <th class="w-[30%] py-2.5 px-4 text-left font-semibold text-gray-700">Nombre</th>
                            <th class="w-[20%] py-2.5 px-4 text-center font-semibold text-gray-700 relative">
                                <div id="statusFilterTrigger" class="flex items-center justify-center gap-2 cursor-pointer hover:bg-gray-200 p-1 rounded transition duration-200 select-none">
                                    <span>Estatus</span>
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-800" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M7 12h10M10 18h4" />
                                    </svg>
                                </div>

                                <div id="statusDropdown" class="hidden absolute top-full left-1/2 transform -translate-x-1/2 mt-2 w-44 bg-white border border-gray-100 shadow-xl rounded-xl z-50 p-3 flex flex-col gap-3 font-normal">
                                    <button class="status-option w-full py-1.5 px-4 rounded-lg text-sm border border-gray-300 bg-gray-50 text-gray-700 hover:bg-gray-100 transition" data-value="">Todos</button>
                                    <button class="status-option w-full py-1.5 px-4 rounded-lg text-sm border border-[#E03232] bg-[#E03232]/30 text-[#E03232] hover:bg-[#E03232]/50 transition" data-value="Discharged">Alta</button>
                                    <button class="status-option w-full py-1.5 px-4 rounded-lg text-sm border border-[#1F893A] bg-[#1F893A]/30 text-[#1F893A] hover:bg-[#1F893A]/50 transition" data-value="Active">Activo</button>
                                    <button class="status-option w-full py-1.5 px-4 rounded-lg text-sm border border-[#1560BD] bg-[#1560BD]/30 text-[#1560BD] hover:bg-[#1560BD]/50 transition" data-value="Stand_by">Stand By</button>
                                    <button class="status-option w-full py-1.5 px-4 rounded-lg text-sm border border-[#276076] bg-[#276076]/30 text-[#276076] hover:bg-[#276076]/50 transition" data-value="Declined">No ingresó</button>
                                </div>
                            </th>                            
                            <th class="w-[20%] py-2.5 px-4 text-center font-semibold text-gray-700 relative">
                                <div id="protocolFilterTrigger" class="flex items-center justify-center gap-2 cursor-pointer hover:bg-gray-200 p-1 rounded transition duration-200 select-none">
                                    <span>Protocolo</span>
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-800" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M7 12h10M10 18h4" />
                                    </svg>
                                </div>

                                <div id="protocolDropdown" class="hidden absolute top-full left-1/2 transform -translate-x-1/2 mt-2 w-44 bg-white border border-gray-100 shadow-xl rounded-xl z-50 p-3 flex flex-col gap-3 font-normal">
                                    <button class="protocol-option w-full py-1.5 px-4 rounded-lg text-sm border border-gray-300 bg-gray-50 text-gray-700 hover:bg-gray-100 transition" data-value="">Todos</button>
                                    <button class="protocol-option w-full py-1.5 px-4 rounded-lg text-sm border border-gray-300 bg-gray-50 text-gray-700 hover:bg-gray-100 transition" data-value="Pending">Sin asignar</button>
                                    <button class="protocol-option w-full py-1.5 px-4 rounded-lg text-sm border border-gray-300 bg-gray-50 text-gray-700 hover:bg-gray-100 transition" data-value="Clinical">Clínico</button>
                                    <button class="protocol-option w-full py-1.5 px-4 rounded-lg text-sm border border-gray-300 bg-gray-50 text-gray-700 hover:bg-gray-100 transition" data-value="Research">Investigación</button>

                                </div>
                            </th>                                 
                            <th class="w-[20%] py-2.5 px-4 text-center font-semibold text-gray-700">Consultar Información</th>
                        </tr>
                    </thead>
                    <tbody id="users-tbody">
                        <tr>
                            <td colspan="5" class="py-10 text-center text-gray-400">Cargando...</td>
                        </tr>
                    </tbody>
                </table>
            </div>

                <div id="pagination" class="flex items-center justify-center gap-3 py-3"></div>

            </div>
        </main>
    </div>

    <script src="/js/sidebar.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.js.iife.js"></script>
    <script src="/js/tutorial.js"></script>
    <script>
        const tutorialElements = {
        1: null,                  // intro
        2: '#btnNewUser',    // btn new user
        3: '#search-input',       // finder
        4: '#usersTable',         // table
        5: '#pagination',         // pagination
        };
    </script>    


<script>
// ===== UTilitys ========

const MAX_SEARCH_LENGTH = 50;

let currentPage   = 1;
const LIMIT       = 6;
let searchQuery   = "";
let statusQuery   = "";
let protocolQuery = "";
let debounceTimer;

if (sessionStorage.getItem('userSaved') === 'true') {
    showToast('Usuario guardado correctamente');
    sessionStorage.removeItem('userSaved');
}

// = ====  Fetch===========
async function fetchUsers() {
    const params = new URLSearchParams({ search: searchQuery, status: statusQuery, protocol: protocolQuery, page: currentPage, limit: LIMIT });
    try {
        const res  = await fetch(`/api/users?${params}`);
        const data = await res.json();

        if (res.status === 429) {
            showMsg('Demasiadas solicitudes. Intenta de nuevo en unos minutos.', 'text-red-400');
            return;
        }
        if (!res.ok) {
            console.error("Server error:", data.error);
            showMsg("Ocurrió un error en el sistema. Intenta de nuevo más tarde.", "text-red-400");
            return;
        }

        renderTable(data.users);
        renderPagination(data.totalPages, data.page);

    } catch (err) {
        console.error("Network error:", err);
        showMsg("No se pudo conectar al servidor. Verifica tu conexión.", "text-red-400");
    }
}

// = ====  Render===========
function renderTable(users) {
    const tbody = document.getElementById("users-tbody");
    if (!users.length) { showMsg("Sin resultados", "text-gray-400"); return; }

    tbody.innerHTML = users.map(u => `
        <tr class="border-b border-gray-100 hover:bg-blue-50 transition-colors duration-150">
            <td class="py-3 px-4 text-gray-500">${escapeHtml(u.reference_number)}</td>
            <td class="py-3 px-4 text-gray-800">${escapeHtml(u.fullName)}</td>
            <td class="py-3 px-4 text-center">${getStatusBadge(u.state)}</td>
            <td class="py-3 px-4 text-center text-gray-600 text-sm">${
                escapeHtml(u.protocol === 'Clinical' ? 'Clínico' : u.protocol === 'Research' ? 'Investigación' : '—')}</td> 
            <td class="py-3 px-4 flex justify-center">
                <button
                    onclick="consult('${escapeHtml(u.id)}')"
                    class="btn-mini bg-[#3350A9]">
                    <svg xmlns="http://www.w3.org/2000/svg" class="white-icon-mini" fill="none"
                        viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                            d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round"
                            d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943
                            9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                    </svg>
                    <span>Consultar</span>
                </button>
            </td>
        </tr>
    `).join("");
}

function renderPagination(totalPages, page) {
    const c = document.getElementById("pagination");
    c.innerHTML = "";
    if (totalPages <= 1) return;

    const btn = (label, disabled, onClick) => {
        const b = document.createElement("button");
        b.textContent = label;
        b.disabled = disabled;
        b.onclick = onClick;
        b.className = "btn-mini bg-[#002B7A] disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:scale-100 disabled:hover:shadow-none";
        return b;
    };

    const info = document.createElement("span");
    info.className = "text-sm text-gray-500";
    info.textContent = `Página ${page} de ${totalPages}`;

    c.append(
        btn("Anterior", page <= 1, () => { currentPage--; fetchUsers(); }),
        info,
        btn("Siguiente ", page >= totalPages, () => { currentPage++; fetchUsers(); })
    );
}

function showMsg(msg, colorClass) {
    document.getElementById("users-tbody").innerHTML =
   `<tr>
    <td colspan="5" class="py-10">
        <div class="flex justify-center items-center text-center ${escapeHtml(colorClass)}">
            ${escapeHtml(msg)}
        </div>
    </td>
    </tr>`;
    document.getElementById("pagination").innerHTML = "";
}

// = ==== User Finder===========
const searchInput     = document.getElementById("search-input");
searchInput.setAttribute("maxlength", MAX_SEARCH_LENGTH); // limit of characters

searchInput.addEventListener("input", e => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
        searchQuery = e.target.value.trim();
        currentPage = 1;
        fetchUsers();
    }, 400);
});

// = ==== Dropdown Status Filter ===========
const statusTrigger = document.getElementById("statusFilterTrigger");
const statusDropdown = document.getElementById("statusDropdown");
const statusOptions = document.querySelectorAll(".status-option");

statusTrigger.addEventListener("click", (e) => {
    e.stopPropagation(); 
    statusDropdown.classList.toggle("hidden");
});

document.addEventListener("click", (e) => {
    if (!statusTrigger.contains(e.target) && !statusDropdown.contains(e.target)) {
        statusDropdown.classList.add("hidden");
    }
});

statusOptions.forEach(option => {
    option.addEventListener("click", (e) => {
        statusQuery = e.currentTarget.getAttribute("data-value"); 
        currentPage = 1;
        statusDropdown.classList.add("hidden");
        fetchUsers();
    });
});

// = ==== Dropdown Protocol Filter ===========
const protocolTrigger = document.getElementById("protocolFilterTrigger");
const protocolDropdown = document.getElementById("protocolDropdown");
const protocolOptions = document.querySelectorAll(".protocol-option");

protocolTrigger.addEventListener("click", (e) => {
    e.stopPropagation(); 
    protocolDropdown.classList.toggle("hidden");
});

document.addEventListener("click", (e) => {
    if (!protocolTrigger.contains(e.target) && !protocolDropdown.contains(e.target)) {
        protocolDropdown.classList.add("hidden");
    }
});

protocolOptions.forEach(option => {
    option.addEventListener("click", (e) => {
        protocolQuery = e.currentTarget.getAttribute("data-value"); 
        currentPage = 1;
        protocolDropdown.classList.add("hidden");
        fetchUsers();
    });
});

function getStatusBadge(val) {
    const map = {
        'Discharged': { label: 'Alta',               border: '#E03232', text: '#E03232', bg: 'rgba(224,50,50,0.33)' },
        'Stand_by':   { label: 'Stand By',            border: '#1560BD', text: '#1560BD', bg: 'rgba(21,96,189,0.33)' },
        'Active':     { label: 'Activo',              border: '#1F893A', text: '#1F893A', bg: 'rgba(31,137,58,0.33)' },
        'Declined':   { label: 'No ingresó',          border: '#276076', text: '#276076', bg: 'rgba(39,96,118,0.33)' },
    };
    const m = map[val];
    if (!m) return `<span class="text-gray-300 text-xs"> - </span>`;
    return `<span class="btn-badge" style="border-color:${m.border}; color:${m.text}; background-color:${m.bg};">${m.label}</span>`;
}


function consult(id) { 
    window.location.href = `/users/${id}`
 }

fetchUsers();
</script>
</body>
</html>