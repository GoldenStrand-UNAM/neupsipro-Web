<div id="deleteUserModal" class="fixed inset-0 z-50 flex items-center justify-center hidden">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
    <div class="relative bg-white rounded-2xl p-8 max-w-md w-full mx-4 shadow-2xl text-center">

        <div class="mx-auto flex items-center justify-center h-20 w-20 rounded-full border-4 border-red-100 mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10 text-red-600">
                <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
            </svg>
        </div>

        <h2 class="text-2xl font-bold text-gray-900 mb-2">Eliminar usuario</h2>
        <p class="text-gray-600 mb-2 px-4">
            ¿Estás seguro de eliminar este usuario? Su información se ocultará del sistema, pero podrá restaurarse posteriormente.
        </p>

        <p id="deleteUserError" class="text-sm text-red-500 mb-4 hidden"></p>

        <div class="flex flex-col sm:flex-row gap-4 mt-6">
            <button id="cancelDeleteUser" class="flex-1 flex items-center justify-center gap-3 px-4 py-3 border border-gray-300 rounded-2xl font-semibold text-gray-700 hover:bg-gray-50 transition-colors cursor-pointer">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m9.75 9.75 4.5 4.5m0-4.5-4.5 4.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                </svg>
                <span class="whitespace-nowrap">Cancelar</span>
            </button>
            <button id="confirmDeleteUser" class="flex-1 flex items-center justify-center gap-3 px-4 py-3 bg-red-600 rounded-2xl font-semibold text-white hover:bg-red-700 transition-colors cursor-pointer disabled:opacity-60 disabled:cursor-not-allowed">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                </svg>
                <span class="whitespace-nowrap">Eliminar</span>
            </button>
        </div>
    </div>
</div>

<script>
(function () {
    const btnOptions = document.getElementById('btnUserOptions');
    const menu       = document.getElementById('userOptionsMenu');
    const btnEdit    = document.getElementById('btnEditUser');
    const btnDelete  = document.getElementById('btnDeleteUser');

    const modal       = document.getElementById('deleteUserModal');
    const btnCancel   = document.getElementById('cancelDeleteUser');
    const btnConfirm  = document.getElementById('confirmDeleteUser');
    const errorBox    = document.getElementById('deleteUserError');

    const user   = window.__USER_DATA__ || {};
    const idUser = user.idUser;

    // Dropdown toggle
    btnOptions?.addEventListener('click', (e) => {
        e.stopPropagation();
        menu.classList.toggle('hidden');
    });

    // Any click outside close the dropdown
    document.addEventListener('click', (e) => {
        if (menu && !menu.contains(e.target) && !btnOptions.contains(e.target)) {
            menu.classList.add('hidden');
        }
    });

    // edit button
    btnEdit?.addEventListener('click', () => {
        menu.classList.add('hidden');
        //window.location.href = `/users/${idUser}/edit`;
        window.location.href = `/construction`
    });

    // delete button, opens modal
    btnDelete?.addEventListener('click', () => {
        menu.classList.add('hidden');
        errorBox.classList.add('hidden');
        errorBox.textContent = '';
        modal.classList.remove('hidden');
    });

    // Cancel
    btnCancel?.addEventListener('click', () => {
        modal.classList.add('hidden');
    });

    // delete confirm
    btnConfirm?.addEventListener('click', async () => {
        if (!idUser) {
            errorBox.textContent = 'No se pudo identificar al usuario.';
            errorBox.classList.remove('hidden');
            return;
        }

        const originalHTML = btnConfirm.innerHTML;

        try {
            btnConfirm.disabled = true;
            btnConfirm.innerHTML = '<span>Eliminando...</span>';

            const res = await fetch(`/users/${idUser}`, {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
            });

            if (!res.ok) {
                const data = await res.json().catch(() => ({}));
                throw new Error(data.error || 'Error al eliminar usuario');
            }

            window.location.href = '/users';
        } catch (err) {
            errorBox.textContent = err.message;
            errorBox.classList.remove('hidden');
            btnConfirm.disabled = false;
            btnConfirm.innerHTML = originalHTML;
        }
    });
})();
</script>