@startuml ConsultCreateInterventionSequence
title Consult/Create Intervention - Sequence Diagram

actor User as U
participant "consultUser.ejs\n(Browser)" as ConsultView
participant "intervention.ejs\n(Browser)" as View
participant "Router" as Router
participant "Auth & Permissions\nMiddleware" as Auth
participant "intervention\nController" as Ctrl
participant "getInterventionUseCase" as UseCase
participant "ImpIntervention\nRepository" as Repo
database "MySQL DB" as DB

U -> ConsultView: Clicks "Consultar" (Intervention)
activate ConsultView
ConsultView -> Router: GET /users/:id_user/intervention
deactivate ConsultView
activate Router

Router -> Auth: verifyToken + requirePermission('consultation')
Auth --> Router: OK

Router -> Ctrl: getPage(req, res)
activate Ctrl
Ctrl -> UseCase: execute({ id_user })
activate UseCase

UseCase -> Repo: findByUser({ id_user })
activate Repo
Repo -> DB: SELECT intervention + user info (JOINs)
DB --> Repo: rows
Repo --> UseCase: Intervention or null
deactivate Repo

alt Intervention does not exist
    UseCase -> Repo: createIntervention({ id_user })
    activate Repo
    Repo -> DB: INSERT intervention (empty)
    DB --> Repo: created
    Repo --> UseCase: id_intervention
    deactivate Repo

    UseCase -> Repo: findByUser({ id_user })
    activate Repo
    Repo -> DB: SELECT intervention + user info
    DB --> Repo: rows
    Repo --> UseCase: Intervention (new)
    deactivate Repo
end

UseCase -> Repo: findSessionsByIntervention({ id_intervention })
activate Repo
Repo -> DB: SELECT sessions ORDER BY date ASC
DB --> Repo: session rows
Repo --> UseCase: sessions[]
deactivate Repo

UseCase --> Ctrl: intervention (with sessions)
deactivate UseCase
Ctrl --> Router: render('users/intervention')
deactivate Ctrl
Router --> View: HTML response
deactivate Router

View --> U: Display intervention page\n(user info, contract, profile, sessions table)

@enduml