@startuml ModifyStateSequence
title Modify User Status - Sequence Diagram

actor User as U
participant "consultUser.ejs\n(Browser)" as View
participant "statusModal.ejs\n(JS)" as Modal
participant "Express Router\n(getUser.Routes)" as Router
participant "Auth & Permissions\nMiddleware" as Auth
participant "modifyState\nController" as Ctrl
participant "modifyStateUseCase" as UseCase
participant "ImpUsers\nRepository" as Repo
database "MySQL DB" as DB

U -> View: Clicks "Estatus" field
activate View
View -> Modal: Open modal
activate Modal

Modal -> Modal: Show options\n(Activo, En espera, Alta, Rechazado)
Modal --> U: Display modal with form
deactivate Modal

U -> Modal: Selects new status
activate Modal
U -> Modal: Clicks "Guardar"
Modal -> Modal: Validate selection not empty
Modal -> Modal: Disable button, show "Guardando..."

Modal -> Router: PATCH /users/:id_user/state
activate Router
Router -> Auth: verifyToken + requirePermission('writing')
Auth --> Router: OK

Router -> Ctrl: modifyState(req, res)
activate Ctrl
Ctrl -> UseCase: execute({id_user, state})
activate UseCase

UseCase -> UseCase: Validate state enum\n(Active | Stand_by | Discharged | Declined)

alt Validation fails (invalid state / user not found)
  UseCase --> Ctrl: throw error
  Ctrl --> Router: 400 { error }
  Router --> Modal: error response
  Modal --> U: Show error message
else Valid request
  UseCase -> Repo: editUserState({id_user, state})
  activate Repo
  Repo -> DB: UPDATE user_info SET state = ?
  DB --> Repo: affectedRows
  Repo --> UseCase: updated user
  deactivate Repo

  UseCase --> Ctrl: UserDTO
  deactivate UseCase
  Ctrl --> Router: 200 OK + JSON
  deactivate Ctrl
  Router --> Modal: 200 OK
  deactivate Router

  Modal -> Modal: Show success toast
  Modal -> View: window.location.reload()
  deactivate Modal
  View --> U: Refresh page with\nupdated status visible
end

@enduml