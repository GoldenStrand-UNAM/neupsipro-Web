@startuml DeletePublicationActivity
title Delete Publication - Activity 

start

:User opens forum / post detail;
:User clicks delete icon;
:Confirmation modal opens;
:User clicks "Eliminar";
:Send DELETE /forum/:idPublication;

if (Auth & permissions OK?) then (yes)

    if (Publication exists?) then (yes)

        if (User is author or admin?) then (yes)

            :Delete all interactions\n(likes & comments);
            :Delete publication row in DB;

            if (Publication had image?) then (yes)
                :Delete image from S3 bucket;
            else (no)
            endif

            :Show success toast;
            :Redirect to forum;
            stop

        else (no)
            :Show "No autorizado" error (403);
            stop
        endif

    else (no)
        :Show "Not found" error (404);
        stop
    endif

else (no)
    :Reject request (401/403);
    stop
endif

@enduml