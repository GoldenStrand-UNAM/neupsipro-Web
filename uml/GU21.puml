@startuml GU05 Get-Clinical-User

title Get Clinical User - User Management (NeuPsi-Pro)

actor "Clinical Group" as CG

boundary "clinicalUserListView" as VUsers
boundary "clinicalUserView" as VOne
boundary "getClinicalUser\nRoutes" as ROUTE
control "getClinicalUser\nController" as CTRL
control "getClinicalUser\nUseCase" as UC
control "clinicalUser\nRepository" as REPO
entity "clinicalUser" as ENT
entity "ClinicalUserDTO" as DTO
database DB

CG -> VUsers : Click [Consultar Usuario (Clínico)]
VUsers -> MAIN : navigate\n('/clinical/{id_clinicalUser}')

MAIN -> ROUTE : GET /api/clinical/{id_clinicalUser}\n[Authorization: Bearer JWT]

ROUTE -> ROUTE : authMiddleware\nvalidate JWT
ROUTE -> CTRL : getClinicalUser(req, res)

CTRL -> CTRL : Extract id_clinicalUser from req.params

CTRL -> UC : execute({id_clinicalUser})

UC -> REPO : fetchOne({id_clinicalUser})

REPO --> DB : SELECT \nl.*, \nu.first_name,\nu.lastname_p,\nu.lastname_m,\nu.profile_photo,\nu.birthdate, \nur.id_clinic_user, \nuc.first_name AS assigned_clinic, \n(SELECT a.date_time \nFROM appointment a \nJOIN user_relation ur_app ON a.id_user_relation = ur_app.id_user_relation \nWHERE ur_app.id_user = l.id_user \nAND a.date_time >= NOW() \nORDER BY a.date_time ASC \nLIMIT 1 \n) AS next_appointment \nFROM user_info l \nJOIN users u ON l.id_user = u.id_user \nLEFT JOIN user_relation ur ON u.id_user = ur.id_user AND ur.type = 'assigned' \nLEFT JOIN users uc ON ur.id_clinic_user = uc.id_user \nWHERE l.id_user = ?;

DB --> REPO : rawData

REPO --> ENT : rawData

ENT --> UC : ClinicalUserEntity

UC --> CTRL : ClinicalUserEntity

CTRL -> DTO : map entities to DTO
DTO --> CTRL : UserDTO

CTRL --> ROUTE : HTTP 200 { data: ClinicalUserDTO }

ROUTE --> MAIN : HTTP 200 { data: clinicalUser }

MAIN -> VOne : navigate('/clinical/{id_clinicalUser}')\n+ data

VOne --> CG : Display one clinical user view


@enduml