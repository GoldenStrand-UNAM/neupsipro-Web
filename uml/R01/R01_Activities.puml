@startuml Registro de resultados de pruebas

start

:Select test;

:Show modal with options;
note right
- Registrar resultados
- Modificar resultados
- Consultar resultados
end note

:Select "Registrar resultados";

:Show register results modal;

:Enter score number;

:System interprets result automatically;

:Show live interpretation;
note right
Only one word
Example:
"Normal"
"Low"
"High"
end note

:Enter notes;

if (¿Desea guardar resultados?) then (Sí)

    :Validate data;

    if (¿Datos correctos?) then (Sí)

        :Save data in database;
        :Show confirmation message;
        stop

    else (No)

        :Show error message;
        stop

    endif

else (No)

    :Close modal;
    stop

endif

@enduml