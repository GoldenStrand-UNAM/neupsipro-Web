@startuml Post_REY

actor "Clinic User" as USR
participant "getTests.ejs" as VEJS
participant "optionsModal.js" as OMODAL
participant "rey.modal.js" as RMODAL
participant "testList.js" as TLIST
participant "UserRoutes" as UROUTE
participant "postREYController" as TCTRL
participant "postREYUseCase" as UC_POST
participant "impTestResultsRepository" as RREPO
database "DB" as DB

== Abrir modal de opciones ==

USR -> TLIST : Click [card REY]
TLIST -> OMODAL : openOptionsModal(idUser, idApplication, test)
OMODAL --> USR : Modal con opciones visible\n(Registrar / Modificar / Consultar)

USR -> OMODAL : Click [Registrar resultados]
OMODAL -> OMODAL : closeModal()
OMODAL -> RMODAL : config.openRegister(idUser, idApplication, test)\n→ openREYModal(idUser, idApplication, test, 'register')

== Carga de escolaridad y edad al abrir modal ==

RMODAL -> UROUTE : Promise.all([\nfetch GET /api/usuarios/:id_user/escolaridad,\nfetch GET /api/usuarios/:id_user/edad\n])

UROUTE -> RREPO : fetchUserSchooling({ id_user })
RREPO -> DB : SELECT ii.schooling\nFROM initial_interview ii\nINNER JOIN user_relation ur\n  ON ii.id_user_relation = ur.id_user_relation\nWHERE ur.id_user = ?\nLIMIT 1
DB --> RREPO : { schooling } | []
RREPO --> UROUTE : schooling | null
UROUTE --> RMODAL : HTTP 200 { schooling, years }

UROUTE -> RREPO : fetchUserAge({ id_user })
RREPO -> DB : SELECT birthdate\nFROM users\nWHERE id_user = ?
DB --> RREPO : { birthdate } | []
RREPO --> UROUTE : birthdate | null
UROUTE --> RMODAL : HTTP 200 { age }

RMODAL -> RMODAL : resolveSchoolingYears(schooling)\n'Sin escolaridad' → 0\n'Primaria'        → 6\n'Secundaria'      → 9\n'Bachillerato'    → 12\n'Licenciatura'    → 16\n'Posgrado'        → 18

RMODAL -> RMODAL : resolveEducationBlock(schoolingYears)\nyears > 12 → '>12'\nyears <= 12 → '1-12'

RMODAL -> RMODAL : resolveAgeRange(age)\n18-22 | 23-27 | ... | >77

alt sin escolaridad o edad registrada
    RMODAL --> USR : Banner: "No se pudieron cargar\nlos datos del paciente"
end

RMODAL --> USR : Modal de registro visible\nBanner: escolaridad + bloque\n+ edad + rango de edad

== Interpretación en vivo ==

USR -> RMODAL : Ingresa percentil (número)
RMODAL -> RMODAL : validateInput(percentile)\n- solo dígitos\n- no negativo\n- no > 95

alt Input inválido
    RMODAL --> USR : showScoreError(msg)\n"El percentil debe estar entre 0 y 95"
end

alt sin educationBlock o ageRange
    RMODAL --> USR : normativeLabel: "Sin datos suficientes"
end

RMODAL -> RMODAL : resolveNormativeScore(percentile,\neducationBlock, ageRange)\n1. Obtiene columna de REY_TABLE\n2. Convierte claves a números\n3. Busca el percentil más cercano\n4. En empate usa el percentil menor\n(interpretación clínica conservadora)\n5. Retorna el score exacto de la matriz
RMODAL --> USR : Muestra puntaje normativo en vivo\n(sin submit)

== Validación de notas ==

USR -> RMODAL : Ingresa notas
RMODAL -> RMODAL : contador actualiza\ntextContent = len / 200
RMODAL --> USR : Contador en rojo si len >= 200

== Guardar resultados ==

USR -> RMODAL : Click [Guardar]
RMODAL -> RMODAL : validate client-side\n- percentil válido (0-95)\n- notas max 200 chars

alt Datos inválidos
    RMODAL --> USR : showScoreError(msg)
end

RMODAL -> UROUTE : fetch POST /api/usuarios/:id_user/\naplicaciones/:id_application/pruebas/3/resultados\n{ score: percentile, notes }

UROUTE -> TCTRL : controller.postResult(req, res)
TCTRL -> UC_POST : execute({ id_user, id_application,\nscore: percentile, notes })

== Validaciones en Use Case ==

UC_POST -> UC_POST : validate score (percentile)\n- no vacío\n- es número\n- entre 0 y 95

alt percentile inválido
    UC_POST --> TCTRL : throw Error 422\n'score must be a valid number'
    TCTRL --> RMODAL : HTTP 422 { error }
    RMODAL --> USR : showApiError(json.error)
end

alt percentile fuera de rango
    UC_POST --> TCTRL : throw Error 422\n'score (percentile) must be between 0 and 95'
    TCTRL --> RMODAL : HTTP 422 { error }
    RMODAL --> USR : showApiError(json.error)
end

alt notes > 200 caracteres
    UC_POST --> TCTRL : throw Error 422\n'notes must be 200 characters or less'
    TCTRL --> RMODAL : HTTP 422 { error }
    RMODAL --> USR : showApiError(json.error)
end

UC_POST -> RREPO : fetchResultRow({ id_user, id_application, id_test: 3 })
RREPO -> DB : SELECT id_results, status\nFROM test_results\nWHERE id_user = ?\n  AND id_application = ?\n  AND id_test = 3
DB --> RREPO : { id_results, status } | []
RREPO --> UC_POST : { id_results, status } | null

alt result row not found (null)
    UC_POST --> TCTRL : throw Error 404\n'Test result row not found'
    TCTRL --> RMODAL : HTTP 404 { error }
    RMODAL --> USR : showApiError(json.error)
end

== Cálculo server-side ==

UC_POST -> RREPO : fetchUserSchooling({ id_user })
RREPO -> DB : SELECT ii.schooling\nFROM initial_interview ii\nINNER JOIN user_relation ur\n  ON ii.id_user_relation = ur.id_user_relation\nWHERE ur.id_user = ?\nLIMIT 1
DB --> RREPO : { schooling } | []
RREPO --> UC_POST : schooling | null

UC_POST -> RREPO : fetchUserAge({ id_user })
RREPO -> DB : SELECT birthdate\nFROM users\nWHERE id_user = ?
DB --> RREPO : { birthdate } | []
RREPO --> UC_POST : birthdate | null

UC_POST -> UC_POST : calculateAge(birthdate)
UC_POST -> UC_POST : resolveSchoolingYears(schooling)
UC_POST -> UC_POST : resolveEducationBlock(schoolingYears)
UC_POST -> UC_POST : resolveAgeRange(ageYears)

alt educationBlock o ageRange null
    UC_POST --> TCTRL : throw Error 422\n'Cannot calculate REY score:\nmissing age or schooling data'
    TCTRL --> RMODAL : HTTP 422 { error }
    RMODAL --> USR : showApiError(json.error)
end

UC_POST -> UC_POST : resolveNormativeScore\n(percentile, educationBlock, ageRange)\n1. Obtiene columna de REY_TABLE\n2. Convierte claves a números\n3. Busca el percentil más cercano\n4. En empate usa el percentil menor\n(interpretación clínica conservadora)\n5. Retorna el score exacto de la matriz

note right
  El servidor recalcula el puntaje normativo
  de forma independiente para no confiar
  en el cliente.
  score         → percentile (entrada clínico)
  interpretation → puntaje normativo (tabla)
  No hay interpolación — solo valores
  exactos de la matriz normativa.
end note

== Persistencia ==

UC_POST -> RREPO : saveResult({ id_results,\nscore: percentile,\ninterpretation: normativeScore,\nnotes })
RREPO -> DB : UPDATE test_results\nSET score          = ?,\n    interpretation = ?,\n    notes          = ?,\n    date_applied   = CURDATE(),\n    status         = 3\nWHERE id_results = ?
DB --> RREPO : OK
RREPO -> DB : SELECT tr.*, pt.test_name\nFROM test_results tr\nJOIN psych_tests pt ON tr.id_test = pt.id_test\nWHERE tr.id_results = ?
DB --> RREPO : { updated row }
RREPO --> UC_POST : Tests entity

UC_POST -> UC_POST : map entity → TestResultDTO
UC_POST --> TCTRL : TestResultDTO
TCTRL --> RMODAL : HTTP 200 { data: TestResultDTO }

== Actualizar UI ==

RMODAL -> RMODAL : closeModal()
RMODAL -> TLIST : updateTestCardStatus(dto)\nbadge → "Calificada"
RMODAL -> VEJS : showToast()\n"Resultado guardado con éxito"
VEJS --> USR : Modal cerrado\nCard actualizada con badge "Calificada"\nToast visible 3s

@enduml