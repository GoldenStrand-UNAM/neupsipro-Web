@startuml DeleteUserSequenceDiagram
title Delete User - Sequence Diagram

actor User as U
participant "consultUser.ejs\n(Browser)" as View
participant "deleteUserModal.ejs\n(JS)" as Modal
participant "Express Router\n(getUser.Routes)" as Router
participant "Auth & Permissions\nMiddleware" as Auth
participant "deleteUser\nController" as Controller
participant "deleteUserUseCase" as UseCase
participant "ImpUsersRepository" as Repo
database "MySQL\n(users table)" as DB

U -> View: Clicks options button
activate View
View -> View: Toggle dropdown menu
View --> U: Show "Edit / Delete" options
deactivate View

U -> View: Clicks "Delete"
activate View
View -> Modal: Open confirmation modal
activate Modal
Modal --> U: Display modal with warning
deactivate View

U -> Modal: Clicks "Confirm Delete"
Modal -> Router: DELETE /users/:id_user
activate Router

Router -> Auth: verifyToken()
activate Auth
Auth --> Router: Token valid
Router -> Auth: requirePermission('user management', 'eliminate')
Auth --> Router: Permission granted
deactivate Auth

Router -> Controller: deleteUser(req, res)
activate Controller
Controller -> UseCase: execute({ id_user })
activate UseCase

UseCase -> Repo: fetchOne({ id_user })
activate Repo
Repo -> DB: SELECT user info
DB --> Repo: User row
Repo --> UseCase: User entity
deactivate Repo

alt User not found
    UseCase --> Controller: throw "Usuario no encontrado"
    Controller --> Router: 404 { error }
    Router --> Modal: 404 response
    Modal --> U: Show error in modal
else User found
    UseCase -> Repo: softDeleteUser({ id_user })
    activate Repo
    Repo -> DB: UPDATE users SET eliminated = 1
    DB --> Repo: affectedRows > 0
    Repo --> UseCase: true
    deactivate Repo

    UseCase --> Controller: { success: true }
    deactivate UseCase
    Controller --> Router: 200 { success, message }
    deactivate Controller
    Router --> Modal: 200 OK
    deactivate Router
    Modal -> View: window.location = '/users'
    deactivate Modal
    View --> U: Redirect to users list\n(deleted user no longer visible)
end

@enduml