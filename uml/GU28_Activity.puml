@startuml DeleteLastSessionActivity
title Delete Last Session - Activity

start

:User clicks trash icon\n(only visible on last row);
:Confirmation modal opens;
:User clicks "Eliminar";
:Send DELETE /users/:id/intervention/sessions/:id_session;

if (Auth & permissions OK?) then (yes)

    if (Intervention exists?) then (yes)

        if (Sessions exist?) then (yes)

            if (id_session is the last one?) then (yes)
                :DELETE session from DB;
                :Show success toast;
                :Reload page;
                stop
            else (no)
                :Show "Only last session can be deleted" error;
                stop
            endif

        else (no)
            :Show "No sessions" error;
            stop
        endif

    else (no)
        :Show "No intervention" error;
        stop
    endif

else (no)
    :Reject request (401/403);
    stop
endif

@enduml