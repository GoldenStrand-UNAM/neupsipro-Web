@startuml GU05 Get-User

title Get User - User Management (Neurogolondrina)

actor "Clinical Group" as CG

boundary "userListView" as VUsers
boundary "userView" as VOne
control "main.js" as MAIN
boundary "getUser\nRoutes" as ROUTE
control "getUser\nController" as CTRL
control "getUser\nUseCase" as UC
control "users\nRepository" as REPO
control "testSessions\nRepository" as tsREPO
entity "User" as ENT
entity "UserDTO" as DTO
entity "testSessions" as tsENT
database DB

CG -> VUsers : Click [Consultar Usuario]
VUsers -> MAIN : navigate\n('/users/{id_user}')

MAIN -> ROUTE : GET /api/users/{id_user}\n[Authorization: Bearer JWT]

ROUTE -> ROUTE : authMiddleware\nvalidate JWT
ROUTE -> CTRL : getUser(req, res)

CTRL -> CTRL : Extract id_user from req.params

CTRL -> UC : execute({id_user})

UC -> REPO : fetchOne({id_user})

REPO --> DB : SELECT \nl.*, \nu.first_name,\nu.lastname_p,\nu.lastname_m,\nu.profile_photo,\nu.birthdate, \nur.id_clinic_user, \nuc.first_name AS assigned_clinic, \n(SELECT a.date_time \nFROM appointment a \nJOIN user_relation ur_app ON a.id_user_relation = ur_app.id_user_relation \nWHERE ur_app.id_user = l.id_user \nAND a.date_time >= NOW() \nORDER BY a.date_time ASC \nLIMIT 1 \n) AS next_appointment \nFROM user_info l \nJOIN users u ON l.id_user = u.id_user \nLEFT JOIN user_relation ur ON u.id_user = ur.id_user AND ur.type = 'assigned' \nLEFT JOIN users uc ON ur.id_clinic_user = uc.id_user \nWHERE l.id_user = ?;

DB --> REPO : rawData

REPO --> ENT : rawData

ENT --> UC : UserEntity

alt user.protocol

    UC -> tsREPO : fetchTestSessions({id_user})

    tsREPO --> DB : SELECT * \nFROM test_sessions ts \nWHERE ts.id_user = ?

    DB --> tsREPO : [testSessions]

    tsREPO -> tsENT : rawData

    tsENT --> tsREPO : TestSessionsEntity

    tsREPO --> UC : TestEntity

    UC --> CTRL : UserEntity
    UC --> CTRL : assignedSessions

    CTRL -> DTO : map entities to DTO
    DTO --> CTRL : UserDTO

    CTRL --> ROUTE : HTTP 200 { data: UserDTO, assignedSessions }

    ROUTE --> MAIN : HTTP 200 { data: user, assignedSessions }

    MAIN -> VOne : navigate('/users/{id_user}')\n+ data

    VOne --> CG : Display one user view
    
else !user.protocol

    UC --> CTRL : UserEntity

    CTRL -> DTO : map entities to DTO
    DTO --> CTRL : UserDTO

    CTRL --> ROUTE : HTTP 200 { data: UserDTO }

    ROUTE --> MAIN : HTTP 200 { data: user }

    MAIN -> VOne : navigate('/users/{id_user}')\n+ data

    VOne --> CG : Display one user view

end

@enduml