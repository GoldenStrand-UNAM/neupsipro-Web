@startuml EditContractProfileSequence
title Edit Contract & Neuropsych Profile - Sequence Diagram

actor User as U
participant "intervention.ejs\n(Browser)" as View
participant "editContractModal.ejs\n(JS)" as Modal
participant "Router" as Router
participant "Auth & Permissions\nMiddleware" as Auth
participant "intervention\nController" as Ctrl
participant "updateContractUseCase" as UseCase
participant "ImpIntervention\nRepository" as Repo
database "MySQL DB" as DB

U -> View: Clicks edit icon (contract or profile)
activate View
View -> Modal: Open modal with prefilled values
activate Modal
Modal --> U: Show form (link + profile)
deactivate View

U -> Modal: Edits link and/or profile
U -> Modal: Clicks "Guardar"
Modal -> Modal: Disable button, show "Guardando..."

Modal -> Router: PATCH /users/:id_user/intervention\n{ contract_link, neuro_profile }
activate Router

Router -> Auth: verifyToken + requirePermission('edit')
Auth --> Router: OK

Router -> Ctrl: updateContract(req, res)
activate Ctrl
Ctrl -> UseCase: execute({ id_user, contract_link, neuro_profile })
activate UseCase

UseCase -> Repo: findByUser({ id_user })
activate Repo
Repo -> DB: SELECT intervention
DB --> Repo: row
Repo --> UseCase: Intervention or null
deactivate Repo

alt No intervention found
    UseCase --> Ctrl: throw "No existe intervención"
    Ctrl --> Router: 400 { error }
    Router --> Modal: 400 response
    Modal --> U: Show error
else Intervention exists
    UseCase -> Repo: updateContract({ id_user, contract_link, neuro_profile })
    activate Repo
    Repo -> DB: UPDATE intervention SET ... WHERE id_user = ?
    DB --> Repo: affectedRows = 1
    Repo --> UseCase: true
    deactivate Repo

    UseCase --> Ctrl: { success: true }
    deactivate UseCase
    Ctrl --> Router: 200 OK
    deactivate Ctrl
    Router --> Modal: 200 OK
    deactivate Router

    Modal -> Modal: showToast("Datos guardados")
    Modal -> View: window.location.reload()
    deactivate Modal
    View --> U: Refresh page with new values
end

@enduml