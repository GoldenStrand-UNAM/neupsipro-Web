@startuml CancelAppointmentSequenceDiagram
title Cancel Appointment - Sequence Diagram

actor User as U
participant "consultUser.ejs\n(Browser)" as View
participant "cancelAppointmentModal.ejs\n(JS)" as Modal
participant "Express Router" as Router
participant "Auth & Permissions\nMiddleware" as Auth
participant "deleteAppointment\nController" as Ctrl
participant "deleteAppointmentUseCase" as UseCase
participant "ImpAppointment\nRepository" as Repo
database "MySQL DB" as DB

U -> View: Clicks "Cancelar cita"
activate View
View -> Modal: Open confirmation modal
activate Modal
Modal --> U: Show confirmation
deactivate View

U -> Modal: Clicks "Cancelar cita" (confirm)
Modal -> Modal: Disable button, show "Cancelando..."
Modal -> Router: DELETE /users/:id_user/appointments
activate Router

Router -> Auth: verifyToken + requirePermission('eliminate')
Auth --> Router: OK

Router -> Ctrl: deleteAppointment(req, res)
activate Ctrl
Ctrl -> UseCase: execute({ id_user })
activate UseCase

UseCase -> Repo: findUpcomingByUser({ id_user })
activate Repo
Repo -> DB: SELECT upcoming appointment
DB --> Repo: row or empty
Repo --> UseCase: Appointment or null
deactivate Repo

alt No upcoming appointment
    UseCase --> Ctrl: throw "No hay cita para cancelar"
    Ctrl --> Router: 404 { error }
    Router --> Modal: 404 response
    Modal --> U: Show error
else Upcoming appointment exists
    UseCase -> Repo: deleteUpcomingByUser({ id_user })
    activate Repo
    Repo -> DB: SELECT appointment + relation ids
    DB --> Repo: ids
    Repo -> DB: DELETE FROM appointment
    Repo -> DB: DELETE FROM user_relation
    DB --> Repo: success
    Repo --> UseCase: true
    deactivate Repo

    UseCase --> Ctrl: { success: true }
    deactivate UseCase
    Ctrl --> Router: 200 OK
    deactivate Ctrl
    Router --> Modal: 200 OK
    deactivate Router

    Modal -> Modal: showToast("Cita cancelada")
    Modal -> View: window.location.reload()
    deactivate Modal
    View --> U: Refresh page,\n"Próxima cita" gone
end

@enduml