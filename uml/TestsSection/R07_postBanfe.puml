@startuml Post_BANFE

actor "Clinic User" as USR
participant "getTests.ejs" as VEJS
participant "banfe.modal.js" as BMODAL
participant "options.modal.js" as OMODAL
participant "testList.js" as TLIST
participant "getTestsRoutes.js" as UROUTE
participant "postBANFEController" as TCTRL
participant "postBANFEUseCase" as UC_POST
participant "impTestResultsRepository" as RREPO
database "DB" as DB

== Abrir modal de opciones ==

USR -> TLIST : Click [card BANFE]
TLIST -> OMODAL : openOptionsModal(idUser, idApplication, test)
OMODAL --> USR : Modal con opciones visible\n(Registrar / Modificar / Consultar)\nModificar y Consultar habilitados\nsolo si test.status === 'Calificada'

USR -> OMODAL : Click [Registrar resultados]
OMODAL -> OMODAL : closeModal()
OMODAL -> BMODAL : config.openRegister(idUser, idApplication, test)\n→ openBANFEModal(idUser, idApplication, test, 'register')
BMODAL --> USR : Modal de registro visible\n(3 inputs de área + total en vivo + notas)

== Interpretación en vivo ==

USR -> BMODAL : Ingresa score en cualquier área
BMODAL -> BMODAL : strip non-digits\ninterpretBANFE(score)\n≤69 → "Alteración severa"\n70-84 → "Alteración leve-moderada"\n85-115 → "Normal"\n116+ → "Normal alto"
BMODAL --> USR : Interpretación en vivo por área\nPuntaje Total actualizado\n(suma de las 3 áreas)

== Validación de notas ==

USR -> BMODAL : Ingresa notas
BMODAL -> BMODAL : contador actualiza\ntextContent = len / 200
BMODAL --> USR : Contador visible en rojo\nsi len >= 200

== Guardar resultados ==

USR -> BMODAL : Click [Guardar]
BMODAL -> BMODAL : validate client-side\n- 3 scores presentes y no negativos\n- notas max 200 chars

alt Datos inválidos
    BMODAL --> USR : showFieldError(msg) por área
end

BMODAL -> UROUTE : fetch POST /api/usuarios/:id_user/\naplicaciones/:id_application/pruebas/1/resultados\n{ score_orbit_frontal, score_prefrontal_before,\n  score_d_lateral, notes }

UROUTE -> TCTRL : banfeController.postResult(req, res)
TCTRL -> UC_POST : execute({ id_user, id_application,\nscore_orbit_frontal, score_prefrontal_before,\nscore_d_lateral, notes })

== Validaciones en Use Case ==

UC_POST -> UC_POST : #parseAreaScore()\npor cada área:\n- no vacío\n- es número\n- no negativo

alt score inválido por área
    UC_POST --> TCTRL : throw Error 422\n'fieldName must be a valid number'
    TCTRL --> BMODAL : HTTP 422 { error }
    BMODAL --> USR : showApiError(json.error)
end

alt notes > 200 caracteres
    UC_POST --> TCTRL : throw Error 422\n'notes must be 200 characters or less'
    TCTRL --> BMODAL : HTTP 422 { error }
    BMODAL --> USR : showApiError(json.error)
end

UC_POST -> RREPO : fetchResultRow({ id_user, id_application, id_test: 1 })
RREPO -> DB : SELECT id_results, status\nFROM test_results\nWHERE id_user = ?\n  AND id_application = ?\n  AND id_test = 1
DB --> RREPO : { id_results, status } | []
RREPO --> UC_POST : { idResults, status } | null

alt result row not found (null)
    UC_POST --> TCTRL : throw Error 404\n'Test result row not found'
    TCTRL --> BMODAL : HTTP 404 { error }
    BMODAL --> USR : showApiError(json.error)
end

== Interpretación en Use Case ==

UC_POST -> UC_POST : resolveInterpretation(score) por área\n≤69 → "Alteración severa"\n70-84 → "Alteración leve-moderada"\n85-115 → "Normal"\n116+ → "Normal alto"\nscoreTotal = suma de las 3 áreas\n(sin interpretación)

note right
  El servidor recalcula la interpretación
  para no confiar en el cliente
end note

== Persistencia ==

UC_POST -> RREPO : saveBANFEResult({ id_results,\nscore_orbit_frontal, inter_orbit_frontal,\nscore_prefrontal_before, inter_prefrontal_before,\nscore_d_lateral, inter_d_lateral,\nscore_total, notes })

RREPO -> DB : UPDATE test_results\nSET status = 3,\n    date_applied = CURDATE()\nWHERE id_results = ?
DB --> RREPO : OK

RREPO -> DB : INSERT INTO banfe_results (...)\nVALUES (...)\nON DUPLICATE KEY UPDATE ...
DB --> RREPO : OK

RREPO -> DB : SELECT * FROM banfe_results\nWHERE id_results = ?
DB --> RREPO : { saved row }
RREPO --> UC_POST : raw banfe_results row

UC_POST -> UC_POST : map row → BanfeResultsDTO\n{ idResults, idTest, status: 3,\n  areas: { orbitFrontal, prefrontalBefore, dLateral },\n  scoreTotal, notes }
UC_POST --> TCTRL : BanfeResultsDTO
TCTRL --> BMODAL : HTTP 200 { data: BanfeResultsDTO }

== Actualizar UI ==

BMODAL -> BMODAL : closeModal()
BMODAL -> TLIST : updateTestCardStatus(dto)\nnormaliza status 3 → 'Calificada'\nbadge → "Calificada"
BMODAL -> VEJS : showToast()\n"Resultado guardado con éxito"
VEJS --> USR : Modal cerrado\nCard actualizada con badge "Calificada"\nToast visible 3s

@enduml