@startuml Post_Emotion

actor "Clinic User" as USR
participant "emotion.modal.js" as EMODAL
participant "options.modal.js" as OMODAL
participant "testList.js" as TLIST
participant "getTestsRoutes.js" as UROUTE
participant "postEmotionController" as TCTRL
participant "postEmotionUseCase" as UC_POST
participant "impTestResultsRepository" as RREPO
database "DB" as DB

== Abrir modal de opciones ==

USR -> TLIST : Click [card Adaptación Socioemocional]
TLIST -> OMODAL : openOptionsModal(idUser, idApplication, test, applicationStatus)
OMODAL --> USR : Modal con opciones visible\nRegistrar habilitado solo si status !== 'Calificada'\ny aplicación no caducada\nModificar y Consultar habilitados\nsolo si test.status === 'Calificada'

USR -> OMODAL : Click [Registrar resultados]
OMODAL -> OMODAL : closeModal()
OMODAL -> EMODAL : config.openRegister(idUser, idApplication, test)\n→ openEmotionModal(idUser, idApplication, test, 'register')
EMODAL --> USR : Modal de registro visible\n(IAB score + IDB score +\nnotas SCL-90 + tabs)

== Interpretación en vivo ==

USR -> EMODAL : Ingresa score IAB o IDB
EMODAL -> EMODAL : interpretAnxietyBeck(score)\n0-5 → Mínima\n6-15 → Leve\n16-30 → Moderada\n31-63 → Grave

EMODAL -> EMODAL : interpretDepressionBeck(score)\n0-13 → Mínima\n14-19 → Leve\n20-28 → Moderada\n29-63 → Grave

EMODAL --> USR : Interpretación en vivo por campo

== Guardar resultados ==

USR -> EMODAL : Click [Guardar]
EMODAL -> EMODAL : validate client-side\n- score_anxiety_beck presente 0-63\n- score_depression_beck presente 0-63\n- notes max 200 chars

alt Datos inválidos
    EMODAL --> USR : showFieldError(msg) por campo
end

EMODAL -> UROUTE : fetch POST /api/usuarios/:id_user/\naplicaciones/:id_application/pruebas/6/resultados\n{ score_anxiety_beck, score_depression_beck, notes }

UROUTE -> TCTRL : emotionController.postResult(req, res)
TCTRL -> UC_POST : execute({ id_user, id_application,\nscore_anxiety_beck,\nscore_depression_beck, notes })

== Validaciones en Use Case ==

UC_POST -> UC_POST : validate scores\n- no vacío\n- es número\n- entre 0 y 63

alt score inválido
    UC_POST --> TCTRL : throw Error 422\n'score must be between 0 and 63'
    TCTRL --> EMODAL : HTTP 422 { error }
    EMODAL --> USR : showApiError(json.error)
end

alt notes > 200 caracteres
    UC_POST --> TCTRL : throw Error 422\n'notes must be 200 characters or less'
    TCTRL --> EMODAL : HTTP 422 { error }
    EMODAL --> USR : showApiError(json.error)
end

UC_POST -> RREPO : fetchResultRow({ id_user, id_application, id_test: 6 })
RREPO -> DB : SELECT id_results, status\nFROM test_results\nWHERE id_user = ?\n  AND id_application = ?\n  AND id_test = 6
DB --> RREPO : { id_results, status } | []
RREPO --> UC_POST : { idResults, status } | null

alt result row not found
    UC_POST --> TCTRL : throw Error 404\n'Test result row not found'
    TCTRL --> EMODAL : HTTP 404 { error }
    EMODAL --> USR : showApiError(json.error)
end

== Interpretación en Use Case ==

UC_POST -> UC_POST : resolveAnxietyInterpretation(score)\n0-5 → Mínima\n6-15 → Leve\n16-30 → Moderada\n31-63 → Grave

UC_POST -> UC_POST : resolveDepressionInterpretation(score)\n0-13 → Mínima\n14-19 → Leve\n20-28 → Moderada\n29-63 → Grave

note right
  El servidor recalcula ambas interpretaciones
  de forma independiente — nunca confía en el cliente
end note

== Persistencia ==

UC_POST -> RREPO : saveEmotionResult({ id_results,\nscore_anxiety_beck, inter_anxiety_beck,\nscore_depression_beck, inter_depression_beck,\nnotes })

RREPO -> DB : UPDATE test_results\nSET status = 3,\n    date_applied = CURDATE()\nWHERE id_results = ?
DB --> RREPO : OK

RREPO -> DB : INSERT INTO emotion_results (...)\nVALUES (...)\nON DUPLICATE KEY UPDATE ...
DB --> RREPO : OK

RREPO -> DB : SELECT * FROM emotion_results\nWHERE id_results = ?
DB --> RREPO : { saved row }
RREPO --> UC_POST : raw emotion_results row

UC_POST -> UC_POST : map row → EmotionResultsDTO\n{ idResults, idTest, status: 3,\n  scoreAnxietyBeck, interAnxietyBeck,\n  scoreDepressionBeck, interDepressionBeck,\n  notes }
UC_POST --> TCTRL : EmotionResultsDTO
TCTRL --> EMODAL : HTTP 200 { data: EmotionResultsDTO }

== Actualizar UI ==

EMODAL -> EMODAL : closeModal()
EMODAL -> TLIST : updateTestCardStatus(dto)\nnormaliza status 3 → 'Calificada'\nbadge → "Calificada"
EMODAL -> TLIST : showToast()\n"Resultado guardado con éxito"
TLIST --> USR : Modal cerrado\nCard actualizada con badge "Calificada"\nToast visible 3s

@enduml