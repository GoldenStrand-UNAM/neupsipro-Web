@startuml DeletePublicationSequence
title Delete Publication - Sequence Diagram

actor User as U
participant "forum.ejs / postDetail.ejs\n(Browser)" as View
participant "deletePostModal.ejs\n(JS)" as Modal
participant "Express Router" as Router
participant "Auth & Permissions\nMiddleware" as Auth
participant "deletePublication\nController" as Ctrl
participant "deletePublicationUseCase" as UseCase
participant "ImpForum\nRepository" as ForumRepo
participant "ImpInteraction\nRepository" as IntRepo
participant "S3 Service\n(s3.config)" as S3
database "MySQL DB" as DB
database "AWS S3 Bucket" as Bucket

U -> View: Clicks delete icon on post
activate View
View -> Modal: Open confirmation modal
activate Modal
Modal --> U: "¿Eliminar publicación?\nEsta acción es permanente"
deactivate View

U -> Modal: Clicks "Eliminar"
Modal -> Modal: Disable button, show "Eliminando..."

Modal -> Router: DELETE /forum/:idPublication
activate Router

Router -> Auth: verifyToken + requirePermission('Forum', 'eliminate')
Auth --> Router: OK

Router -> Ctrl: deletePublication(req, res)
activate Ctrl
Ctrl -> UseCase: execute({ idPublication, idCurrentUser })
activate UseCase

' === Step 1: validate publication exists & ownership ===
UseCase -> ForumRepo: findById({ idPublication })
activate ForumRepo
ForumRepo -> DB: SELECT publication WHERE id_publication = ?
DB --> ForumRepo: row or empty
ForumRepo --> UseCase: publication or null
deactivate ForumRepo

alt Publication not found
    UseCase --> Ctrl: throw "Publicación no encontrada"
    Ctrl --> Router: 404 { error }
    Router --> Modal: 404 response
    Modal --> U: Show error
else Publication exists
    ' === Step 2: authorization check ===
    UseCase -> UseCase: Verify ownership or admin role

    alt Not the author and not admin
        UseCase --> Ctrl: throw "No autorizado"
        Ctrl --> Router: 403 { error }
        Router --> Modal: 403 response
        Modal --> U: Show error
    else Authorized
        ' === Step 3: delete interactions (FK constraint) ===
        UseCase -> IntRepo: deleteAllFromPublication({ idPublication })
        activate IntRepo
        IntRepo -> DB: DELETE FROM interaction WHERE id_publication = ?
        DB --> IntRepo: rows deleted
        IntRepo --> UseCase: success
        deactivate IntRepo

        ' === Step 4: delete publication row ===
        UseCase -> ForumRepo: deletePublication({ idPublication })
        activate ForumRepo
        ForumRepo -> DB: DELETE FROM publication WHERE id_publication = ?
        DB --> ForumRepo: affectedRows = 1
        ForumRepo --> UseCase: true
        deactivate ForumRepo

        ' === Step 5: delete image from S3 (if exists) ===
        alt Publication has image
            UseCase -> S3: deleteObject(image key)
            activate S3
            S3 -> Bucket: DELETE /forum/<filename>
            Bucket --> S3: success
            S3 --> UseCase: deleted
            deactivate S3
        end

        UseCase --> Ctrl: { success: true }
        deactivate UseCase
        Ctrl --> Router: 200 OK
        deactivate Ctrl
        Router --> Modal: 200 OK
        deactivate Router

        Modal -> Modal: showToast("Publicación eliminada")
        Modal -> View: redirect to /forum
        deactivate Modal
        View --> U: Forum list without the deleted post
    end
end

@enduml