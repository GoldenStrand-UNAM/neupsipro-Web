@startuml ScheduleAppointment
title Schedule Appointment 

actor User as U
participant "consultUser.ejs\n(Browser)" as View
participant "appointmentModal.ejs\n(JS)" as Modal
participant "Flatpickr\n(Date Picker)" as Picker
participant "Express Router\n(getUser.Routes)" as Router
participant "Auth & Permissions\nMiddleware" as Auth
participant "listClinics\nController" as ClinicsCtrl
participant "createAppointment\nController" as ApptCtrl
participant "listClinicsUseCase" as ClinicsUC
participant "createAppointmentUseCase" as ApptUC
participant "ImpClinical\nRepository" as ClinicRepo
participant "ImpAppointment\nRepository" as ApptRepo
database "MySQL DB" as DB

U -> View: Clicks "Agendar cita"
activate View
View -> Modal: Open modal
activate Modal

Modal -> Picker: initDatePicker()
activate Picker
Picker --> Modal: Date picker ready
deactivate Picker

Modal -> Router: GET /users/clinics/list
activate Router
Router -> Auth: verifyToken + requirePermission
Auth --> Router: OK
Router -> ClinicsCtrl: listClinics(req, res)
activate ClinicsCtrl
ClinicsCtrl -> ClinicsUC: execute()
activate ClinicsUC
ClinicsUC -> ClinicRepo: fetchAll()
activate ClinicRepo
ClinicRepo -> DB: SELECT clinics WHERE id_role = 3
DB --> ClinicRepo: rows
ClinicRepo --> ClinicsUC: clinics list
deactivate ClinicRepo
ClinicsUC --> ClinicsCtrl: clinics list
deactivate ClinicsUC
ClinicsCtrl --> Router: 200 OK + JSON
deactivate ClinicsCtrl
Router --> Modal: clinics list
deactivate Router

Modal -> Modal: Populate dropdown
Modal --> U: Show modal with form
deactivate Modal

U -> Modal: Selects date, clinic, issue
activate Modal
U -> Modal: Clicks "Agendar"
Modal -> Modal: Validate fields not empty
Modal -> Modal: Disable button, show "Agendando..."

Modal -> Router: POST /users/:id_user/appointments
activate Router
Router -> Auth: verifyToken + requirePermission
Auth --> Router: OK
Router -> ApptCtrl: createAppointment(req, res)
activate ApptCtrl
ApptCtrl -> ApptUC: execute({id_user, id_clinic_user, issue, date_time})
activate ApptUC

ApptUC -> ApptUC: Validate fields + future date
ApptUC -> ApptRepo: findUpcomingByUser({id_user})
activate ApptRepo
ApptRepo -> DB: SELECT next appointment
DB --> ApptRepo: row or empty
ApptRepo --> ApptUC: Appointment or null
deactivate ApptRepo

alt User already has upcoming appointment
    ApptUC --> ApptCtrl: throw "Already has appointment"
    ApptCtrl --> Router: 400 { error }
    Router --> Modal: 400 response
    Modal --> U: Show error message
else No upcoming appointment
    ApptUC -> ApptRepo: findOrCreateUserRelation({id_user, id_clinic_user})
    activate ApptRepo
    ApptRepo -> DB: SELECT user_relation
    DB --> ApptRepo: existing or empty

    alt Relation does not exist
        ApptRepo -> DB: INSERT user_relation (type='appointment')
        DB --> ApptRepo: created
    end

    ApptRepo --> ApptUC: id_user_relation
    deactivate ApptRepo

    ApptUC -> ApptRepo: createAppointment({id_user_relation, issue, date_time})
    activate ApptRepo
    ApptRepo -> DB: INSERT appointment
    DB --> ApptRepo: created
    ApptRepo --> ApptUC: id_appointment
    deactivate ApptRepo

    ApptUC --> ApptCtrl: { success, idAppointment }
    deactivate ApptUC
    ApptCtrl --> Router: 201 Created + JSON
    deactivate ApptCtrl
    Router --> Modal: 201 OK
    deactivate Router

    Modal -> Modal: Show success toast
    Modal -> View: window.location.reload()
    deactivate Modal
    View --> U: Refresh page with new\n"Próxima cita" visible
end

@enduml