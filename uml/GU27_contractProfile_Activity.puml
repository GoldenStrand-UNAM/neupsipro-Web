@startuml EditContractProfileActivity
title Edit Contract & Profile - Activity 

start

:User opens intervention page;
:User clicks edit icon\n(contract or profile);
:Modal opens with prefilled values;
:User modifies fields;
:User clicks "Guardar";
:Send PATCH /users/:id/intervention;

if (Auth & permissions OK?) then (yes)

    if (Intervention exists?) then (yes)
        :UPDATE intervention\n(contract_link, neuro_profile);
        :Show success toast;
        :Reload page;
        stop
    else (no)5
        :Show "Not found" error;
        stop
    endif

else (no)
    :Reject request (401/403);
    stop
endif

@enduml