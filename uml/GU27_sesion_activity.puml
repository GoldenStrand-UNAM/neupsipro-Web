@startuml AddSessionActivity
title Add Session - Activity 

start

:User clicks "+" button;
:Modal opens with empty form;
:User fills session data;
:User clicks "Agregar";

if (Date field filled?) then (yes)

    :Send POST /users/:id/intervention/sessions;

    if (Auth & permissions OK?) then (yes)

        if (Intervention exists?) then (yes)
            :INSERT new session;
            :Show success toast;
            :Reload page;
            stop
        else (no)
            :Show "No intervention" error;
            stop
        endif

    else (no)
        :Reject request (401/403);
        stop
    endif

else (no)
    :Show "Select date" error;
    stop
endif

@enduml